# ================== DATABASE ==================
MONGO_URL=mongodb://localhost:27017/shrigovindfarmacy

# ================== SERVER ==================
PORT=3000
NODE_ENV=development

# ================== SECURITY ==================
SESSION_SECRET=your-session-secret-key-here
ACCESS_SECRET=your-access-token-secret-key-here
REFRESH_SECRET=your-refresh-token-secret-key-here

# ================== PAYMENT GATEWAY ==================
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ================== EMAIL CONFIGURATION ==================
# Brevo (Sendinblue) SMTP Configuration
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=your-brevo-smtp-username
EMAIL_PASS=your-brevo-smtp-password
EMAIL_FROM=noreply@yourdomain.com

# ================== SMS CONFIGURATION ==================
SMS_PROVIDER=bravo
BRAVO_MOCK_MODE=false
BRAVO_API_KEY=your-bravo-api-key
BRAVO_SENDER_ID=SGPHAR
BRAVO_BASE_URL=https://api.bravo-sms.com

# ================== FILE UPLOAD ==================
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ================== GOOGLE OAUTH ==================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
