<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>COD Tracking - Shri Govind Pharmacy</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root {
            --primary: #1c8125;
            --primary-dark: #145a1a;
            --bg: #f8f9fa;
            --surface: #ffffff;
            --text: #1a1a1a;
            --text-muted: #6c757d;
            --border: #e9ecef;
            --success: #28a745;
            --danger: #dc3545;
            --warning: #ffc107;
            --shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        }
        [data-theme="dark"] {
            --bg: #121212;
            --surface: #1e1e1e;
            --text: #e0e0e0;
            --text-muted: #a0a0a0;
            --border: #2d2d2d;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; padding: 2rem; }
        
        .header {
            max-width: 1200px;
            margin: 0 auto 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .header h1 { color: var(--primary); font-size: 28px; }
        
        .btn {
            padding: 12px 24px;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s;
        }
        .btn-primary { background: var(--primary); color: white; }
        .btn-primary:hover { background: var(--primary-dark); }
        .btn-outline { border: 2px solid var(--border); background: transparent; color: var(--text); }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            max-width: 1200px;
            margin: 0 auto 2rem;
        }
        
        .stat-card {
            background: var(--surface);
            padding: 24px;
            border-radius: 12px;
            box-shadow: var(--shadow);
            border-left: 4px solid var(--primary);
        }
        .stat-card.pending { border-left-color: var(--warning); }
        .stat-card.paid { border-left-color: var(--success); }
        
        .stat-label { font-size: 14px; color: var(--text-muted); margin-bottom: 8px; }
        .stat-value { font-size: 32px; font-weight: 700; color: var(--text); }
        .stat-sub { font-size: 12px; color: var(--text-muted); margin-top: 8px; }
        
        .card {
            background: var(--surface);
            border-radius: 12px;
            padding: 24px;
            box-shadow: var(--shadow);
            max-width: 1200px;
            margin: 0 auto 2rem;
        }
        
        .card-title {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid var(--border); }
        th { font-weight: 600; color: var(--text-muted); font-size: 13px; text-transform: uppercase; }
        tr:hover { background: var(--bg); }
        
        .badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }
        .badge-collected { background: #fff3cd; color: #856404; }
        .badge-paid { background: #d4edda; color: #155724; }
        
        .pay-form {
            display: grid;
            gap: 15px;
            max-width: 500px;
        }
        
        .form-group { display: flex; flex-direction: column; gap: 5px; }
        .form-group label { font-weight: 600; font-size: 14px; }
        .form-group input, .form-group select {
            padding: 10px;
            border: 2px solid var(--border);
            border-radius: 8px;
            font-size: 14px;
        }
        
        .alert {
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
        }
        .alert-warning { background: #fff3cd; color: #856404; border: 1px solid #ffc107; }
        .alert-success { background: #d4edda; color: #155724; border: 1px solid #28a745; }
    </style>
</head>
<body>
    <div class="header">
        <div>
            <h1><i class="fas fa-wallet"></i> COD Tracking</h1>
            <p style="color: var(--text-muted);">Manage your Cash on Delivery collections</p>
        </div>
        <a href="/agent/deliveries" class="btn btn-outline">
            <i class="fas fa-arrow-left"></i> Back to Deliveries
        </a>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-label"><i class="fas fa-coins"></i> Total Collected</div>
            <div class="stat-value">₹<%= codTracking.totalCollected.toFixed(2) %></div>
            <div class="stat-sub">Lifetime COD collections</div>
        </div>
        
        <div class="stat-card pending">
            <div class="stat-label"><i class="fas fa-exclamation-circle"></i> Pending to Pay</div>
            <div class="stat-value" style="color: var(--warning);">₹<%= codTracking.pendingToPay.toFixed(2) %></div>
            <div class="stat-sub">Amount to be paid to admin</div>
        </div>
        
        <div class="stat-card paid">
            <div class="stat-label"><i class="fas fa-check-circle"></i> Paid to Admin</div>
            <div class="stat-value" style="color: var(--success);">₹<%= codTracking.paidToAdmin.toFixed(2) %></div>
            <div class="stat-sub">Total paid</div>
        </div>
    </div>

    <% if (codTracking.pendingToPay > 0) { %>
    <div class="card">
        <h3 class="card-title"><i class="fas fa-hand-holding-usd"></i> Pay COD to Admin</h3>
        <div class="alert alert-warning">
            <i class="fas fa-info-circle"></i> You have <strong>₹<%= codTracking.pendingToPay.toFixed(2) %></strong> pending to pay to admin.
        </div>
        
        <form class="pay-form" id="payForm">
            <div class="form-group">
                <label>Amount to Pay (₹)</label>
                <input type="number" name="amount" id="amount" min="1" max="<%= codTracking.pendingToPay %>" step="0.01" required>
            </div>
            
            <div class="form-group">
                <label>Payment Method</label>
                <select name="paymentMethod" id="paymentMethod" required>
                    <option value="cash">Cash</option>
                    <option value="upi">UPI</option>
                    <option value="bank_transfer">Bank Transfer</option>
                    <option value="other">Other</option>
                </select>
            </div>
            
            <div class="form-group">
                <label>Transaction ID / Reference (Optional)</label>
                <input type="text" name="transactionId" id="transactionId" placeholder="e.g., UPI TXN ID">
            </div>
            
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-paper-plane"></i> Submit Payment
            </button>
        </form>
    </div>
    <% } %>

    <div class="card">
        <h3 class="card-title"><i class="fas fa-history"></i> Recent Transactions</h3>
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Order ID</th>
                    <th>Amount</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                <% if (recentTransactions.length === 0) { %>
                <tr>
                    <td colspan="5" style="text-align: center; color: var(--text-muted);">No transactions yet</td>
                </tr>
                <% } else { %>
                    <% recentTransactions.forEach(txn => { %>
                    <tr>
                        <td><%= new Date(txn.timestamp).toLocaleDateString('en-IN') %></td>
                        <td>
                            <span class="badge <%= txn.type === 'collected' ? 'badge-collected' : 'badge-paid' %>">
                                <%= txn.type === 'collected' ? '📥 Collected' : '📤 Paid' %>
                            </span>
                        </td>
                        <td><%= txn.orderTrackingId || 'N/A' %></td>
                        <td><strong>₹<%= txn.amount.toFixed(2) %></strong></td>
                        <td style="color: var(--text-muted); font-size: 13px;"><%= txn.notes || '-' %></td>
                    </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>

    <script>
        document.getElementById('payForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const formData = {
                amount: parseFloat(document.getElementById('amount').value),
                paymentMethod: document.getElementById('paymentMethod').value,
                transactionId: document.getElementById('transactionId').value
            };
            
            try {
                const response = await fetch('/agent/cod/pay', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                });
                
                const result = await response.json();
                
                if (result.success) {
                    alert(result.message);
                    window.location.reload();
                } else {
                    alert('Error: ' + result.message);
                }
            } catch (err) {
                alert('Failed to submit payment');
                console.error(err);
            }
        });
    </script>
</body>
</html>
