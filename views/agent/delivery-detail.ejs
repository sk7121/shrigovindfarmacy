<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delivery Details - <%= delivery.qrCode %></title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root {
            --primary: #1c8125;
            --primary-dark: #145a1a;
            --secondary: #e67e22;
            --bg: #f8f9fa;
            --surface: #ffffff;
            --text: #1a1a1a;
            --text-muted: #6c757d;
            --border: #e9ecef;
            --success: #28a745;
            --danger: #dc3545;
            --warning: #ffc107;
            --info: #17a2b8;
            --shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        }
        [data-theme="dark"] {
            --bg: #121212;
            --surface: #1e1e1e;
            --text: #e0e0e0;
            --text-muted: #a0a0a0;
            --border: #2d2d2d;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }

        .header {
            background: var(--surface);
            padding: 20px;
            box-shadow: var(--shadow);
            margin-bottom: 30px;
        }
        .header-content {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }
        .header h1 { color: var(--primary); font-size: 24px; }

        .container { max-width: 1200px; margin: 0 auto; padding: 20px; }

        .btn {
            padding: 12px 24px;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s;
            font-size: 14px;
        }
        .btn-primary { background: var(--primary); color: white; }
        .btn-primary:hover { background: var(--primary-dark); transform: translateY(-2px); }
        .btn-success { background: var(--success); color: white; }
        .btn-outline { border: 2px solid var(--border); background: transparent; color: var(--text); }
        .btn-outline:hover { border-color: var(--primary); color: var(--primary); }
        .btn-danger { background: var(--danger); color: white; }
        .btn:disabled { opacity: 0.5; cursor: not-allowed; }
        .btn-sm { padding: 8px 16px; font-size: 13px; }
        .btn-block { width: 100%; justify-content: center; }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
        }

        .card {
            background: var(--surface);
            border-radius: 12px;
            padding: 24px;
            box-shadow: var(--shadow);
        }

        .card-title {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 16px;
            color: var(--primary);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            padding: 12px 0;
            border-bottom: 1px solid var(--border);
        }
        .info-row:last-child { border-bottom: none; }
        .info-label { color: var(--text-muted); font-weight: 500; }
        .info-value { font-weight: 600; }

        .status-badge {
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            text-transform: capitalize;
        }
        .status-badge.out_for_delivery { background: #e2e3e5; color: #383d41; }
        .status-badge.assigned { background: #d1ecf1; color: #0c5460; }
        .status-badge.processing { background: #fff3cd; color: #856404; }
        .status-badge.delivered { background: #d4edda; color: #155724; }

        .flash {
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
        }
        .flash.success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
        .flash.error { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
        .flash.warning { background: #fff3cd; color: #856404; border: 1px solid #ffeaa7; }
        .flash.info { background: #d1ecf1; color: #0c5460; border: 1px solid #bee5eb; }

        .qr-code-container {
            text-align: center;
            padding: 20px;
        }
        .qr-code-container img {
            max-width: 250px;
            border: 4px solid var(--border);
            border-radius: 8px;
            padding: 10px;
            background: white;
        }

        .otp-display {
            font-size: 32px;
            font-weight: 700;
            letter-spacing: 8px;
            text-align: center;
            padding: 20px;
            background: var(--bg);
            border-radius: 8px;
            border: 2px dashed var(--primary);
            margin: 15px 0;
            color: var(--primary);
        }

        .alert-box {
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            border-left: 4px solid;
        }
        .alert-box.warning {
            background: #fff3cd;
            border-color: var(--warning);
            color: #856404;
        }
        .alert-box.info {
            background: #d1ecf1;
            border-color: var(--info);
            color: #0c5460;
        }
        .alert-box.success {
            background: #d4edda;
            border-color: var(--success);
            color: #155724;
        }

        @media (max-width: 768px) {
            .header-content {
                flex-direction: column;
                align-items: flex-start;
            }
            .grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="header-content">
            <div>
                <h1><i class="fas fa-shipping-fast"></i> Delivery Details</h1>
                <p style="color: var(--text-muted);">
                    Order: <%= delivery.order?.tracking?.orderId || delivery.order?._id?.toString?.().slice(-4) || 'N/A' %>
                </p>
            </div>
            <a href="/agent/deliveries" class="btn btn-outline">
                <i class="fas fa-list"></i> Back to Deliveries
            </a>
        </div>
    </div>

    <div class="container">
        <% if (locals.success && success.length > 0) { %>
            <div class="flash success"><%= success %></div>
        <% } %>
        <% if (locals.error && error.length > 0) { %>
            <div class="flash error"><%= error %></div>
        <% } %>
        <% if (locals.info && info.length > 0) { %>
            <div class="flash info"><%= info %></div>
        <% } %>

        <div class="grid">
            <!-- Delivery Status Card -->
            <div class="card">
                <h3 class="card-title"><i class="fas fa-info-circle"></i> Delivery Status</h3>
                <div class="info-row">
                    <span class="info-label"><i class="fas fa-hashtag"></i> QR Code</span>
                    <span class="info-value" style="font-size: 12px;"><%= delivery.qrCode %></span>
                </div>
                <div class="info-row">
                    <span class="info-label"><i class="fas fa-circle-notch"></i> Status</span>
                    <span class="status-badge <%= delivery.status %>"><%= delivery.status.replace('_', ' ') %></span>
                </div>
                <div class="info-row">
                    <span class="info-label"><i class="fas fa-calendar"></i> Assigned At</span>
                    <span class="info-value"><%= new Date(delivery.assignedAt).toLocaleString() %></span>
                </div>
                <% if (delivery.priority) { %>
                <div class="info-row">
                    <span class="info-label"><i class="fas fa-flag"></i> Priority</span>
                    <span class="info-value" style="text-transform: capitalize;"><%= delivery.priority %></span>
                </div>
                <% } %>
                <% if (delivery.codAmount > 0) { %>
                <div class="info-row" style="background: #fff3cd; padding: 10px; border-radius: 8px; margin-top: 10px;">
                    <span class="info-label"><i class="fas fa-money-bill-wave"></i> COD Amount</span>
                    <span class="info-value" style="color: var(--warning); font-size: 18px;">₹<%= delivery.codAmount %></span>
                </div>
                <% } %>
            </div>

            <!-- Customer Details Card -->
            <div class="card">
                <h3 class="card-title"><i class="fas fa-user-circle"></i> Customer Details</h3>
                <%
                    const customerInfo = delivery.deliveryAddress?.fullName ? delivery.deliveryAddress :
                                        (delivery.order?.address?.fullName ? delivery.order.address :
                                        (delivery.order?.shippingAddress?.fullName ? delivery.order.shippingAddress : {}));
                    const customerName = customerInfo.fullName || customerInfo.name || 'N/A';
                    const customerPhone = customerInfo.phone || 'N/A';
                    const customerEmail = customerInfo.email || delivery.order?.address?.email || 'N/A';
                    const customerAddress = customerInfo.address || 'N/A';
                    const customerCity = customerInfo.city || '';
                    const customerState = customerInfo.state || '';
                    const customerPincode = customerInfo.pincode || '';
                    const customerLandmark = customerInfo.landmark || '';
                %>
                <div class="info-row">
                    <span class="info-label"><i class="fas fa-user"></i> Name</span>
                    <span class="info-value"><%= customerName %></span>
                </div>
                <div class="info-row">
                    <span class="info-label"><i class="fas fa-phone"></i> Phone</span>
                    <span class="info-value">
                        <a href="tel:<%= customerPhone %>" style="color: var(--primary);">
                            <%= customerPhone %>
                            <i class="fas fa-external-link-alt" style="font-size: 12px; margin-left: 5px;"></i>
                        </a>
                    </span>
                </div>
                <div class="info-row">
                    <span class="info-label"><i class="fas fa-envelope"></i> Email</span>
                    <span class="info-value"><%= customerEmail %></span>
                </div>
                <div class="info-row">
                    <span class="info-label"><i class="fas fa-map-marker-alt"></i> Address</span>
                    <span class="info-value">
                        <%= customerAddress %><br>
                        <small style="color: var(--text-muted);">
                            <%= customerLandmark ? customerLandmark + ', ' : '' %>
                            <%= customerCity %>, <%= customerState %> - <%= customerPincode %>
                        </small>
                    </span>
                </div>
                <div style="margin-top: 20px; display: flex; gap: 10px; flex-wrap: wrap;">
                    <a href="https://www.google.com/maps/search/?api=1&query=<%= encodeURIComponent(customerAddress + ', ' + customerCity + ', ' + customerPincode) %>"
                       target="_blank"
                       class="btn btn-primary btn-sm">
                        <i class="fas fa-map-marked-alt"></i> Navigate
                    </a>
                    <a href="tel:<%= customerPhone %>"
                       class="btn btn-success btn-sm">
                        <i class="fas fa-phone"></i> Call Customer
                    </a>
                </div>
            </div>

            <!-- QR Code Card -->
            <div class="card">
                <h3 class="card-title"><i class="fas fa-qrcode"></i> Delivery QR Code</h3>
                <div class="qr-code-container">
                    <% if (qrLabel && qrLabel.qrCodeUrl) { %>
                        <img src="<%= qrLabel.qrCodeUrl %>" alt="Delivery QR Code">
                        <p style="margin-top: 15px; color: var(--text-muted); font-size: 13px;">
                            <i class="fas fa-info-circle"></i> Show this QR code to customer for verification
                        </p>
                    <% } else { %>
                        <div class="alert-box warning">
                            <i class="fas fa-exclamation-triangle"></i> QR code generation failed
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- Delivery OTP Card -->
            <div class="card">
                <h3 class="card-title"><i class="fas fa-key"></i> Delivery OTP</h3>
                <div class="alert-box info">
                    <strong><i class="fas fa-info-circle"></i> Instructions:</strong>
                    <p style="margin-top: 8px; font-size: 13px;">
                        This OTP is for customer verification. Ask the customer to provide this 6-digit code to confirm the delivery.
                    </p>
                </div>
                <%
                    const deliveryOTP = delivery.order?.deliveryOTP?.code || OTP || '000000';
                    const otpExpiresAt = delivery.order?.deliveryOTP?.expiresAt;
                %>
                <div class="otp-display"><%= deliveryOTP %></div>
                <% if (otpExpiresAt) { %>
                <p style="text-align: center; color: var(--text-muted); font-size: 13px;">
                    <i class="fas fa-clock"></i> Valid until: <%= new Date(otpExpiresAt).toLocaleString() %>
                </p>
                <% } %>
            </div>

            <!-- Order Items Card -->
            <div class="card">
                <h3 class="card-title"><i class="fas fa-box"></i> Order Items</h3>
                <% if (delivery.order?.items && delivery.order.items.length > 0) { %>
                    <ul style="list-style: none; padding: 0;">
                        <% delivery.order.items.forEach(item => { %>
                            <li class="info-row">
                                <span class="info-label">
                                    <%= item.name %>
                                    <% if (item.quantity > 1) { %>
                                        <span style="color: var(--primary);">x<%= item.quantity %></span>
                                    <% } %>
                                </span>
                                <% if (item.price) { %>
                                    <span class="info-value">₹<%= item.price %></span>
                                <% } %>
                            </li>
                        <% }) %>
                    </ul>
                <% } else { %>
                    <p style="color: var(--text-muted);">No items information available</p>
                <% } %>
            </div>

            <!-- Actions Card -->
            <div class="card">
                <h3 class="card-title"><i class="fas fa-tools"></i> Actions</h3>
                
                <% if (delivery.status === 'picked_up') { %>
                    <!-- Show Complete Delivery button ONLY when picked_up -->
                    <a href="/agent/delivery/<%= delivery._id %>" class="btn btn-success btn-block">
                        <i class="fas fa-check-circle"></i> Complete Delivery
                    </a>
                <% } else if (delivery.status === 'out_for_delivery') { %>
                    <!-- Out for delivery - waiting for pickup -->
                    <div class="alert-box warning" style="padding: 10px; font-size: 13px; margin-bottom: 10px; background: #fff3cd; border: 1px solid #ffeaa7; color: #856404;">
                        <i class="fas fa-truck"></i> 
                        <strong>Out for Delivery - Awaiting Pickup!</strong><br>
                        The delivery is out for delivery but items have not been picked up yet.
                        You must confirm pickup before you can complete the delivery.
                    </div>
                <% } else if (delivery.status === 'assigned' || delivery.status === 'processing') { %>
                    <!-- Show Start Delivery button for assigned/processing status -->
                    <div class="alert-box error" style="padding: 10px; font-size: 13px; margin-bottom: 10px; background: #f8d7da; border: 1px solid #f5c6cb; color: #721c24;">
                        <i class="fas fa-lock"></i> 
                        <strong>Completion Locked - Delivery Not Started!</strong><br>
                        You cannot access the delivery completion page until the delivery is marked as "Picked Up".
                        Click the button below to start the delivery first.
                    </div>
                    <form action="/agent/delivery/<%= delivery._id %>/start" method="POST" style="display: inline;">
                        <button type="submit" class="btn btn-primary btn-block">
                            <i class="fas fa-play"></i> Start Delivery (Mark as Out for Delivery)
                        </button>
                    </form>
                <% } else { %>
                    <!-- Show status message for other states -->
                    <div class="alert-box warning" style="padding: 10px; font-size: 13px; margin-bottom: 10px;">
                        <i class="fas fa-exclamation-triangle"></i> Delivery cannot be completed in current status: <strong><%= delivery.status.replace('_', ' ') %></strong>
                    </div>
                <% } %>
                
                <button type="button" onclick="window.print()" class="btn btn-outline btn-block">
                    <i class="fas fa-print"></i> Print Details
                </button>
            </div>
        </div>
    </div>

    <script>
        // Auto-hide flash messages after 5 seconds
        document.addEventListener('DOMContentLoaded', () => {
            const flashes = document.querySelectorAll('.flash');
            flashes.forEach(flash => {
                setTimeout(() => {
                    flash.style.transition = 'opacity 0.5s';
                    flash.style.opacity = '0';
                    setTimeout(() => flash.remove(), 500);
                }, 5000);
            });
        });
    </script>
</body>
</html>
