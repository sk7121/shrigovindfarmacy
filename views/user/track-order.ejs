<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Track Your Order — Shri Govind Pharmacy</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root {
            --primary: #1c8125;
            --primary-dark: #145a1a;
            --secondary: #e67e22;
            --bg: #f8f9fa;
            --surface: #ffffff;
            --text: #1a1a1a;
            --text-muted: #6c757d;
            --border: #e9ecef;
            --success: #28a745;
            --danger: #dc3545;
            --warning: #ffc107;
            --info: #17a2b8;
            --shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        }
        [data-theme="dark"] {
            --bg: #121212;
            --surface: #1e1e1e;
            --text: #e0e0e0;
            --text-muted: #a0a0a0;
            --border: #2d2d2d;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; }
        
        .tracking-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 40px 20px;
        }
        
        .header {
            text-align: center;
            color: white;
            margin-bottom: 30px;
        }
        
        .header h1 {
            font-size: 32px;
            margin-bottom: 10px;
        }
        
        .header p {
            opacity: 0.9;
        }
        
        .search-box {
            background: var(--surface);
            padding: 30px;
            border-radius: 16px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
            margin-bottom: 30px;
        }
        
        .search-form {
            display: flex;
            gap: 10px;
        }
        
        .search-input {
            flex: 1;
            padding: 15px 20px;
            border: 2px solid var(--border);
            border-radius: 10px;
            font-size: 16px;
            transition: border-color 0.3s;
        }
        
        .search-input:focus {
            outline: none;
            border-color: var(--primary);
        }
        
        .btn {
            padding: 15px 30px;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
            font-size: 16px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s;
        }
        
        .btn-primary {
            background: var(--primary);
            color: white;
        }
        
        .btn-primary:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
        }
        
        .error-box {
            background: #f8d7da;
            color: #721c24;
            padding: 15px 20px;
            border-radius: 10px;
            margin-bottom: 20px;
            border: 1px solid #f5c6cb;
        }
        
        .tracking-result {
            background: var(--surface);
            border-radius: 16px;
            padding: 30px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
        }
        
        .tracking-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-bottom: 20px;
            border-bottom: 2px solid var(--border);
            margin-bottom: 20px;
        }
        
        .order-info h2 {
            color: var(--primary);
            margin-bottom: 5px;
        }
        
        .order-info p {
            color: var(--text-muted);
        }
        
        .status-badge {
            padding: 10px 20px;
            border-radius: 25px;
            font-size: 14px;
            font-weight: 600;
            text-transform: capitalize;
        }
        
        .status-badge.delivered { background: #d4edda; color: #155724; }
        .status-badge.in_transit { background: #cce5ff; color: #004085; }
        .status-badge.out_for_delivery { background: #d6d8d9; color: #1b1e21; }
        .status-badge.pending_assignment { background: #f8d7da; color: #721c24; }
        .status-badge.assigned { background: #fff3cd; color: #856404; }
        .status-badge.picked_up { background: #d1ecf1; color: #0c5460; }
        
        /* Progress Steps */
        .progress-steps {
            display: flex;
            justify-content: space-between;
            margin: 40px 0;
            position: relative;
        }
        
        .progress-steps::before {
            content: '';
            position: absolute;
            top: 20px;
            left: 0;
            right: 0;
            height: 3px;
            background: var(--border);
            z-index: 1;
        }
        
        .step {
            position: relative;
            z-index: 2;
            text-align: center;
            flex: 1;
        }
        
        .step-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--border);
            color: var(--text-muted);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 10px;
            font-size: 16px;
            transition: all 0.3s;
        }
        
        .step.active .step-icon {
            background: var(--primary);
            color: white;
            transform: scale(1.2);
        }
        
        .step.completed .step-icon {
            background: var(--success);
            color: white;
        }
        
        .step-label {
            font-size: 12px;
            color: var(--text-muted);
            font-weight: 500;
        }
        
        .step.active .step-label {
            color: var(--primary);
            font-weight: 600;
        }
        
        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-top: 30px;
        }
        
        .info-card {
            background: var(--bg);
            padding: 20px;
            border-radius: 12px;
            border-left: 4px solid var(--primary);
        }
        
        .info-card h4 {
            color: var(--primary);
            margin-bottom: 10px;
            font-size: 14px;
        }
        
        .info-card p {
            font-size: 14px;
            line-height: 1.6;
            color: var(--text);
        }
        
        .timeline {
            margin-top: 30px;
            padding-left: 20px;
        }
        
        .timeline-item {
            position: relative;
            padding-left: 20px;
            padding-bottom: 20px;
            border-left: 2px solid var(--border);
        }
        
        .timeline-item::before {
            content: '';
            position: absolute;
            left: -6px;
            top: 0;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: var(--primary);
        }
        
        .timeline-item:last-child {
            border-left: none;
        }
        
        .timeline-time {
            font-size: 12px;
            color: var(--text-muted);
        }
        
        .timeline-status {
            font-weight: 600;
            margin: 4px 0;
        }
        
        .timeline-notes {
            font-size: 13px;
            color: var(--text-muted);
        }
        
        .agent-card {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            padding: 20px;
            border-radius: 12px;
            margin-top: 20px;
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .agent-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: 600;
        }
        
        .agent-info h4 {
            margin-bottom: 5px;
        }
        
        .agent-info p {
            opacity: 0.9;
            font-size: 14px;
        }
        
        .qr-section {
            text-align: center;
            padding: 20px;
            background: var(--bg);
            border-radius: 12px;
            margin-top: 20px;
        }
        
        .home-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: white;
            text-decoration: none;
            margin-top: 20px;
            padding: 10px 20px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 8px;
            transition: background 0.3s;
        }
        
        .home-link:hover {
            background: rgba(255, 255, 255, 0.3);
        }
        
        @media (max-width: 600px) {
            .search-form { flex-direction: column; }
            .progress-steps { overflow-x: auto; }
            .tracking-header { flex-direction: column; gap: 15px; }
        }
    </style>
</head>
<body>
  <style>
    .flash {
      padding: 12px 14px;
      border-radius: 14px;
      margin: 18px auto;
      max-width: 980px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 10px;
      border: 1px solid rgba(0,0,0,0.08);
      background: rgba(255, 255, 255, 0.9);
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    }
    .flash.success {
      border-color: rgba(74, 222, 128, 0.4);
      color: #166534;
      background: rgba(74, 222, 128, 0.15);
    }
    .flash.error {
      border-color: rgba(255, 107, 107, 0.4);
      color: #b91c1c;
      background: rgba(254, 202, 202, 0.25);
    }
  </style>
  <% if (success && success.length) { %>
    <div class="flash success"><%= success[0] %></div>
  <% } %>
  <% if (error && error.length) { %>
    <div class="flash error"><%= error[0] %></div>
  <% } %>

    <div class="tracking-container">
        <div class="header">
            <h1><i class="fas fa-shipping-fast"></i> Track Your Order</h1>
            <p>Enter your Order ID or scan the QR code to track your delivery</p>
            <a href="/home" class="home-link">
                <i class="fas fa-home"></i> Back to Home
            </a>
        </div>

        <div class="search-box">
            <form action="/track-order" method="GET" class="search-form">
                <input type="text" name="orderId" class="search-input" placeholder="Enter Order ID (e.g., ORD260301ABC123)" value="<%= locals.trackingInfo?.orderId || '' %>">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-search"></i> Track
                </button>
            </form>
        </div>

        <% if (locals.error && error) { %>
            <div class="error-box">
                <i class="fas fa-exclamation-circle"></i> <%= error %>
            </div>
        <% } %>

        <% if (locals.trackingInfo && trackingInfo) { %>
            <div class="tracking-result">
                <div class="tracking-header">
                    <div class="order-info">
                        <h2><i class="fas fa-box"></i> Order <%= trackingInfo.orderId || trackingInfo.deliveryId %></h2>
                        <p>QR Code: <code><%= trackingInfo.qrCode %></code></p>
                    </div>
                    <span class="status-badge <%= trackingInfo.status %>">
                        <%= trackingInfo.status.replace(/_/g, ' ') %>
                    </span>
                </div>

                <!-- Progress Steps -->
                <div class="progress-steps">
                    <div class="step <%= ['pending_assignment', 'assigned', 'picked_up', 'in_transit', 'out_for_delivery', 'delivered'].includes(trackingInfo.status) ? 'completed' : '' %>">
                        <div class="step-icon"><i class="fas fa-clipboard-check"></i></div>
                        <div class="step-label">Order Confirmed</div>
                    </div>
                    <div class="step <%= ['assigned', 'picked_up', 'in_transit', 'out_for_delivery', 'delivered'].includes(trackingInfo.status) ? 'completed' : '' %>">
                        <div class="step-icon"><i class="fas fa-user-check"></i></div>
                        <div class="step-label">Agent Assigned</div>
                    </div>
                    <div class="step <%= ['picked_up', 'in_transit', 'out_for_delivery', 'delivered'].includes(trackingInfo.status) ? 'completed' : '' %>">
                        <div class="step-icon"><i class="fas fa-box"></i></div>
                        <div class="step-label">Picked Up</div>
                    </div>
                    <div class="step <%= ['in_transit', 'out_for_delivery', 'delivered'].includes(trackingInfo.status) ? 'completed' : '' %>">
                        <div class="step-icon"><i class="fas fa-shipping-fast"></i></div>
                        <div class="step-label">In Transit</div>
                    </div>
                    <div class="step <%= ['out_for_delivery', 'delivered'].includes(trackingInfo.status) ? 'completed' : '' %>">
                        <div class="step-icon"><i class="fas fa-motorcycle"></i></div>
                        <div class="step-label">Out for Delivery</div>
                    </div>
                    <div class="step <%= ['delivered'].includes(trackingInfo.status) ? 'completed' : '' %> <%= ['delivered'].includes(trackingInfo.status) ? 'active' : '' %>">
                        <div class="step-icon"><i class="fas fa-check-circle"></i></div>
                        <div class="step-label">Delivered</div>
                    </div>
                </div>

                <!-- Delivery Agent Info -->
                <% if (trackingInfo.agent) { %>
                    <div class="agent-card">
                        <div class="agent-avatar">
                            <%= trackingInfo.agent.name.charAt(0).toUpperCase() %>
                        </div>
                        <div class="agent-info">
                            <h4><i class="fas fa-user"></i> Delivery Agent: <%= trackingInfo.agent.name %></h4>
                            <p><i class="fas fa-phone"></i> <%= trackingInfo.agent.phone %></p>
                            <p><i class="fas fa-motorcycle"></i> <%= trackingInfo.agent.vehicleType %> - <%= trackingInfo.agent.vehicleNumber || 'N/A' %></p>
                        </div>
                    </div>
                <% } %>

                <!-- Delivery Address -->
                <div class="info-grid">
                    <div class="info-card">
                        <h4><i class="fas fa-map-marker-alt"></i> Delivery Address</h4>
                        <p>
                            <strong><%= trackingInfo.deliveryAddress?.fullName || 'N/A' %></strong><br>
                            <%= trackingInfo.deliveryAddress?.address || '' %><br>
                            <%= trackingInfo.deliveryAddress?.city %>, <%= trackingInfo.deliveryAddress?.state %> <%= trackingInfo.deliveryAddress?.pincode %><br>
                            <i class="fas fa-phone"></i> <%= trackingInfo.deliveryAddress?.phone || 'N/A' %>
                        </p>
                    </div>
                    
                    <div class="info-card">
                        <h4><i class="fas fa-clock"></i> Delivery Timeline</h4>
                        <p>
                            <strong>Estimated:</strong> <%= trackingInfo.estimatedDelivery ? new Date(trackingInfo.estimatedDelivery).toLocaleString() : 'Not set' %><br>
                            <% if (trackingInfo.actualDelivery) { %>
                                <strong>Delivered:</strong> <%= new Date(trackingInfo.actualDelivery).toLocaleString() %>
                            <% } %>
                        </p>
                    </div>

                    <% if (trackingInfo.codAmount > 0) { %>
                        <div class="info-card" style="border-left-color: var(--warning);">
                            <h4><i class="fas fa-money-bill-wave"></i> Cash on Delivery</h4>
                            <p style="font-size: 24px; font-weight: 700; color: var(--warning);">₹<%= trackingInfo.codAmount %></p>
                            <p style="font-size: 12px; margin-top: 5px;">Please keep exact change ready</p>
                        </div>
                    <% } %>
                </div>

                <!-- Timeline -->
                <div class="timeline">
                    <h3 style="margin-bottom: 15px; color: var(--primary);"><i class="fas fa-history"></i> Tracking History</h3>
                    <% if (trackingInfo.timeline && trackingInfo.timeline.length > 0) { %>
                        <% trackingInfo.timeline.slice().reverse().forEach(event => { %>
                            <div class="timeline-item">
                                <div class="timeline-time"><%= new Date(event.timestamp).toLocaleString() %></div>
                                <div class="timeline-status"><%= event.status.replace(/_/g, ' ') %></div>
                                <% if (event.notes) { %>
                                    <div class="timeline-notes"><%= event.notes %></div>
                                <% } %>
                                <% if (event.location) { %>
                                    <div class="timeline-notes"><i class="fas fa-map-marker-alt"></i> <%= event.location %></div>
                                <% } %>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p style="color: var(--text-muted); text-align: center; padding: 20px;">No tracking updates yet</p>
                    <% } %>
                </div>
            </div>
        <% } else if (!error) { %>
            <!-- Instructions when no search performed -->
            <div class="tracking-result" style="text-align: center; padding: 60px 20px;">
                <i class="fas fa-search-location" style="font-size: 80px; color: var(--text-muted); margin-bottom: 20px;"></i>
                <h3 style="color: var(--text); margin-bottom: 10px;">Track Your Delivery</h3>
                <p style="color: var(--text-muted); max-width: 400px; margin: 0 auto;">
                    Enter your Order ID above to see real-time tracking information about your delivery.
                </p>
                <div style="margin-top: 30px; display: flex; justify-content: center; gap: 20px; flex-wrap: wrap;">
                    <div style="text-align: center;">
                        <i class="fas fa-qrcode" style="font-size: 40px; color: var(--primary); margin-bottom: 10px;"></i>
                        <p style="font-size: 14px; color: var(--text-muted);">Scan QR Code</p>
                    </div>
                    <div style="text-align: center;">
                        <i class="fas fa-mobile-alt" style="font-size: 40px; color: var(--primary); margin-bottom: 10px;"></i>
                        <p style="font-size: 14px; color: var(--text-muted);">Real-time Updates</p>
                    </div>
                    <div style="text-align: center;">
                        <i class="fas fa-shield-alt" style="font-size: 40px; color: var(--primary); margin-bottom: 10px;"></i>
                        <p style="font-size: 14px; color: var(--text-muted);">Secure Delivery</p>
                    </div>
                </div>
            </div>
        <% } %>
    </div>

    <script src="/js/theme.js"></script>
</body>
</html>
