                    <li class="mob-user-info">
                      <div class="mob-user-display">
                        <i class="fas fa-user-circle"></i>
                        <span>
                          <%= user.name %>
                        </span>
                      </div>
                      <ul class="mob-user-menu">
                        <li><a href="/account"><i class="fas fa-user"></i> My Account</a></li>
                        <li><a href="/user/orders"><i class="fas fa-box"></i> My Orders</a></li>
                        <li><a href="/wishlist"><i class="fas fa-heart"></i> Wishlist</a></li>
                        <li><a href="/doctor"><i class="fas fa-user-md"></i> Consult Doctor</a></li>
                        <li class="divider"></li>
                        <li><a href="/logout"
                            onclick="event.preventDefault(); fetch('/logout', {method: 'POST', credentials: 'same-origin'}).then(() => window.location.href = '/login'); return false;"><i
                              class="fas fa-sign-out-alt"></i> Logout</a></li>
                      </ul>
                    </li>
                    <% } else { %>
                      <li><a href="/login"><i class="fas fa-user"></i> Login</a></li>
                      <% } %>
                        <li>
                          <a href="/doctor" class="btn btn-primary mob-consult">
                            <i class="fas fa-user-md"></i> Consult Doctor
                          </a>
                        </li>
                </ul>
                <div class="mob-contact-strip">
                  <a href="tel:+919413010731"><i class="fas fa-phone"></i> +91 9413010731</a>
                  <a href="https://wa.me/919413010731" target="_blank" rel="noopener noreferrer"><i
                      class="fab fa-whatsapp"></i>
                    WhatsApp Us</a>
                </div>
              </div>
            </div>
            <div class="mobile-overlay" id="mobile-overlay"></div>

          </header>

          <main class="main-content">
            <div class="breadcrumb">
              <a href="/home"><i class="fas fa-home"></i> Home</a>
              <i class="fas fa-chevron-right"></i>
              <a href="/user/orders">Orders</a>
              <i class="fas fa-chevron-right"></i>
              <span>
                <%= order.tracking.orderId %>
              </span>
            </div>

            <div class="order-header">
              <h1 class="order-title">Order Details</h1>
              <% if (order.status === 'delivered') { %>
                <a href="/user/orders/<%= order._id %>/invoice" class="btn-download" target="_blank">
                  <i class="fas fa-download"></i> Download Invoice
                </a>
              <% } %>
            </div>

            <div class="order-grid">
              <div>
                <div class="card">
                  <h2 class="card-title">Order Items</h2>
                  <% order.items.forEach(item=> { %>
                    <div class="order-item">
                      <img src="<%= item.image || 'https://via.placeholder.com/80' %>" alt="<%= item.name %>"
                        class="item-image">
                      <div class="item-details">
                        <div class="item-name">
                          <%= item.name %>
                        </div>
                        <div class="item-meta">Qty: <%= item.quantity %> × ₹<%= item.price %>
                        </div>
                      </div>
                      <div class="item-price">
                        <div class="price">₹<%= item.subtotal %>
                        </div>
                      </div>
                    </div>
                    <% }) %>
                </div>

                <div class="card">
                  <h2 class="card-title"><i class="fas fa-map-marker-alt"></i> Delivery Address</h2>
                  <div class="address-box">
                    <strong>
                      <%= order.address.fullName %>
                    </strong><br>
                    <%= order.address.address %><br>
                      <%= order.address.city %>, <%= order.address.state %> - <%= order.address.pincode %><br>
                            <% if (order.address.landmark) { %>Landmark: <%= order.address.landmark %><br>
                                <% } %>
                                  Phone: <%= order.address.phone %><br>
                                    Email: <%= order.address.email %>
                  </div>
                </div>
              </div>

              <div>
                <div class="card">
                  <h2 class="card-title">Order Summary</h2>
                  <div style="text-align: center; margin-bottom: 1rem;">
                    <span class="status-badge status-<%= order.status %>">
                      <%= order.status.replace('_', ' ' ).toUpperCase() %>
                    </span>
                  </div>
                  <div class="summary-row"><span>Subtotal</span><span>₹<%= Math.round(order.pricing.subtotal) %></span>
                  </div>
                  <div class="summary-row"><span>GST (5%)</span><span>₹<%= Math.round(order.pricing.gst) %></span></div>
                  <div class="summary-row"><span>Delivery</span><span style="color: var(--success);">FREE</span></div>
                  <div class="summary-row summary-total"><span>Total</span><span>₹<%= Math.round(order.pricing.total) %>
                    </span></div>

                  <div style="margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--border);">
                    <div style="font-size: 0.875rem; color: var(--text-muted); margin-bottom: 0.5rem;">Payment Method
                    </div>
                    <div style="font-weight: 600;"><i
                        class="fas fa-<%= order.payment.method === 'cod' ? 'money-bill-wave' : 'credit-card' %>"></i>
                      <%= order.payment.method.toUpperCase() %>
                    </div>
                  </div>

                  <% 
                    // Debug logging for OTP status
                    const otpDebug = {
                      orderId: order._id.toString(),
                      status: order.status,
                      hasDeliveryOTP: !!order.deliveryOTP,
                      otpCode: order.deliveryOTP?.code || 'NONE',
                      otpGeneratedAt: order.deliveryOTP?.generatedAt || 'NOT SET',
                      otpExpiresAt: order.deliveryOTP?.expiresAt || 'NOT SET',
                      otpVerifiedAt: order.deliveryOTP?.verifiedAt || 'NOT SET',
                      isPickedUp: order.status === 'picked_up',
                      shouldShowOTP: (order.status === 'picked_up' || order.status === 'out_for_delivery' || order.status === 'assigned') &&
                                    order.deliveryOTP &&
                                    order.deliveryOTP.code &&
                                    !order.deliveryOTP.verifiedAt
                    };
                    console.log('\n========== CUSTOMER ORDER DETAIL PAGE ==========');
                    console.log('Order ID:', otpDebug.orderId);
                    console.log('Order Status:', otpDebug.status);
                    console.log('Has Delivery OTP:', otpDebug.hasDeliveryOTP);
                    console.log('OTP Code:', otpDebug.otpCode);
                    console.log('OTP Generated At:', otpDebug.otpGeneratedAt);
                    console.log('OTP Expires At:', otpDebug.otpExpiresAt);
                    console.log('OTP Verified At:', otpDebug.otpVerifiedAt);
                    console.log('Is Picked Up:', otpDebug.isPickedUp);
                    console.log('Should Show OTP:', otpDebug.shouldShowOTP);
                    console.log('=================================================\n');
                  %>
                  <% if ((order.status === 'picked_up' || order.status === 'out_for_delivery' || order.status === 'assigned') &&
                      order.deliveryOTP &&
                      order.deliveryOTP.code &&
                      !order.deliveryOTP.verifiedAt) { %>
                    <div
                      style="margin-top: 1.5rem; padding: 1rem; background: rgba(255, 193, 7, 0.1); border: 1px solid rgba(255, 193, 7, 0.3); border-radius: 8px;">
                      <div style="font-size: 0.875rem; color: var(--warning); font-weight: 600; margin-bottom: 0.5rem;">
                        <i class="fas fa-key"></i> Delivery OTP
                      </div>
                      <div
                        style="font-size: 1.5rem; font-weight: 700; color: var(--text-dark); letter-spacing: 4px; text-align: center; background: white; padding: 0.75rem; border-radius: 6px; border: 2px dashed var(--warning);">
                        <%= order.deliveryOTP.code %>
                      </div>
                      <div
                        style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.5rem; text-align: center;">
                        <i class="fas fa-info-circle"></i> Share this OTP with the delivery agent when they arrive
                      </div>
                      <div
                        style="font-size: 0.75rem; color: var(--text-muted); text-align: center; margin-top: 0.25rem;">
                        <i class="fas fa-clock"></i> Valid until <%= new Date(order.deliveryOTP.expiresAt).toLocaleString('en-IN') %>
                      </div>
                      <div style="font-size: 0.75rem; color: var(--warning); margin-top: 0.5rem; text-align: center; font-weight: 600;">
                        <i class="fas fa-shield-alt"></i> Status: <%= order.status.replace(/_/g, ' ') %>
                      </div>
                    </div>
                    <% } else { %>
                      <div style="margin-top: 1.5rem; padding: 1rem; background: rgba(220, 53, 69, 0.1); border: 1px solid rgba(220, 53, 69, 0.3); border-radius: 8px; text-align: center;">
                        <div style="font-size: 0.875rem; color: var(--danger); font-weight: 600;">
                          <i class="fas fa-exclamation-circle"></i> OTP Not Available
                        </div>
                        <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.5rem;">
                          Order Status: <%= order.status %><br>
                          <% if (order.deliveryOTP && order.deliveryOTP.verifiedAt) { %>
                            OTP has been verified on <%= new Date(order.deliveryOTP.verifiedAt).toLocaleString('en-IN') %>
                          <% } else if (!order.deliveryOTP || !order.deliveryOTP.code) { %>
                            OTP has not been generated yet. It will be generated when the order is picked up.
                          <% } else if (order.deliveryOTP && new Date() > new Date(order.deliveryOTP.expiresAt)) { %>
                            OTP has expired
                          <% } %>
                        </div>
                      </div>
                    <% } %>

                      <% if (order.deliveryAgent) { %>
                        <div
                          style="margin-top: 1.5rem; padding: 1rem; background: rgba(28, 129, 37, 0.1); border: 1px solid rgba(28, 129, 37, 0.3); border-radius: 8px;">
                          <div
                            style="font-size: 0.875rem; color: var(--primary); font-weight: 600; margin-bottom: 0.75rem;">
                            <i class="fas fa-truck"></i> Delivery Agent Details
                          </div>
                          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
                            <% if (order.deliveryAgent.profileImage) { %>
                              <img src="<%= order.deliveryAgent.profileImage %>" alt="Agent"
                                style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;">
                              <% } else { %>
                                <div
                                  style="width: 40px; height: 40px; border-radius: 50%; background: var(--primary); display: flex; align-items: center; justify-content: center; color: white;">
                                  <i class="fas fa-user"></i>
                                </div>
                                <% } %>
                                  <div>
                                    <div style="font-weight: 600; color: var(--text);">
                                      <%= order.deliveryAgent.name %>
                                    </div>
                                    <div style="font-size: 0.75rem; color: var(--text-muted);">
                                      <i class="fas fa-phone"></i>
                                      <%= order.deliveryAgent.phone %>
                                    </div>
                                  </div>
                          </div>
                          <% if (order.deliveryAgent.vehicleType && order.deliveryAgent.vehicleNumber) { %>
                            <div style="font-size: 0.75rem; color: var(--text-muted);">
                              <i
                                class="fas fa-<%= order.deliveryAgent.vehicleType === 'bike' ? 'motorcycle' : order.deliveryAgent.vehicleType === 'scooter' ? 'motorcycle' : order.deliveryAgent.vehicleType === 'car' ? 'car' : 'truck' %>"></i>
                              <%= order.deliveryAgent.vehicleType.charAt(0).toUpperCase() +
                                order.deliveryAgent.vehicleType.slice(1) %> - <%= order.deliveryAgent.vehicleNumber %>
                            </div>
                            <% } %>
                        </div>
                        <% } %>

                          <button onclick="window.print()" class="btn-print"><i class="fas fa-print"></i> Print
                            Invoice</button>

                          <%
                            // Check if cancellation is allowed
                            var cancellationAllowed = false;
                            var cancellationDisabledReason = '';
                            var isAlreadyCancelled = order.tracking && order.tracking.cancelledAt;
                            var nonCancellableStatuses = ['delivered', 'cancelled', 'refunded', 'picked_up'];
                            var cancellableStatuses = ['pending', 'confirmed', 'processing', 'assigned', 'shipped', 'out_for_delivery'];

                            if (isAlreadyCancelled) {
                              cancellationDisabledReason = 'Order already cancelled';
                            } else if (nonCancellableStatuses.indexOf(order.status) !== -1) {
                              cancellationDisabledReason = 'Cancellation not allowed for ' + order.status + ' orders';
                            } else if (cancellableStatuses.indexOf(order.status) !== -1) {
                              cancellationAllowed = true;
                            } else {
                              cancellationDisabledReason = 'Cancellation not allowed for this order status (' + order.status + ')';
                            }

                            // Console log for debugging
                            console.log('=== Cancellation Check ===');
                            console.log('Order ID:', order._id);
                            console.log('Order Status:', order.status);
                            console.log('Is Already Cancelled:', isAlreadyCancelled);
                            console.log('Cancellation Allowed:', cancellationAllowed);
                            console.log('Disabled Reason:', cancellationDisabledReason);
                          %>

                          <% if (cancellationAllowed) { %>
                            <button class="btn-cancel" id="cancelOrderBtn"><i class="fas fa-times"></i> Request Cancellation</button>
                          <% } else { %>
                            <div style="font-size: 12px; color: var(--danger); padding: 10px; text-align: center; margin-top: 10px; background: rgba(220, 53, 69, 0.1); border-radius: 8px;">
                              <i class="fas fa-exclamation-circle"></i>
                              <%= cancellationDisabledReason %>
                              <% if (order.tracking && order.tracking.cancelledAt) { %>
                                <br><small>(Cancelled on <%= new Date(order.tracking.cancelledAt).toLocaleDateString('en-IN') %>)</small>
                              <% } %>
                            </div>
                          <% } %>
                </div>

                <div class="card">
                  <h2 class="card-title"><i class="fas fa-clock"></i> Order Timeline</h2>
                  <div style="font-size: 0.875rem;">
                    <div style="padding: 0.5rem 0; border-left: 2px solid var(--primary); padding-left: 1rem;">
                      <strong>Order Placed</strong><br>
                      <span style="color: var(--text-muted);">
                        <%= new Date(order.createdAt).toLocaleDateString('en-IN') %>
                      </span>
                    </div>
                    <% if (order.tracking.shippedAt) { %>
                      <div style="padding: 0.5rem 0; border-left: 2px solid var(--primary); padding-left: 1rem;">
                        <strong>Shipped</strong><br>
                        <span style="color: var(--text-muted);">
                          <%= new Date(order.tracking.shippedAt).toLocaleDateString('en-IN') %>
                        </span>
                      </div>
                      <% } %>
                        <% if (order.tracking.deliveredAt) { %>
                          <div style="padding: 0.5rem 0; border-left: 2px solid var(--success); padding-left: 1rem;">
                            <strong>Delivered</strong><br>
                            <span style="color: var(--text-muted);">
                              <%= new Date(order.tracking.deliveredAt).toLocaleDateString('en-IN') %>
                            </span>
                          </div>
                          <% } %>
                  </div>
                </div>

                <% if (order.status === 'delivered' && order.deliveryProof && order.deliveryProof.image) { %>
                <div class="card">
                  <h2 class="card-title"><i class="fas fa-camera"></i> Delivery Proof</h2>
                  <div style="text-align: center;">
                    <img src="<%= order.deliveryProof.image %>" alt="Delivery Proof" 
                         style="max-width: 100%; border-radius: 8px; border: 2px solid var(--border);">
                    <p style="font-size: 0.875rem; color: var(--text-muted); margin-top: 10px;">
                      <i class="fas fa-check-circle" style="color: var(--success);"></i>
                      Delivered on <%= new Date(order.deliveryProof.uploadedAt).toLocaleString('en-IN') %>
                    </p>
                  </div>
                </div>
                <% } %>

                <% if (order.deliveryOTP && order.deliveryOTP.verifiedAt) { %>
                <div class="card">
                  <h2 class="card-title"><i class="fas fa-shield-alt"></i> OTP Verification</h2>
                  <div style="padding: 1rem; background: rgba(40, 167, 69, 0.1); border: 1px solid rgba(40, 167, 69, 0.3); border-radius: 8px;">
                    <div style="display: flex; align-items: center; gap: 10px; color: var(--success);">
                      <i class="fas fa-check-circle" style="font-size: 24px;"></i>
                      <div>
                        <div style="font-weight: 600;">Delivery Verified with OTP</div>
                        <div style="font-size: 0.75rem; color: var(--text-muted);">
                          Verified on <%= new Date(order.deliveryOTP.verifiedAt).toLocaleString('en-IN') %>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
                <% } %>
              </div>
            </div>
          </main>

<!-- Cancellation Request Modal -->
<div id="cancellationModal" class="modal-overlay" style="display: none;">
  <div class="modal-container">
    <div class="modal-header">
      <h3><i class="fas fa-exclamation-triangle"></i> Request Order Cancellation</h3>
      <button type="button" class="modal-close-btn" id="closeModalBtn">&times;</button>
    </div>
    <form id="cancellationForm">
      <input type="hidden" id="orderId" value="<%= order._id %>">

      <div class="modal-body">
        <div class="form-group">
          <label for="reason">Reason for Cancellation *</label>
          <select id="reason" required>
            <option value="">Select a reason</option>
            <option value="wrong_item">Wrong item ordered</option>
            <option value="damaged_product">Product damaged</option>
            <option value="expired_product">Product expired</option>
            <option value="not_as_described">Not as described</option>
            <option value="duplicate_order">Duplicate order</option>
            <option value="changed_mind">Changed my mind</option>
            <option value="delivery_delay">Delivery delay</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div class="form-group">
          <label for="description">Additional Details *</label>
          <textarea id="description" rows="4" placeholder="Please provide more details about your cancellation request..." required></textarea>
        </div>

        <div class="form-group">
          <label>Items to Cancel</label>
          <div class="items-list">
            <% order.items.forEach((item, idx) => { %>
              <label class="item-checkbox">
                <input type="checkbox" name="items" value="<%= item.product._id || item.product %>" data-idx="<%= idx %>" checked>
                <div class="item-info">
                  <img src="<%= item.image || 'https://via.placeholder.com/40' %>" alt="<%= item.name %>">
                  <div>
                    <div class="item-name"><%= item.name %></div>
                    <div class="item-meta">Qty: <%= item.quantity %> × ₹<%= item.price %></div>
                  </div>
                </div>
              </label>
            <% }) %>
          </div>
        </div>

        <div class="form-group">
          <label>Pickup Address</label>
          <div class="address-box">
            <strong><%= order.address.fullName %></strong><br>
            <%= order.address.address %><br>
            <%= order.address.city %>, <%= order.address.state %> - <%= order.address.pincode %><br>
            Phone: <%= order.address.phone %>
          </div>
        </div>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn-modal-secondary" id="cancelModalBtn">Cancel</button>
        <button type="submit" class="btn-modal-primary">Submit Request</button>
      </div>
    </form>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  console.log('=== Order Detail Page Loaded ===');
  console.log('DOM fully loaded and parsed');
  
  // Get elements
  const modal = document.getElementById('cancellationModal');
  const cancelBtn = document.getElementById('cancelOrderBtn');
  const closeBtn = document.getElementById('closeModalBtn');
  const cancelModalBtn = document.getElementById('cancelModalBtn');
  const form = document.getElementById('cancellationForm');

  console.log('Modal element:', modal);
  console.log('Cancel button:', cancelBtn);
  console.log('Close button:', closeBtn);
  console.log('Cancel modal button:', cancelModalBtn);
  console.log('Form:', form);

  // Store order items data for form submission
  const orderItemsData = <%= JSON.stringify(order.items) %>;
  console.log('Order items data loaded:', orderItemsData.length, 'items');

  // Debug: Check if button exists and attach click handler
  if (cancelBtn) {
    console.log('✅ Cancel button found in DOM with ID:', cancelBtn.id);
    console.log('Button classes:', cancelBtn.className);
    console.log('Button text:', cancelBtn.innerText);
    console.log('Button computed styles:', window.getComputedStyle(cancelBtn).display);
    
    // Remove any existing listeners and add new one
    cancelBtn.replaceWith(cancelBtn.cloneNode(true));
    const newCancelBtn = document.getElementById('cancelOrderBtn');
    
    newCancelBtn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      console.log('🔔 Cancel button clicked!');
      console.log('Event:', e);
      
      if (!modal) {
        console.error('❌ Modal element not found!');
        alert('Error: Modal not found');
        return;
      }
      
      console.log('Modal before:', modal.style.display);
      modal.style.display = 'flex';
      document.body.style.overflow = 'hidden';
      console.log('Modal after:', modal.style.display);
      
      // Verify modal is visible
      const modalVisible = window.getComputedStyle(modal).display !== 'none';
      console.log('Modal is visible:', modalVisible);
      
      if (modalVisible) {
        console.log('✅ Modal opened successfully');
      } else {
        console.error('❌ Modal failed to open');
        alert('Modal display issue - check CSS');
      }
    });
    
    console.log('✅ Click listener attached to cancel button');
  } else {
    console.error('❌ Cancel button NOT found in DOM!');
    console.log('Searching for any button with class btn-cancel...');
    const allCancelButtons = document.querySelectorAll('.btn-cancel');
    console.log('Found', allCancelButtons.length, 'buttons with class btn-cancel');
    allCancelButtons.forEach((btn, idx) => {
      console.log('Button', idx, ':', btn);
    });
  }

  // Close modal functions
  function closeModal() {
    console.log('🔄 Closing modal');
    if (modal) {
      modal.style.display = 'none';
    }
    document.body.style.overflow = 'auto';
    if (form) {
      form.reset();
    }
  }

  // Close on X button
  if (closeBtn) {
    console.log('✅ Close button found');
    closeBtn.addEventListener('click', closeModal);
  }

  // Close on Cancel button
  if (cancelModalBtn) {
    console.log('✅ Cancel modal button found');
    cancelModalBtn.addEventListener('click', closeModal);
  }

  // Close on overlay click
  if (modal) {
    modal.addEventListener('click', function(e) {
      if (e.target === modal) {
        console.log('🔄 Overlay clicked, closing modal');
        closeModal();
      }
    });
  }

  // Form submit handler
  if (form) {
    console.log('✅ Cancellation form found');
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      console.log('📝 Form submitted');

      const orderId = document.getElementById('orderId').value;
      const reason = document.getElementById('reason').value;
      const description = document.getElementById('description').value;

      console.log('Order ID:', orderId);
      console.log('Reason:', reason);
      console.log('Description:', description);

      // Get selected items
      const selectedItems = [];
      const checkboxes = form.querySelectorAll('input[name="items"]:checked');

      console.log('Selected checkboxes:', checkboxes.length);
      
      checkboxes.forEach(cb => {
        const idx = cb.getAttribute('data-idx');
        const item = orderItemsData[idx];
        console.log('Item selected:', item);
        selectedItems.push({
          productId: item.product._id || item.product,
          quantity: item.quantity
        });
      });

      if (selectedItems.length === 0) {
        console.log('❌ No items selected');
        alert('Please select at least one item to cancel');
        return;
      }

      // Get pickup address from order data
      const pickupAddress = {
        fullName: '<%= order.address.fullName %>',
        phone: '<%= order.address.phone %>',
        address: '<%= order.address.address %>',
        city: '<%= order.address.city %>',
        state: '<%= order.address.state %>',
        pincode: '<%= order.address.pincode %>',
        landmark: '<%= order.address.landmark || "" %>'
      };
      
      console.log('Pickup address:', pickupAddress);

      // Disable submit button
      const submitBtn = form.querySelector('button[type="submit"]');
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Submitting...';

      try {
        console.log('📡 Sending cancellation request...');
        const res = await fetch('/api/cancellations', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            orderId,
            items: selectedItems,
            reason,
            description,
            pickupAddress
          })
        });

        const result = await res.json();
        console.log('Response:', result);

        if (result.success) {
          console.log('✅ Cancellation successful');
          alert('✅ Cancellation request submitted successfully!');
          closeModal();
          location.reload();
        } else {
          console.log('❌ Cancellation failed:', result.message);
          alert('❌ ' + result.message);
          submitBtn.disabled = false;
          submitBtn.innerHTML = 'Submit Request';
        }

      } catch (err) {
        console.error('❌ Cancellation error:', err);
        alert('❌ Server error. Please try again.');
        submitBtn.disabled = false;
        submitBtn.innerHTML = 'Submit Request';
      }
    });
  } else {
    console.log('❌ Cancellation form NOT found in DOM');
  }

  // Escape key to close modal
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal && modal.style.display === 'flex') {
      console.log('🔑 Escape key pressed, closing modal');
      closeModal();
    }
  });

  console.log('=== Order Detail Page Initialization Complete ===');
});
</script>
          <script src="/js/script.js"></script>
</body>

