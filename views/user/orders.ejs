<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Orders — Shri Govind Pharmacy</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    :root {
      --primary: #1c8125;
      --primary-dark: #145a1a;
      --bg-light: #f0fdf4;
      --surface: #ffffff;
      --text-dark: #17252a;
      --text-muted: #6b7c85;
      --border: #e9ecef;
      --shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    [data-theme="dark"] {
      --bg-light: #0b0c10;
      --surface: #1e1e1e;
      --text-dark: #d1d9e0;
      --text-muted: #7f8c95;
      --border: #2d2d2d;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--bg-light);
      color: var(--text-dark);
      min-height: 100vh;
    }

    .page-header {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 1rem 0;
    }

    .header-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      text-decoration: none;
      color: var(--text-dark);
    }

    .logo-icon {
      width: 40px;
      height: 40px;
      background: linear-gradient(135deg, var(--primary), var(--primary-dark));
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
    }

    .logo-text {
      display: flex;
      flex-direction: column;
    }

    .logo-main {
      font-weight: 700;
      font-size: 1.1rem;
      color: var(--primary);
    }

    .logo-sub {
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    .btn-link {
      padding: 0.5rem 1rem;
      background: transparent;
      color: var(--text-muted);
      border: 1px solid var(--border);
      border-radius: 8px;
      text-decoration: none;
      font-weight: 500;
    }

    .main-content {
      max-width: 1200px;
      margin: 2rem auto;
      padding: 0 2rem;
    }

    .breadcrumb {
      display: flex;
      gap: 0.5rem;
      font-size: 0.875rem;
      color: var(--text-muted);
      margin-bottom: 1.5rem;
    }

    .breadcrumb a {
      color: var(--text-muted);
      text-decoration: none;
    }

    .page-title {
      font-size: 1.75rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .page-subtitle {
      color: var(--text-muted);
      margin-bottom: 2rem;
    }

    .orders-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .order-card {
      background: var(--surface);
      border-radius: 12px;
      padding: 1.5rem;
      box-shadow: var(--shadow);
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 1rem;
      align-items: center;
    }

    .order-info {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .order-id {
      font-weight: 700;
      font-size: 1.1rem;
      color: var(--primary);
    }

    .order-date {
      font-size: 0.875rem;
      color: var(--text-muted);
    }

    .order-items {
      display: flex;
      gap: 0.5rem;
      margin-top: 0.5rem;
    }

    .order-item-thumb {
      width: 50px;
      height: 50px;
      border-radius: 8px;
      object-fit: cover;
    }

    .order-meta {
      display: flex;
      gap: 1.5rem;
      margin-top: 0.5rem;
    }

    .meta-item {
      font-size: 0.875rem;
    }

    .meta-label {
      color: var(--text-muted);
    }

    .meta-value {
      font-weight: 600;
    }

    .order-status {
      padding: 0.5rem 1rem;
      border-radius: 20px;
      font-weight: 600;
      font-size: 0.875rem;
      text-align: center;
    }

    .status-pending,
    .status-confirmed {
      background: rgba(255, 193, 7, 0.1);
      color: #ffc107;
    }

    .status-processing,
    .status-shipped {
      background: rgba(52, 152, 219, 0.1);
      color: #3498db;
    }

    .status-out_for_delivery,
    .status-delivered {
      background: rgba(40, 167, 69, 0.1);
      color: #28a745;
    }

    .status-cancelled,
    .status-refunded {
      background: rgba(220, 53, 69, 0.1);
      color: #dc3545;
    }

    .btn-view {
      padding: 0.75rem 1.5rem;
      background: var(--primary);
      color: white;
      border: none;
      border-radius: 10px;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }

    .btn-view:hover {
      background: var(--primary-dark);
    }

    .empty-state {
      text-align: center;
      padding: 4rem 2rem;
    }

    .empty-icon {
      font-size: 5rem;
      color: var(--text-muted);
      opacity: 0.3;
      margin-bottom: 1.5rem;
    }

    @media (max-width: 768px) {

      .header-inner,
      .main-content {
        padding: 0 1rem;
      }

      .order-card {
        grid-template-columns: 1fr;
      }
    }
  </style>
  <script src="/js/theme.js"></script>

</head>

<body>
  <style>
    .flash {
      padding: 12px 14px;
      border-radius: 14px;
      margin: 18px auto;
      max-width: 980px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 10px;
      border: 1px solid rgba(0, 0, 0, 0.08);
      background: rgba(255, 255, 255, 0.9);
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    }

    .flash.success {
      border-color: rgba(74, 222, 128, 0.4);
      color: #166534;
      background: rgba(74, 222, 128, 0.15);
    }

    .flash.error {
      border-color: rgba(255, 107, 107, 0.4);
      color: #b91c1c;
      background: rgba(254, 202, 202, 0.25);
    }
  </style>
  <% if (success && success.length) { %>
    <div class="flash success">
      <%= success[0] %>
    </div>
    <% } %>
      <% if (error && error.length) { %>
        <div class="flash error">
          <%= error[0] %>
        </div>
        <% } %>

          <header class="page-header">
            <div class="header-inner">
              <a href="/home" class="logo">
                <img src="https://res.cloudinary.com/drufdfmfr/image/upload/v1772726044/favicon_uuzvml.svg"
                  alt="Shri Govind Pharmacy" class="logo-favicon">
                <div class="logo-text">
                  <span class="logo-main">Shri Govind</span>
                  <span class="logo-sub">Pharmacy</span>
                </div>
              </a>
              <div>
                <a href="/home" class="btn-link"><i class="fas fa-home"></i> Home</a>
                <a href="/user/cart" class="btn-link"><i class="fas fa-shopping-cart"></i> Cart</a>
              </div>
            </div>
          </header>

          <main class="main-content">
            <div class="breadcrumb">
              <a href="/home"><i class="fas fa-home"></i> Home</a>
              <i class="fas fa-chevron-right"></i>
              <span>My Orders</span>
            </div>

            <h1 class="page-title"><i class="fas fa-box"></i> My Orders</h1>
            <p class="page-subtitle">Track and manage your orders</p>

            <% if (orders.length===0) { %>
              <div class="empty-state">
                <div class="empty-icon"><i class="fas fa-shopping-bag"></i></div>
                <h2>No orders yet</h2>
                <p style="color: var(--text-muted); margin: 1rem 0 2rem;">Start shopping to see your orders here</p>
                <a href="/home#product" class="btn-view"><i class="fas fa-shopping-bag"></i> Browse Products</a>
              </div>
              <% } else { %>
                <div class="orders-list">
                  <% orders.forEach(order=> { %>
                    <div class="order-card">
                      <div class="order-info">
                        <div class="order-id">
                          <%= order.tracking.orderId %>
                        </div>
                        <div class="order-date">Placed on <%= new Date(order.createdAt).toLocaleDateString('en-IN', {
                            day: 'numeric' , month: 'long' , year: 'numeric' , hour: '2-digit' , minute: '2-digit' }) %>
                        </div>
                        <div class="order-items">
                          <% order.items.slice(0, 4).forEach(item=> { %>
                            <img src="<%= item.image || 'https://via.placeholder.com/50' %>" alt="<%= item.name %>"
                              class="order-item-thumb">
                            <% }) %>
                              <% if (order.items.length> 4) { %>
                                <div
                                  style="width: 50px; height: 50px; border-radius: 8px; background: var(--bg-light); display: flex; align-items: center; justify-content: center; font-size: 0.875rem; font-weight: 600;">
                                  +<%= order.items.length - 4 %>
                                </div>
                                <% } %>
                        </div>
                        <div class="order-meta">
                          <div class="meta-item">
                            <div class="meta-label">Items</div>
                            <div class="meta-value">
                              <%= order.items.length %>
                            </div>
                          </div>
                          <div class="meta-item">
                            <div class="meta-label">Total</div>
                            <div class="meta-value">₹<%= Math.round(order.pricing.total) %>
                            </div>
                          </div>
                          <div class="meta-item">
                            <div class="meta-label">Payment</div>
                            <div class="meta-value">
                              <%= order.payment.method.toUpperCase() %>
                            </div>
                          </div>
                        </div>
                      </div>
                      <div style="display: flex; flex-direction: column; gap: 1rem; align-items: flex-end;">
                        <span class="order-status status-<%= order.status %>">
                          <%= order.status.replace('_', ' ' ).toUpperCase() %>
                        </span>
                        <a href="/user/orders/<%= order._id %>" class="btn-view"><i class="fas fa-eye"></i> View
                          Details</a>
                      </div>
                    </div>
                    <% }) %>
                </div>
                <% } %>
          </main>
</body>

</html>