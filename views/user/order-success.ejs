<!DOCTYPE html>
<html lang="en" data-theme="<%= typeof theme !== 'undefined' ? theme : 'light' %>">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order Confirmed — Shri Govind Pharmacy</title>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap"
    rel="stylesheet">

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">

  <style>
    :root {
      --primary: #1c8125;
      --primary-dark: #155724;
      --primary-light: #28a745;
      --success: #28a745;
      --danger: #dc3545;
      --warning: #ffc107;
      --info: #17a2b8;
      --bg: #f8f9fa;
      --bg-light: #ffffff;
      --surface: #ffffff;
      --text: #212529;
      --text-dark: #212529;
      --text-muted: #6c757d;
      --border: #dee2e6;
      --border-color: #dee2e6;
      --shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      --shadow-lg: 0 4px 20px rgba(0, 0, 0, 0.12);
    }

    [data-theme="dark"] {
      --bg: #0f1419;
      --bg-light: #1a1f2e;
      --surface: #1a1f2e;
      --text: #e7e9ea;
      --text-dark: #e7e9ea;
      --text-muted: #8b98a5;
      --border: #2d3748;
      --border-color: #2d3748;
      --shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
      --shadow-lg: 0 4px 20px rgba(0, 0, 0, 0.4);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    /* Main Success Content */
    .success-container {
      max-width: 600px;
      margin: 3rem auto;
      padding: 0 2rem;
    }

    .success-card {
      background: var(--surface);
      border-radius: 20px;
      box-shadow: var(--shadow-lg);
      overflow: hidden;
      text-align: center;
    }

    .success-icon-wrapper {
      background: linear-gradient(135deg, var(--primary), var(--primary-dark));
      padding: 3rem 2rem;
      position: relative;
      overflow: hidden;
    }

    .success-icon {
      width: 100px;
      height: 100px;
      background: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto;
      animation: scaleIn 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    }

    .success-icon i {
      font-size: 3rem;
      color: var(--success);
    }

    @keyframes scaleIn {
      from {
        transform: scale(0);
        opacity: 0;
      }

      to {
        transform: scale(1);
        opacity: 1;
      }
    }

    .confetti {
      position: absolute;
      width: 10px;
      height: 10px;
      background: rgba(255, 255, 255, 0.3);
      animation: fall linear forwards;
    }

    @keyframes fall {
      to {
        transform: translateY(200px) rotate(720deg);
        opacity: 0;
      }
    }

    .success-content {
      padding: 2.5rem;
    }

    .success-title {
      font-size: 1.75rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: var(--text-dark);
    }

    .success-message {
      color: var(--text-muted);
      margin-bottom: 2rem;
      line-height: 1.6;
    }

    .order-details {
      background: var(--bg);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 2rem;
      text-align: left;
    }

    .order-row {
      display: flex;
      justify-content: space-between;
      padding: 0.75rem 0;
      border-bottom: 1px solid var(--border);
    }

    .order-row:last-child {
      border-bottom: none;
    }

    .order-label {
      color: var(--text-muted);
      font-size: 0.9rem;
    }

    .order-value {
      font-weight: 600;
      color: var(--text-dark);
    }

    .order-id {
      font-family: monospace;
      background: var(--surface);
      padding: 0.25rem 0.75rem;
      border-radius: 6px;
      border: 1px solid var(--border);
    }

    .action-buttons {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.875rem 1.5rem;
      border-radius: 10px;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.3s;
      border: none;
      cursor: pointer;
      font-size: 0.95rem;
      flex: 1;
      min-width: 150px;
    }

    .btn-primary {
      background: var(--primary);
      color: white;
    }

    .btn-primary:hover {
      background: var(--primary-dark);
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(28, 129, 37, 0.3);
    }

    .btn-outline {
      background: transparent;
      color: var(--primary);
      border: 2px solid var(--primary);
    }

    .btn-outline:hover {
      background: var(--primary);
      color: white;
    }

    .btn-whatsapp {
      background: #25D366;
      color: white;
    }

    .btn-whatsapp:hover {
      background: #128C7E;
    }

    /* Order Items Preview */
    .order-items-preview {
      margin-top: 2rem;
      text-align: left;
    }

    .preview-title {
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 1rem;
      color: var(--text-dark);
    }

    .preview-item {
      display: flex;
      gap: 1rem;
      padding: 1rem;
      background: var(--bg);
      border-radius: 10px;
      margin-bottom: 0.75rem;
    }

    .preview-item-img {
      width: 60px;
      height: 60px;
      border-radius: 8px;
      object-fit: cover;
      background: var(--surface);
    }

    .preview-item-details {
      flex: 1;
    }

    .preview-item-name {
      font-weight: 600;
      color: var(--text-dark);
      margin-bottom: 0.25rem;
    }

    .preview-item-meta {
      font-size: 0.85rem;
      color: var(--text-muted);
    }

    .preview-item-price {
      font-weight: 600;
      color: var(--primary);
      white-space: nowrap;
    }

    /* Info Box */
    .info-box {
      background: rgba(23, 162, 184, 0.1);
      border: 1px solid rgba(23, 162, 184, 0.3);
      border-radius: 10px;
      padding: 1rem;
      margin-top: 1.5rem;
      display: flex;
      gap: 0.75rem;
      align-items: flex-start;
      text-align: left;
    }

    .info-box i {
      color: var(--info);
      font-size: 1.25rem;
      flex-shrink: 0;
      margin-top: 0.125rem;
    }

    .info-box-content {
      flex: 1;
    }

    .info-box-title {
      font-weight: 600;
      color: var(--text-dark);
      margin-bottom: 0.25rem;
    }

    .info-box-text {
      font-size: 0.875rem;
      color: var(--text-muted);
      line-height: 1.5;
    }

    /* Delivery Timeline */
    .delivery-timeline {
      margin-top: 2rem;
      padding: 1.5rem;
      background: var(--bg);
      border-radius: 12px;
    }

    .timeline-title {
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 1rem;
      color: var(--text-dark);
    }

    .timeline-steps {
      display: flex;
      justify-content: space-between;
      position: relative;
    }

    .timeline-steps::before {
      content: '';
      position: absolute;
      top: 15px;
      left: 0;
      right: 0;
      height: 2px;
      background: var(--border);
      z-index: 0;
    }

    .timeline-step {
      position: relative;
      z-index: 1;
      text-align: center;
      flex: 1;
    }

    .timeline-dot {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: var(--surface);
      border: 2px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 0.5rem;
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    .timeline-step.active .timeline-dot {
      background: var(--primary);
      border-color: var(--primary);
      color: white;
    }

    .timeline-step.completed .timeline-dot {
      background: var(--success);
      border-color: var(--success);
      color: white;
    }

    .timeline-label {
      font-size: 0.75rem;
      color: var(--text-muted);
      font-weight: 500;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .success-container {
        margin: 1rem auto;
        padding: 0 1rem;
      }

      .success-content {
        padding: 1.5rem;
      }

      .success-title {
        font-size: 1.5rem;
      }

      .action-buttons {
        flex-direction: column;
      }

      .btn {
        width: 100%;
      }

      .timeline-steps {
        overflow-x: auto;
      }

      .timeline-step {
        min-width: 70px;
      }
    }
  </style>
  <script src="/js/theme.js"></script>

</head>

