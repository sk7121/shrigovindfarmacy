<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Cancellations — Shri Govind Pharmacy</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    :root {
      --primary: #1c8125;
      --primary-dark: #145a1a;
      --bg-light: #f0fdf4;
      --surface: #ffffff;
      --text-dark: #17252a;
      --text-muted: #6b7c85;
      --border: #e9ecef;
      --shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      --success: #28a745;
      --warning: #ffc107;
      --danger: #dc3545;
      --info: #17a2b8;
    }

    [data-theme="dark"] {
      --bg-light: #0b0c10;
      --surface: #1e1e1e;
      --text-dark: #d1d9e0;
      --text-muted: #7f8c95;
      --border: #2d2d2d;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--bg-light);
      color: var(--text-dark);
      min-height: 100vh;
    }

    .page-header {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 1rem 0;
    }

    .header-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      text-decoration: none;
      color: var(--text-dark);
      font-weight: 700;
    }

    .logo-icon {
      width: 40px;
      height: 40px;
      background: linear-gradient(135deg, var(--primary), var(--primary-dark));
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
    }

    .nav-links {
      display: flex;
      gap: 1.5rem;
      align-items: center;
    }

    .nav-links a {
      color: var(--text-dark);
      text-decoration: none;
      font-weight: 500;
      transition: color 0.2s;
    }

    .nav-links a:hover {
      color: var(--primary);
    }

    .main-content {
      max-width: 1200px;
      margin: 2rem auto;
      padding: 0 2rem;
    }

    .page-title {
      font-size: 1.75rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
      color: var(--text-dark);
    }

    .empty-state {
      text-align: center;
      padding: 4rem 2rem;
      background: var(--surface);
      border-radius: 12px;
      box-shadow: var(--shadow);
    }

    .empty-state i {
      font-size: 4rem;
      color: var(--text-muted);
      margin-bottom: 1rem;
    }

    .empty-state h3 {
      font-size: 1.5rem;
      margin-bottom: 0.5rem;
      color: var(--text-dark);
    }

    .empty-state p {
      color: var(--text-muted);
      margin-bottom: 1.5rem;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.5rem;
      border-radius: 8px;
      font-weight: 600;
      text-decoration: none;
      cursor: pointer;
      transition: all 0.2s;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--primary), var(--primary-dark));
      color: white;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(28, 129, 37, 0.3);
    }

    .cancellations-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .cancellation-card {
      background: var(--surface);
      border-radius: 12px;
      padding: 1.5rem;
      box-shadow: var(--shadow);
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .cancellation-info {
      flex: 1;
      min-width: 250px;
    }

    .cancellation-id {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--text-dark);
      margin-bottom: 0.25rem;
    }

    .cancellation-meta {
      font-size: 0.875rem;
      color: var(--text-muted);
    }

    .cancellation-status {
      padding: 0.5rem 1rem;
      border-radius: 20px;
      font-weight: 600;
      font-size: 0.875rem;
      white-space: nowrap;
    }

    .status-pending {
      background: rgba(255, 193, 7, 0.1);
      color: #ffc107;
    }

    .status-approved,
    .status-assigned,
    .status-otp_generated {
      background: rgba(52, 152, 219, 0.1);
      color: #3498db;
    }

    .status-picked_up,
    .status-verified,
    .status-refunded {
      background: rgba(40, 167, 69, 0.1);
      color: #28a745;
    }

    .status-rejected {
      background: rgba(220, 53, 69, 0.1);
      color: #dc3545;
    }

    .btn-view {
      padding: 0.5rem 1rem;
      background: var(--primary);
      color: white;
      text-decoration: none;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.875rem;
      transition: all 0.2s;
    }

    .btn-view:hover {
      background: var(--primary-dark);
      transform: translateY(-2px);
    }

    .filters {
      display: flex;
      gap: 1rem;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
    }

    .filter-btn {
      padding: 0.5rem 1rem;
      border: 2px solid var(--border);
      background: var(--surface);
      color: var(--text-dark);
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }

    .filter-btn.active,
    .filter-btn:hover {
      border-color: var(--primary);
      color: var(--primary);
    }

    @media (max-width: 768px) {
      .header-inner {
        padding: 0 1rem;
      }

      .main-content {
        padding: 0 1rem;
      }

      .nav-links {
        display: none;
      }

      .cancellation-card {
        flex-direction: column;
        align-items: flex-start;
      }

      .cancellation-actions {
        width: 100%;
        display: flex;
        gap: 0.5rem;
        margin-top: 1rem;
      }

      .btn-view {
        flex: 1;
        justify-content: center;
      }
    }
  </style>
  <script src="/js/theme.js"></script>
</head>

<body>
  <div class="page-header">
    <div class="header-inner">
      <a href="/home" class="logo">
        <div class="logo-icon"><i class="fas fa-store"></i></div>
        <span>Shri Govind Pharmacy</span>
      </a>
      <nav class="nav-links">
        <a href="/home"><i class="fas fa-home"></i> Home</a>
        <a href="/user/orders"><i class="fas fa-box"></i> Orders</a>
        <a href="/user/cancellations" class="active"><i class="fas fa-undo"></i> Cancellations</a>
        <a href="/account"><i class="fas fa-user"></i> Account</a>
        <a href="/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
      </nav>
    </div>
  </div>

  <div class="main-content">
    <h1 class="page-title"><i class="fas fa-undo"></i> My Cancellation Requests</h1>

    <!-- Filter Buttons -->
    <div class="filters">
      <button class="filter-btn active" data-status="all">All</button>
      <button class="filter-btn" data-status="pending">Pending</button>
      <button class="filter-btn" data-status="approved">Approved</button>
      <button class="filter-btn" data-status="assigned">Assigned</button>
      <button class="filter-btn" data-status="picked_up">Picked Up</button>
      <button class="filter-btn" data-status="refunded">Refunded</button>
      <button class="filter-btn" data-status="rejected">Rejected</button>
    </div>

    <!-- Cancellations List -->
    <div class="cancellations-list" id="cancellationsList">
      <% if (requests && requests.length > 0) { %>
        <% requests.forEach(request => { %>
          <div class="cancellation-card" data-status="<%= request.status %>">
            <div class="cancellation-info">
              <div class="cancellation-id">
                <i class="fas fa-file-alt"></i> <%= request.trackingId %>
              </div>
              <div class="cancellation-meta">
                <span>Order: <%= request.order.tracking?.orderId || 'N/A' %></span> •
                <span>Reason: <%= request.reason.replace(/_/g, ' ') %></span> •
                <span>Refund: ₹<%= request.refundAmount %></span>
              </div>
            </div>
            <div class="cancellation-actions">
              <span class="cancellation-status status-<%= request.status %>">
                <%= request.status.replace(/_/g, ' ') %>
              </span>
              <a href="/user/cancellations/<%= request._id %>" class="btn-view">
                <i class="fas fa-eye"></i> View Details
              </a>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="empty-state">
          <i class="fas fa-undo"></i>
          <h3>No Cancellation Requests</h3>
          <p>You haven't made any cancellation requests yet.</p>
          <a href="/user/orders" class="btn btn-primary">
            <i class="fas fa-box"></i> View Orders
          </a>
        </div>
      <% } %>
    </div>
  </div>

  <script>
    // Filter functionality
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');

        const status = this.dataset.status;
        document.querySelectorAll('.cancellation-card').forEach(card => {
          if (status === 'all' || card.dataset.status === status) {
            card.style.display = 'flex';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  </script>
</body>

</html>
