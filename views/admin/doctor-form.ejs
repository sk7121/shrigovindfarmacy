<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= action === 'create' ? 'Add' : 'Edit' %> Doctor — Admin — Shri Govind Pharmacy</title>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet">

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

  <style>
    :root {
      --primary: #1c8125;
      --primary-dark: #145a1a;
      --secondary: #e67e22;
      --bg: #f8f9fa;
      --surface: #ffffff;
      --text: #1a1a1a;
      --text-muted: #6c757d;
      --border: #e9ecef;
      --success: #28a745;
      --danger: #dc3545;
      --warning: #ffc107;
      --shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      --shadow-lg: 0 4px 16px rgba(0, 0, 0, 0.12);
    }

    [data-theme="dark"] {
      --bg: #121212;
      --surface: #1e1e1e;
      --text: #e0e0e0;
      --text-muted: #a0a0a0;
      --border: #2d2d2d;
      --shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
      --shadow-lg: 0 4px 16px rgba(0, 0, 0, 0.4);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    .admin-header {
      background: var(--surface);
      padding: 20px 40px;
      box-shadow: var(--shadow);
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .admin-header h1 {
      font-size: 1.5rem;
      color: var(--primary);
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .nav-links {
      display: flex;
      gap: 15px;
    }

    .nav-links a {
      padding: 10px 20px;
      border-radius: 8px;
      text-decoration: none;
      color: var(--text);
      font-weight: 600;
      transition: all 0.3s;
      background: var(--bg);
    }

    .nav-links a:hover,
    .nav-links a.active {
      background: var(--primary);
      color: white;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 40px 20px;
    }

    .page-header {
      margin-bottom: 30px;
    }

    .page-title {
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 10px;
    }

    .breadcrumb {
      color: var(--text-muted);
      font-size: 0.9rem;
    }

    .breadcrumb a {
      color: var(--primary);
      text-decoration: none;
    }

    .form-card {
      background: var(--surface);
      border-radius: 12px;
      box-shadow: var(--shadow);
      padding: 40px;
      margin-bottom: 30px;
    }

    .form-section {
      margin-bottom: 40px;
      padding-bottom: 30px;
      border-bottom: 1px solid var(--border);
    }

    .form-section:last-child {
      border-bottom: none;
      margin-bottom: 0;
      padding-bottom: 0;
    }

    .section-title {
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--primary);
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .form-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 20px;
      margin-bottom: 20px;
    }

    .form-group {
      margin-bottom: 20px;
    }

    .form-group label {
      display: block;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 8px;
      font-size: 0.9rem;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      padding: 12px 16px;
      border: 1.5px solid var(--border);
      border-radius: 8px;
      font-size: 0.9rem;
      font-family: 'Plus Jakarta Sans', sans-serif;
      color: var(--text);
      background: var(--bg);
      transition: all 0.3s;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: var(--primary);
      background: var(--surface);
      box-shadow: 0 0 0 3px rgba(28, 129, 37, 0.1);
    }

    .form-group textarea {
      resize: vertical;
      min-height: 100px;
    }

    .form-group small {
      display: block;
      margin-top: 6px;
      color: var(--text-muted);
      font-size: 0.8rem;
    }

    .checkbox-group {
      display: flex;
      flex-wrap: wrap;
      gap: 15px;
    }

    .checkbox-item {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 16px;
      background: var(--bg);
      border: 1.5px solid var(--border);
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.3s;
    }

    .checkbox-item:hover {
      border-color: var(--primary);
    }

    .checkbox-item input[type="checkbox"] {
      width: auto;
      cursor: pointer;
    }

    .checkbox-item input[type="checkbox"]:checked+span {
      color: var(--primary);
      font-weight: 600;
    }

    .btn {
      padding: 12px 24px;
      border-radius: 8px;
      border: none;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: all 0.3s;
      font-size: 0.9rem;
    }

    .btn-primary {
      background: var(--primary);
      color: white;
    }

    .btn-primary:hover {
      background: var(--primary-dark);
      transform: translateY(-2px);
      box-shadow: var(--shadow-lg);
    }

    .btn-secondary {
      background: var(--bg);
      color: var(--text);
      border: 1.5px solid var(--border);
    }

    .btn-secondary:hover {
      background: var(--border);
    }

    .form-actions {
      display: flex;
      gap: 15px;
      justify-content: flex-end;
      margin-top: 30px;
    }

    .theme-toggle {
      background: none;
      border: none;
      font-size: 1.2rem;
      color: var(--text);
      cursor: pointer;
      padding: 8px;
      border-radius: 8px;
      transition: all 0.3s;
    }

    .theme-toggle:hover {
      background: var(--bg);
    }

    .repeater-item {
      background: var(--bg);
      border: 1.5px solid var(--border);
      border-radius: 8px;
      padding: 20px;
      margin-bottom: 15px;
    }

    .repeater-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 15px;
    }

    .repeater-title {
      font-weight: 600;
      color: var(--text);
    }

    .btn-remove {
      background: var(--danger);
      color: white;
      border: none;
      padding: 6px 12px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 0.85rem;
    }

    .btn-add {
      background: var(--success);
      color: white;
      border: none;
      padding: 10px 20px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 0.9rem;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .btn-add:hover {
      opacity: 0.9;
    }

    @media (max-width: 768px) {
      .admin-header {
        padding: 15px 20px;
        flex-direction: column;
        gap: 15px;
        position: static;
      }

      .admin-header h1 {
        font-size: 1.3rem;
      }

      .nav-links {
        flex-wrap: wrap;
        justify-content: center;
      }

      .nav-links a {
        padding: 8px 12px;
        font-size: 0.85rem;
      }

      .container {
        padding: 20px 15px;
      }

      .form-card {
        padding: 25px 20px;
      }

      .form-row {
        grid-template-columns: 1fr;
      }

      .section-title {
        font-size: 1.1rem;
      }

      .page-title {
        font-size: 1.5rem;
      }

      .form-actions {
        flex-direction: column;
      }

      .form-actions .btn {
        width: 100%;
        justify-content: center;
      }

      .checkbox-group {
        flex-direction: column;
      }

      .checkbox-item {
        width: 100%;
      }
    }

    @media (max-width: 480px) {
      .admin-header h1 {
        font-size: 1.2rem;
      }

      .form-card {
        padding: 20px 15px;
      }

      .page-title {
        font-size: 1.3rem;
      }
    }
  </style>
  <script src="/js/theme.js"></script>

</head>

<body>
  <style>
    .flash {
      padding: 12px 14px;
      border-radius: 14px;
      margin: 18px auto;
      max-width: 980px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 10px;
      border: 1px solid rgba(0,0,0,0.08);
      background: rgba(255, 255, 255, 0.9);
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    }
    .flash.success {
      border-color: rgba(74, 222, 128, 0.4);
      color: #166534;
      background: rgba(74, 222, 128, 0.15);
    }
    .flash.error {
      border-color: rgba(255, 107, 107, 0.4);
      color: #b91c1c;
      background: rgba(254, 202, 202, 0.25);
    }
  </style>
  <% if (success && success.length) { %>
    <div class="flash success"><%= success[0] %></div>
  <% } %>
  <% if (error && error.length) { %>
    <div class="flash error"><%= error[0] %></div>
  <% } %>

  <header class="admin-header">
    <h1><i class="fa-solid fa-user-doctor"></i> <%= action === 'create' ? 'Add' : 'Edit' %> Doctor</h1>
    <div style="display: flex; gap: 15px; align-items: center;">
      <nav class="nav-links">
        <a href="/admin/home"><i class="fa-solid fa-chart-line"></i> Dashboard</a>
        <a href="/admin/doctors"><i class="fa-solid fa-user-doctor"></i> Doctors</a>
        <a href="/admin/appointments"><i class="fa-solid fa-calendar-check"></i> Appointments</a>
        <a href="/home"><i class="fa-solid fa-house"></i> Back to Site</a>
      </nav>
      <button class="theme-toggle" onclick="toggleTheme()">
        <i class="fa-solid fa-moon" id="theme-icon"></i>
      </button>
    </div>
  </header>

  <div class="container">
    <div class="page-header">
      <div class="breadcrumb">
        <a href="/admin/doctors"><i class="fa-solid fa-house"></i> Doctors</a>
        <i class="fa-solid fa-chevron-right" style="font-size: 0.7rem; margin: 0 8px;"></i>
        <span><%= action === 'create' ? 'Add New' : 'Edit' %> Doctor</span>
      </div>
      <h2 class="page-title"><%= action === 'create' ? 'Add New Doctor' : 'Edit Doctor' %></h2>
    </div>

    <form method="POST" action="/admin/doctors/<%= action === 'create' ? 'new' : 'edit/' + doctor._id %>" enctype="multipart/form-data">


      <!-- Basic Information -->
      <div class="form-card">
        <h3 class="section-title"><i class="fa-solid fa-circle-info"></i> Basic Information</h3>

        <div class="form-row">
          <div class="form-group">
            <label><i class="fa-solid fa-user"></i> Full Name *</label>
            <input type="text" name="name" value="<%= doctor?.name || '' %>" required placeholder="e.g., Himanshu Chaturvedi">
          </div>

          <div class="form-group">
            <label><i class="fa-solid fa-briefcase-medical"></i> Title *</label>
            <input type="text" name="title" value="<%= doctor?.title || '' %>" required placeholder="e.g., Senior Ayurvedic Physician">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label><i class="fa-solid fa-graduation-cap"></i> Registration Number</label>
            <input type="text" name="registrationNumber" value="<%= doctor?.registrationNumber || '' %>" placeholder="e.g., A-00452">
          </div>

          <div class="form-group">
            <label><i class="fa-solid fa-calendar"></i> Years of Experience</label>
            <input type="number" name="experience[years]" value="<%= doctor?.experience?.years || 0 %>" min="0" placeholder="0">
          </div>
        </div>

        <div class="form-group">
          <label><i class="fa-solid fa-image"></i> Doctor Profile Image *</label>
          <% if (doctor?.image) { %>
          <div style="margin-bottom: 10px;">
            <img id="image-preview" src="<%= doctor.image %>" alt="Doctor image" style="max-height: 150px; border-radius: 8px; box-shadow: 0 0 8px rgba(0, 0, 0, 0.1);" />
            <p style="font-size: 0.85rem; color: var(--text-muted); margin-top: 8px;">
              <i class="fa-solid fa-info-circle"></i> Current image is set. Upload a new image to replace it.
            </p>
          </div>
          <% } else { %>
          <div id="image-preview-container" style="display: none; margin-bottom: 10px;">
            <img id="image-preview" src="" alt="Preview" style="max-height: 150px; border-radius: 8px; box-shadow: 0 0 8px rgba(0, 0, 0, 0.1);" />
          </div>
          <% } %>
          <input type="file" name="image" id="image-input" accept="image/*" <%= action === 'create' ? 'required' : '' %> onchange="previewImage(this)">
          <small>
            <i class="fa-solid fa-circle-info"></i> 
            Upload a clear profile image (ideally 400x400, max 5MB). 
            <% if (action === 'edit') { %>For edit, leave blank to keep existing image.<% } %>
            <br>
            <i class="fa-solid fa-check"></i> Accepted formats: JPG, JPEG, PNG
          </small>
        </div>

        <div class="form-group">
          <label><i class="fa-solid fa-user-md"></i> About Doctor *</label>
          <textarea name="about" required placeholder="Write a brief description about the doctor..."><%= doctor?.about || '' %></textarea>
          <small>Provide a comprehensive description of the doctor's background, expertise, and approach to treatment.</small>
        </div>
      </div>

      <!-- Qualifications -->
      <div class="form-card">
        <h3 class="section-title"><i class="fa-solid fa-graduation-cap"></i> Qualifications</h3>

        <div id="qualifications-container">
          <% if (doctor?.qualifications && doctor.qualifications.length > 0) { %>
          <% doctor.qualifications.forEach((qual, index) => { %>
          <div class="repeater-item">
            <div class="repeater-header">
              <span class="repeater-title">Qualification <%= index + 1 %></span>
              <button type="button" class="btn-remove" onclick="this.parentElement.parentElement.remove()">
                <i class="fa-solid fa-trash"></i> Remove
              </button>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>Degree *</label>
                <input type="text" name="qualifications[<%= index %>][degree]" value="<%= qual.degree %>" required placeholder="e.g., BAMS, MD">
              </div>
              <div class="form-group">
                <label>Specialization</label>
                <input type="text" name="qualifications[<%= index %>][specialization]" value="<%= qual.specialization || '' %>" placeholder="e.g., Ayurvedic Medicine">
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>Institution</label>
                <input type="text" name="qualifications[<%= index %>][institution]" value="<%= qual.institution || '' %>" placeholder="e.g., Rajasthan Ayurveda University">
              </div>
              <div class="form-group">
                <label>Year</label>
                <input type="number" name="qualifications[<%= index %>][year]" value="<%= qual.year || '' %>" min="1950" max="<%= new Date().getFullYear() %>" placeholder="e.g., 2005">
              </div>
            </div>
          </div>
          <% }); %>
          <% } else { %>
          <div class="repeater-item">
            <div class="repeater-header">
              <span class="repeater-title">Qualification 1</span>
              <button type="button" class="btn-remove" onclick="this.parentElement.parentElement.remove()">
                <i class="fa-solid fa-trash"></i> Remove
              </button>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>Degree *</label>
                <input type="text" name="qualifications[0][degree]" required placeholder="e.g., BAMS, MD">
              </div>
              <div class="form-group">
                <label>Specialization</label>
                <input type="text" name="qualifications[0][specialization]" placeholder="e.g., Ayurvedic Medicine">
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>Institution</label>
                <input type="text" name="qualifications[0][institution]" placeholder="e.g., Rajasthan Ayurveda University">
              </div>
              <div class="form-group">
                <label>Year</label>
                <input type="number" name="qualifications[0][year]" min="1950" max="<%= new Date().getFullYear() %>" placeholder="e.g., 2005">
              </div>
            </div>
          </div>
          <% } %>
        </div>

        <button type="button" class="btn-add" onclick="addQualification()">
          <i class="fa-solid fa-plus"></i> Add Qualification
        </button>
      </div>

      <!-- Specializations -->
      <div class="form-card">
        <h3 class="section-title"><i class="fa-solid fa-stethoscope"></i> Specializations & Languages</h3>

        <div class="form-group">
          <label><i class="fa-solid fa-heart-pulse"></i> Specializations</label>
          <div class="checkbox-group">
            <% const specs = ['Digestive Disorders', 'Skin Conditions', 'Joint & Arthritis', 'Immunity Boosting', 'Stress & Anxiety', 'Weight Management', 'Sleep Disorders', 'Diabetes Management', 'Respiratory Health', 'Panchakarma', 'Cardiac Care', 'Neurology']; %>
            <% specs.forEach(spec => { %>
            <label class="checkbox-item">
              <input type="checkbox" name="specializations" value="<%= spec %>" <%= doctor?.specializations?.includes(spec) ? 'checked' : '' %>>
              <span><%= spec %></span>
            </label>
            <% }); %>
          </div>
        </div>

        <div class="form-group">
          <label><i class="fa-solid fa-language"></i> Languages Spoken</label>
          <div class="checkbox-group">
            <% const langs = ['Hindi', 'English', 'Rajasthani', 'Gujarati', 'Marathi', 'Punjabi', 'Bengali', 'Tamil', 'Telugu', 'Kannada']; %>
            <% langs.forEach(lang => { %>
            <label class="checkbox-item">
              <input type="checkbox" name="languages" value="<%= lang %>" <%= doctor?.languages?.includes(lang) ? 'checked' : '' %>>
              <span><%= lang %></span>
            </label>
            <% }); %>
          </div>
        </div>
      </div>

      <!-- Contact Information -->
      <div class="form-card">
        <h3 class="section-title"><i class="fa-solid fa-address-book"></i> Contact Information</h3>

        <div class="form-row">
          <div class="form-group">
            <label><i class="fa-solid fa-phone"></i> Phone Number *</label>
            <input type="tel" name="contact[phone]" value="<%= doctor?.contact?.phone || '' %>" required pattern="[6-9][0-9]{9}" placeholder="9876543210">
          </div>

          <div class="form-group">
            <label><i class="fa-brands fa-whatsapp"></i> WhatsApp Number *</label>
            <input type="tel" name="contact[whatsapp]" value="<%= doctor?.contact?.whatsapp || '' %>" required pattern="[6-9][0-9]{9}" placeholder="9876543210">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label><i class="fa-solid fa-envelope"></i> Email Address *</label>
            <input type="email" name="contact[email]" value="<%= doctor?.contact?.email || '' %>" required placeholder="doctor@example.com">
          </div>

          <div class="form-group">
            <label><i class="fa-solid fa-location-dot"></i> Clinic Address *</label>
            <input type="text" name="contact[clinicAddress]" value="<%= doctor?.contact?.clinicAddress || '' %>" required placeholder="Full clinic address">
          </div>
        </div>
      </div>

      <!-- Availability -->
      <div class="form-card">
        <h3 class="section-title"><i class="fa-solid fa-calendar-days"></i> Availability Schedule</h3>

        <% const days = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday']; %>
        <% days.forEach((day, index) => { %>
        <% const slot = doctor?.availability?.find(a => a.day === day); %>
        <div class="form-row" style="align-items: center; margin-bottom: 15px;">
          <div class="form-group" style="flex: 1; margin-bottom: 0;">
            <label><%= day %></label>
            <input type="hidden" name="availability[<%= index %>][day]" value="<%= day %>">
          </div>
          <div class="form-group" style="flex: 2; margin-bottom: 0;">
            <input type="text" name="availability[<%= index %>][startTime]" value="<%= slot?.startTime || '9:00 AM' %>" placeholder="Start Time">
          </div>
          <div class="form-group" style="flex: 2; margin-bottom: 0;">
            <input type="text" name="availability[<%= index %>][endTime]" value="<%= slot?.endTime || '1:00 PM' %>" placeholder="End Time">
          </div>
          <div class="form-group" style="flex: 1; margin-bottom: 0;">
            <label class="checkbox-item" style="margin-top: 30px;">
              <input type="checkbox" name="availability[<%= index %>][isAvailable]" value="true" <%= !slot || slot.isAvailable ? 'checked' : '' %>>
              <span>Available</span>
            </label>
          </div>
        </div>
        <% }); %>
      </div>

      <!-- Consultation Details -->
      <div class="form-card">
        <h3 class="section-title"><i class="fa-solid fa-file-invoice-dollar"></i> Consultation Details</h3>

        <div class="form-row">
          <div class="form-group">
            <label><i class="fa-solid fa-indian-rupee-sign"></i> First Visit Fee (₹)</label>
            <input type="number" name="consultationFee[firstVisit]" value="<%= doctor?.consultationFee?.firstVisit || 0 %>" min="0" placeholder="0">
          </div>

          <div class="form-group">
            <label><i class="fa-solid fa-indian-rupee-sign"></i> Follow-up Fee (₹)</label>
            <input type="number" name="consultationFee[followUp]" value="<%= doctor?.consultationFee?.followUp || 500 %>" min="0" placeholder="500">
          </div>
        </div>

        <div class="form-group">
          <label class="checkbox-item" style="display: inline-flex;">
            <input type="checkbox" name="consultationFee[isFreeFirstVisit]" value="true" <%= doctor?.consultationFee?.isFreeFirstVisit ? 'checked' : '' %>>
            <span><i class="fa-solid fa-gift"></i> First consultation is FREE</span>
          </label>
        </div>

        <div class="form-group">
          <label><i class="fa-solid fa-video"></i> Consultation Modes</label>
          <div class="checkbox-group">
            <% const modes = ['In-Clinic', 'Online', 'WhatsApp', 'Video Call']; %>
            <% modes.forEach(mode => { %>
            <label class="checkbox-item">
              <input type="checkbox" name="consultationModes" value="<%= mode %>" <%= doctor?.consultationModes?.includes(mode) ? 'checked' : '' %>>
              <span><%= mode %></span>
            </label>
            <% }); %>
          </div>
        </div>
      </div>

      <!-- Settings -->
      <div class="form-card">
        <h3 class="section-title"><i class="fa-solid fa-gear"></i> Settings</h3>

        <div class="form-group">
          <label class="checkbox-item" style="display: inline-flex;">
            <input type="checkbox" name="isActive" value="true" <%= doctor?.isActive !== false ? 'checked' : '' %>>
            <span><i class="fa-solid fa-check-circle"></i> Active (Doctor is available for consultations)</span>
          </label>
        </div>

        <div class="form-group">
          <label class="checkbox-item" style="display: inline-flex;">
            <input type="checkbox" name="featured" value="true" <%= doctor?.featured ? 'checked' : '' %>>
            <span><i class="fa-solid fa-star"></i> Featured (Show on main doctor page)</span>
          </label>
        </div>
      </div>

      <!-- Form Actions -->
      <div class="form-actions">
        <a href="/admin/doctors" class="btn btn-secondary">
          <i class="fa-solid fa-xmark"></i> Cancel
        </a>
        <button type="submit" class="btn btn-primary">
          <i class="fa-solid fa-save"></i> <%= action === 'create' ? 'Add Doctor' : 'Save Changes' %>
        </button>
      </div>

    </form>
  </div>

  <script>
    let qualCount = <%= doctor?.qualifications?.length || 1 %>;

    function addQualification() {
      const container = document.getElementById('qualifications-container');
      const index = qualCount++;

      const div = document.createElement('div');
      div.className = 'repeater-item';
      div.innerHTML = `
        <div class="repeater-header">
          <span class="repeater-title">Qualification ${index + 1}</span>
          <button type="button" class="btn-remove" onclick="this.parentElement.parentElement.remove()">
            <i class="fa-solid fa-trash"></i> Remove
          </button>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Degree *</label>
            <input type="text" name="qualifications[${index}][degree]" required placeholder="e.g., BAMS, MD">
          </div>
          <div class="form-group">
            <label>Specialization</label>
            <input type="text" name="qualifications[${index}][specialization]" placeholder="e.g., Ayurvedic Medicine">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Institution</label>
            <input type="text" name="qualifications[${index}][institution]" placeholder="e.g., Rajasthan Ayurveda University">
          </div>
          <div class="form-group">
            <label>Year</label>
            <input type="number" name="qualifications[${index}][year]" min="1950" max="${new Date().getFullYear()}" placeholder="e.g., 2005">
          </div>
        </div>
      `;

      container.appendChild(div);
    }

    // Image preview function
    function previewImage(input) {
      const file = input.files[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = function(e) {
          const preview = document.getElementById('image-preview');
          let previewContainer = document.getElementById('image-preview-container');
          
          // Create preview container if it doesn't exist (for new uploads)
          if (!previewContainer) {
            previewContainer = document.createElement('div');
            previewContainer.id = 'image-preview-container';
            previewContainer.style.cssText = 'margin-bottom: 10px;';
            input.parentElement.insertBefore(previewContainer, input);
          }
          
          // Create preview image if it doesn't exist
          if (!preview) {
            const newPreview = document.createElement('img');
            newPreview.id = 'image-preview';
            newPreview.style.cssText = 'max-height: 150px; border-radius: 8px; box-shadow: 0 0 8px rgba(0, 0, 0, 0.1);';
            newPreview.alt = 'Preview';
            previewContainer.appendChild(newPreview);
          }
          
          previewContainer.style.display = 'block';
          document.getElementById('image-preview').src = e.target.result;
        }
        reader.readAsDataURL(file);
      }
    }
  </script>

</body>

</html>
