<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Payments — Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300,400,500,600,700,800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    :root { --primary: #1c8125; --bg: #f8f9fa; --surface: #ffffff; --text: #1a1a1a; --text-muted: #6c757d; --border: #e9ecef; --success: #28a745; --danger: #dc3545; --warning: #ffc107; --shadow: 0 2px 8px rgba(0,0,0,0.08); }
    [data-theme="dark"] { --bg: #121212; --surface: #1e1e1e; --text: #e0e0e0; --text-muted: #a0a0a0; --border: #2d2d2d; }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }
    
    .admin-header { background: var(--surface); border-bottom: 1px solid var(--border); padding: 1rem 0; }
    .header-inner { max-width: 1400px; margin: 0 auto; padding: 0 2rem; display: flex; justify-content: space-between; align-items: center; }
    .logo { display: flex; align-items: center; gap: 0.75rem; text-decoration: none; color: var(--text); }
    .logo-icon { width: 40px; height: 40px; background: linear-gradient(135deg, var(--primary), var(--primary-dark)); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: white; }
    
    .main-content { max-width: 1400px; margin: 2rem auto; padding: 0 2rem; }
    .page-title { font-size: 1.75rem; font-weight: 700; margin-bottom: 1.5rem; }
    
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
    .stat-card { background: var(--surface); padding: 1.5rem; border-radius: 12px; box-shadow: var(--shadow); }
    .stat-label { font-size: 0.875rem; color: var(--text-muted); margin-bottom: 0.5rem; }
    .stat-value { font-size: 1.75rem; font-weight: 700; }
    .stat-value.success { color: var(--success); }
    .stat-value.warning { color: var(--warning); }
    .stat-value.danger { color: var(--danger); }
    
    .payments-table { background: var(--surface); border-radius: 12px; overflow: hidden; box-shadow: var(--shadow); }
    table { width: 100%; border-collapse: collapse; }
    th { background: var(--bg); padding: 1rem; text-align: left; font-weight: 600; font-size: 0.875rem; color: var(--text-muted); border-bottom: 1px solid var(--border); }
    td { padding: 1rem; border-bottom: 1px solid var(--border); }
    tr:last-child td { border-bottom: none; }
    
    .status-badge { padding: 0.4rem 0.8rem; border-radius: 20px; font-weight: 600; font-size: 0.8rem; }
    .status-paid { background: rgba(40, 167, 69, 0.1); color: var(--success); }
    .status-created { background: rgba(255, 193, 7, 0.1); color: #ffc107; }
    .status-failed { background: rgba(220, 53, 69, 0.1); color: var(--danger); }
    .status-refunded { background: rgba(108, 117, 125, 0.1); color: #6c757d; }
    
    .method-badge { display: inline-flex; align-items: center; gap: 0.25rem; padding: 0.25rem 0.5rem; background: var(--bg); border-radius: 6px; font-size: 0.85rem; }
    
    @media (max-width: 768px) { .header-inner, .main-content { padding: 0 1rem; } table { font-size: 0.875rem; } }
  </style>
  <!-- Theme Script -->
  <script src="/js/theme.js"></script>
</head>
<body>
  <style>
    .flash {
      padding: 12px 14px;
      border-radius: 14px;
      margin: 18px auto;
      max-width: 980px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 10px;
      border: 1px solid rgba(0,0,0,0.08);
      background: rgba(255, 255, 255, 0.9);
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    }
    .flash.success {
      border-color: rgba(74, 222, 128, 0.4);
      color: #166534;
      background: rgba(74, 222, 128, 0.15);
    }
    .flash.error {
      border-color: rgba(255, 107, 107, 0.4);
      color: #b91c1c;
      background: rgba(254, 202, 202, 0.25);
    }
  </style>
  <% if (success && success.length) { %>
    <div class="flash success"><%= success[0] %></div>
  <% } %>
  <% if (error && error.length) { %>
    <div class="flash error"><%= error[0] %></div>
  <% } %>

  <header class="admin-header">
    <div class="header-inner">
      <a href="/admin/home" class="logo">
        <img src="https://res.cloudinary.com/drufdfmfr/image/upload/v1772726044/favicon_uuzvml.svg" alt="Shri Govind Pharmacy" class="logo-favicon">
        <div class="logo-text"><span class="logo-main">Shri Govind</span><span class="logo-sub">Admin Panel</span></div>
      </a>
      <div>
        <a href="/admin/home" style="padding: 0.5rem 1rem; background: transparent; color: var(--text-muted); border: 1px solid var(--border); border-radius: 8px; text-decoration: none; margin-right: 0.5rem;">Dashboard</a>
        <a href="/logout" style="padding: 0.5rem 1rem; background: var(--danger); color: white; border: none; border-radius: 8px; text-decoration: none;">Logout</a>
      </div>
    </div>
  </header>

  <main class="main-content">
    <h1 class="page-title"><i class="fas fa-credit-card"></i> Payment Transactions</h1>
    
    <% 
      const totalPaid = payments.filter(p => p.razorpay.status === 'paid').reduce((sum, p) => sum + p.amount, 0);
      const totalPending = payments.filter(p => p.razorpay.status === 'created').reduce((sum, p) => sum + p.amount, 0);
      const totalFailed = payments.filter(p => p.razorpay.status === 'failed').length;
    %>
    
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">Total Collected</div>
        <div class="stat-value success">₹<%= Math.round(totalPaid).toLocaleString('en-IN') %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Pending Payments</div>
        <div class="stat-value warning">₹<%= Math.round(totalPending).toLocaleString('en-IN') %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Failed Transactions</div>
        <div class="stat-value danger"><%= totalFailed %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Total Transactions</div>
        <div class="stat-value"><%= payments.length %></div>
      </div>
    </div>

    <div class="payments-table">
      <table>
        <thead>
          <tr>
            <th>Payment ID</th>
            <th>Order ID</th>
            <th>Customer</th>
            <th>Amount</th>
            <th>Method</th>
            <th>Status</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% payments.forEach(payment => { %>
            <tr>
              <td>
                <div style="font-family: monospace; font-size: 0.85rem;">
                  <%= payment.razorpay.paymentId || payment.razorpay.orderId %>
                </div>
              </td>
              <td>
                <div style="font-family: monospace; font-size: 0.85rem;">
                  <%= payment.order?.tracking?.orderId || 'N/A' %>
                </div>
              </td>
              <td>
                <div style="font-weight: 600;"><%= payment.user?.name || 'N/A' %></div>
                <div style="font-size: 0.85rem; color: var(--text-muted);"><%= payment.user?.email || 'N/A' %></div>
              </td>
              <td><strong>₹<%= Math.round(payment.amount).toLocaleString('en-IN') %></strong></td>
              <td>
                <% if (payment.paymentMethod) { %>
                  <span class="method-badge">
                    <i class="fas fa-<%= payment.paymentMethod === 'card' ? 'credit-card' : payment.paymentMethod === 'upi' ? 'mobile-alt' : 'university' %>"></i>
                    <%= payment.paymentMethod.toUpperCase() %>
                  </span>
                <% } else { %>
                  <span style="color: var(--text-muted);">-</span>
                <% } %>
              </td>
              <td>
                <span class="status-badge status-<%= payment.razorpay.status %>">
                  <%= payment.razorpay.status.toUpperCase() %>
                </span>
              </td>
              <td><%= new Date(payment.createdAt).toLocaleDateString('en-IN') %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </main>
</body>
</html>
