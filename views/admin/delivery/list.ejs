<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Deliveries — Shri Govind Pharmacy</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root {
            --primary: #1c8125; --primary-dark: #145a1a; --secondary: #e67e22;
            --bg: #f8f9fa; --surface: #ffffff; --text: #1a1a1a;
            --text-muted: #6c757d; --border: #e9ecef;
            --success: #28a745; --danger: #dc3545; --warning: #ffc107;
            --shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        }
        [data-theme="dark"] {
            --bg: #121212; --surface: #1e1e1e; --text: #e0e0e0;
            --text-muted: #a0a0a0; --border: #2d2d2d;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--bg); color: var(--text); }
        .container { max-width: 1400px; margin: 0 auto; padding: 20px; }
        
        .header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 30px; padding: 20px; background: var(--surface);
            border-radius: 12px; box-shadow: var(--shadow);
        }
        .header h1 { color: var(--primary); font-size: 28px; }
        
        .btn {
            padding: 10px 20px; border: none; border-radius: 8px; cursor: pointer;
            font-weight: 600; text-decoration: none; display: inline-flex;
            align-items: center; gap: 8px; transition: all 0.3s;
        }
        .btn-primary { background: var(--primary); color: white; }
        .btn-primary:hover { background: var(--primary-dark); }
        .btn-outline { border: 2px solid var(--border); background: transparent; }
        
        .filters {
            background: var(--surface); padding: 20px; border-radius: 12px;
            margin-bottom: 20px; box-shadow: var(--shadow);
            display: flex; gap: 15px; flex-wrap: wrap; align-items: center;
        }
        .filter-group { display: flex; flex-direction: column; gap: 5px; }
        .filter-group label { font-size: 12px; color: var(--text-muted); font-weight: 500; }
        .filter-select {
            padding: 8px 12px; border: 1px solid var(--border);
            border-radius: 6px; font-size: 14px; background: var(--surface); color: var(--text);
        }
        
        .table-responsive { overflow-x: auto; border-radius: 8px; }
        table { width: 100%; border-collapse: collapse; background: var(--surface); }
        thead { background: var(--bg); }
        th, td {
            padding: 14px 16px; text-align: left; border-bottom: 1px solid var(--border);
        }
        th { font-weight: 600; font-size: 13px; color: var(--text-muted); text-transform: uppercase; }
        tr:hover { background: var(--bg); }
        
        .status-badge {
            padding: 6px 12px; border-radius: 20px; font-size: 12px;
            font-weight: 600; text-transform: capitalize;
        }
        .status-badge.pending_assignment { background: #f8d7da; color: #721c24; }
        .status-badge.assigned { background: #fff3cd; color: #856404; }
        .status-badge.picked_up { background: #d1ecf1; color: #0c5460; }
        .status-badge.in_transit { background: #cce5ff; color: #004085; }
        .status-badge.out_for_delivery { background: #d6d8d9; color: #1b1e21; }
        .status-badge.delivered { background: #d4edda; color: #155724; }
        .status-badge.failed_attempt { background: #f8d7da; color: #721c24; }
        .status-badge.cancelled { background: #e2e3e5; color: #383d41; }
        
        .pagination {
            display: flex; justify-content: center; gap: 10px; margin-top: 20px;
        }
        .page-item {
            padding: 8px 16px; border: 1px solid var(--border);
            border-radius: 6px; text-decoration: none; color: var(--text);
        }
        .page-item.active { background: var(--primary); color: white; border-color: var(--primary); }
    </style>
</head>
<body>
  <style>
    .flash {
      padding: 12px 14px;
      border-radius: 14px;
      margin: 18px auto;
      max-width: 980px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 10px;
      border: 1px solid rgba(0,0,0,0.08);
      background: rgba(255, 255, 255, 0.9);
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    }
    .flash.success {
      border-color: rgba(74, 222, 128, 0.4);
      color: #166534;
      background: rgba(74, 222, 128, 0.15);
    }
    .flash.error {
      border-color: rgba(255, 107, 107, 0.4);
      color: #b91c1c;
      background: rgba(254, 202, 202, 0.25);
    }
  </style>
  <% if (success && success.length) { %>
    <div class="flash success"><%= success[0] %></div>
  <% } %>
  <% if (error && error.length) { %>
    <div class="flash error"><%= error[0] %></div>
  <% } %>

    <div class="container">
        <div class="header">
            <div>
                <h1><i class="fas fa-shipping-fast"></i> All Deliveries</h1>
                <p style="color: var(--text-muted);">Total: <%= totalDeliveries %> deliveries</p>
            </div>
            <div style="display: flex; gap: 10px; align-items: center;">
                <button class="icon-btn" id="theme-toggle" title="Toggle dark mode" aria-label="Toggle dark mode" style="background: transparent; border: 2px solid var(--border); border-radius: 8px; padding: 8px 12px; cursor: pointer; color: var(--text);">
                    <i class="fas fa-moon" id="theme-icon"></i>
                </button>
                <a href="/admin/delivery" class="btn btn-outline"><i class="fas fa-chart-line"></i> Dashboard</a>
                <a href="/admin/home" class="btn btn-primary"><i class="fas fa-arrow-left"></i> Back to Admin</a>
            </div>
        </div>

        <div class="filters">
            <form action="/admin/deliveries" method="GET" style="display: flex; gap: 15px; flex-wrap: wrap;">
                <div class="filter-group">
                    <label>Status</label>
                    <select name="status" class="filter-select">
                        <option value="">All Statuses</option>
                        <option value="pending_assignment" <%= filters.status === 'pending_assignment' ? 'selected' : '' %>>Pending Assignment</option>
                        <option value="assigned" <%= filters.status === 'assigned' ? 'selected' : '' %>>Assigned</option>
                        <option value="picked_up" <%= filters.status === 'picked_up' ? 'selected' : '' %>>Picked Up</option>
                        <option value="in_transit" <%= filters.status === 'in_transit' ? 'selected' : '' %>>In Transit</option>
                        <option value="out_for_delivery" <%= filters.status === 'out_for_delivery' ? 'selected' : '' %>>Out for Delivery</option>
                        <option value="delivered" <%= filters.status === 'delivered' ? 'selected' : '' %>>Delivered</option>
                        <option value="failed_attempt" <%= filters.status === 'failed_attempt' ? 'selected' : '' %>>Failed Attempt</option>
                        <option value="cancelled" <%= filters.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label>&nbsp;</label>
                    <button type="submit" class="btn btn-primary"><i class="fas fa-filter"></i> Filter</button>
                </div>
            </form>
        </div>

        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>QR Code</th>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Agent</th>
                        <th>Status</th>
                        <th>COD</th>
                        <th>Est. Delivery</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (deliveries && deliveries.length > 0) { %>
                        <% deliveries.forEach(delivery => { %>
                            <tr>
                                <td><code><%= delivery.qrCode.substring(0, 12) %>...</code></td>
                                <td><%= delivery.order?.tracking?.orderId || 'N/A' %></td>
                                <td><%= delivery.deliveryAddress?.fullName || 'N/A' %></td>
                                <td><%= delivery.assignedTo?.name || '<span style="color: var(--text-muted);">Unassigned</span>' %></td>
                                <td><span class="status-badge <%= delivery.status %>"><%= delivery.status.replace(/_/g, ' ') %></span></td>
                                <td><%= delivery.codAmount > 0 ? '₹' + delivery.codAmount : '-' %></td>
                                <td><%= delivery.estimatedDelivery ? new Date(delivery.estimatedDelivery).toLocaleDateString() : 'Not set' %></td>
                                <td><%= new Date(delivery.createdAt).toLocaleDateString() %></td>
                                <td>
                                    <a href="/admin/delivery/<%= delivery._id %>" class="btn btn-outline" style="padding: 6px 12px; font-size: 12px;">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="9" style="text-align: center; padding: 40px;">
                                <i class="fas fa-inbox" style="font-size: 48px; color: var(--text-muted); margin-bottom: 10px;"></i>
                                <p style="color: var(--text-muted);">No deliveries found</p>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <% if (totalPages > 1) { %>
            <div class="pagination">
                <% if (currentPage > 1) { %>
                    <a href="/admin/deliveries?page=<%= currentPage - 1 %>&status=<%= filters.status %>" class="page-item">Previous</a>
                <% } %>
                
                <% for (let i = 1; i <= totalPages; i++) { %>
                    <a href="/admin/deliveries?page=<%= i %>&status=<%= filters.status %>" class="page-item <%= i === currentPage ? 'active' : '' %>"><%= i %></a>
                <% } %>
                
                <% if (currentPage < totalPages) { %>
                    <a href="/admin/deliveries?page=<%= currentPage + 1 %>&status=<%= filters.status %>" class="page-item">Next</a>
                <% } %>
            </div>
        <% } %>
    </div>

    <script src="/js/theme.js"></script>
</body>
</html>
