<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delivery Dashboard — Shri Govind Pharmacy</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root {
            --primary: #1c8125;
            --primary-dark: #145a1a;
            --secondary: #e67e22;
            --bg: #f8f9fa;
            --surface: #ffffff;
            --text: #1a1a1a;
            --text-muted: #6c757d;
            --border: #e9ecef;
            --success: #28a745;
            --danger: #dc3545;
            --warning: #ffc107;
            --info: #17a2b8;
            --shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        }

        [data-theme="dark"] {
            --bg: #121212;
            --surface: #1e1e1e;
            --text: #e0e0e0;
            --text-muted: #a0a0a0;
            --border: #2d2d2d;
            --shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--bg); color: var(--text); }
        
        .dashboard { max-width: 1400px; margin: 0 auto; padding: 20px; }
        
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding: 20px;
            background: var(--surface);
            border-radius: 12px;
            box-shadow: var(--shadow);
        }

        .header h1 { font-size: 28px; color: var(--primary); }
        .header-actions { display: flex; gap: 10px; align-items: center; }

        .icon-btn {
            background: transparent;
            border: 2px solid var(--border);
            border-radius: 8px;
            padding: 8px 12px;
            cursor: pointer;
            color: var(--text);
            transition: all 0.3s;
        }
        .icon-btn:hover {
            background: var(--primary);
            border-color: var(--primary);
            color: white;
        }

        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s;
        }

        .btn-primary { background: var(--primary); color: white; }
        .btn-primary:hover { background: var(--primary-dark); }
        .btn-secondary { background: var(--secondary); color: white; }
        .btn-outline { border: 2px solid var(--border); background: transparent; }

        /* Stats Cards */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: var(--surface);
            padding: 24px;
            border-radius: 12px;
            box-shadow: var(--shadow);
            border-left: 4px solid var(--primary);
        }

        .stat-card.danger { border-left-color: var(--danger); }
        .stat-card.warning { border-left-color: var(--warning); }
        .stat-card.success { border-left-color: var(--success); }
        .stat-card.info { border-left-color: var(--info); }

        .stat-card h3 {
            font-size: 14px;
            color: var(--text-muted);
            margin-bottom: 8px;
            font-weight: 500;
        }

        .stat-card .value {
            font-size: 32px;
            font-weight: 700;
            color: var(--text);
        }

        .stat-card .trend {
            font-size: 13px;
            margin-top: 8px;
            color: var(--text-muted);
        }

        /* Section */
        .section {
            background: var(--surface);
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 24px;
            box-shadow: var(--shadow);
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .section-title {
            font-size: 20px;
            font-weight: 600;
            color: var(--text);
        }

        /* Table */
        .table-responsive {
            overflow-x: auto;
            border-radius: 8px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead {
            background: var(--bg);
        }

        th, td {
            padding: 14px 16px;
            text-align: left;
            border-bottom: 1px solid var(--border);
        }

        th {
            font-weight: 600;
            font-size: 13px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        tr:hover { background: var(--bg); }

        /* Status Badge */
        .status-badge {
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            text-transform: capitalize;
        }

        .status-badge.pending_assignment { background: #f8d7da; color: #721c24; }
        .status-badge.assigned { background: #fff3cd; color: #856404; }
        .status-badge.picked_up { background: #d1ecf1; color: #0c5460; }
        .status-badge.in_transit { background: #cce5ff; color: #004085; }
        .status-badge.out_for_delivery { background: #d6d8d9; color: #1b1e21; }
        .status-badge.delivered { background: #d4edda; color: #155724; }
        .status-badge.failed_attempt { background: #f8d7da; color: #721c24; }
        .status-badge.cancelled { background: #e2e3e5; color: #383d41; }

        /* Agent Cards */
        .agents-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
        }

        .agent-card {
            background: var(--bg);
            border-radius: 12px;
            padding: 20px;
            border: 1px solid var(--border);
        }

        .agent-card-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 15px;
        }

        .agent-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: var(--primary);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: 600;
        }

        .agent-info h4 { font-size: 16px; margin-bottom: 4px; }
        .agent-info p { font-size: 13px; color: var(--text-muted); }

        .agent-stats {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
        }

        .agent-stat {
            background: var(--surface);
            padding: 12px;
            border-radius: 8px;
            text-align: center;
        }

        .agent-stat .label { font-size: 11px; color: var(--text-muted); }
        .agent-stat .value { font-size: 18px; font-weight: 600; margin-top: 4px; }

        .agent-status {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 600;
            margin-top: 10px;
        }

        .agent-status.active { background: #d4edda; color: #155724; }
        .agent-status.offline { background: #e2e3e5; color: #383d41; }

        @media (max-width: 768px) {
            .dashboard { padding: 10px; }
            
            .header { 
                flex-direction: column; 
                gap: 15px; 
                padding: 15px;
            }
            
            .header h1 { font-size: 22px; }
            
            .header-actions { 
                flex-wrap: wrap; 
                justify-content: center;
                gap: 8px;
            }
            
            .header-actions .btn {
                padding: 8px 12px;
                font-size: 13px;
            }
            
            .stats-grid { grid-template-columns: 1fr; gap: 15px; }
            
            .stat-card { padding: 18px; }
            
            .stat-card .value { font-size: 26px; }
            
            .agents-grid { grid-template-columns: 1fr; }
            
            .section { padding: 15px; }
            
            .table-responsive {
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
            }
            
            table { min-width: 600px; }
            
            .section-header {
                flex-direction: column;
                gap: 10px;
                align-items: flex-start;
            }
        }
        
        @media (max-width: 480px) {
            .header h1 { font-size: 20px; }
            
            .header-actions .btn {
                width: 100%;
                justify-content: center;
            }
            
            .stat-card .value { font-size: 22px; }
            .stat-card .label { font-size: 12px; }
        }
    </style>
</head>
<body>
  <style>
    .flash {
      padding: 12px 14px;
      border-radius: 14px;
      margin: 18px auto;
      max-width: 980px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 10px;
      border: 1px solid rgba(0,0,0,0.08);
      background: rgba(255, 255, 255, 0.9);
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    }
    .flash.success {
      border-color: rgba(74, 222, 128, 0.4);
      color: #166534;
      background: rgba(74, 222, 128, 0.15);
    }
    .flash.error {
      border-color: rgba(255, 107, 107, 0.4);
      color: #b91c1c;
      background: rgba(254, 202, 202, 0.25);
    }
  </style>
  <% if (success && success.length) { %>
    <div class="flash success"><%= success[0] %></div>
  <% } %>
  <% if (error && error.length) { %>
    <div class="flash error"><%= error[0] %></div>
  <% } %>

    <div class="dashboard">
        <div class="header">
            <div>
                <h1><i class="fas fa-shipping-fast"></i> Delivery Management</h1>
                <p style="color: var(--text-muted); margin-top: 5px;">Track and manage all deliveries</p>
            </div>
            <div class="header-actions">
                <button class="icon-btn" id="theme-toggle" title="Toggle dark mode" aria-label="Toggle dark mode">
                    <i class="fas fa-moon" id="theme-icon"></i>
                </button>
                <a href="/admin/deliveries" class="btn btn-outline">
                    <i class="fas fa-list"></i> All Deliveries
                </a>
                <a href="/admin/delivery-agents" class="btn btn-outline">
                    <i class="fas fa-users"></i> Agents
                </a>
                <a href="/admin/shipping-partners" class="btn btn-outline">
                    <i class="fas fa-truck"></i> Partners
                </a>
                <a href="/admin/home" class="btn btn-primary">
                    <i class="fas fa-arrow-left"></i> Back to Admin
                </a>
            </div>
        </div>

        <!-- Statistics -->
        <div class="stats-grid">
            <div class="stat-card">
                <h3><i class="fas fa-box"></i> Total Deliveries</h3>
                <div class="value"><%= stats?.total || 0 %></div>
                <div class="trend">All time deliveries</div>
            </div>
            <div class="stat-card warning">
                <h3><i class="fas fa-clock"></i> Pending</h3>
                <div class="value"><%= stats?.pending || 0 %></div>
                <div class="trend">Awaiting assignment</div>
            </div>
            <div class="stat-card info">
                <h3><i class="fas fa-motorcycle"></i> Out for Delivery</h3>
                <div class="value"><%= stats?.outForDelivery || 0 %></div>
                <div class="trend">Final delivery stage</div>
            </div>
            <div class="stat-card success">
                <h3><i class="fas fa-check-circle"></i> Today's Deliveries</h3>
                <div class="value"><%= stats?.today || 0 %></div>
                <div class="trend">Completed today</div>
            </div>
            <div class="stat-card danger">
                <h3><i class="fas fa-money-bill-wave"></i> COD Pending</h3>
                <div class="value">₹<%= stats?.codPending || 0 %></div>
                <div class="trend">To be collected</div>
            </div>
            <div class="stat-card success">
                <h3><i class="fas fa-users"></i> Active Agents</h3>
                <div class="value"><%= stats?.agents?.active || 0 %>/<%= stats?.agents?.total || 0 %></div>
                <div class="trend">Currently available</div>
            </div>
        </div>

        <!-- Recent Deliveries -->
        <div class="section">
            <div class="section-header">
                <h2 class="section-title">Recent Deliveries</h2>
                <a href="/admin/deliveries" class="btn btn-primary">View All</a>
            </div>
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>QR Code</th>
                            <th>Order ID</th>
                            <th>Customer</th>
                            <th>Agent</th>
                            <th>Status</th>
                            <th>COD</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (deliveries && deliveries.length > 0) { %>
                            <% deliveries.forEach(delivery => { %>
                                <tr>
                                    <td><code><%= delivery.qrCode.substring(0, 12) %>...</code></td>
                                    <td><%= delivery.order?.tracking?.orderId || 'N/A' %></td>
                                    <td><%= delivery.deliveryAddress?.fullName || 'N/A' %></td>
                                    <td><%= delivery.assignedTo?.name || 'Unassigned' %></td>
                                    <td>
                                        <span class="status-badge <%= delivery.status %>">
                                            <%= delivery.status.replace(/_/g, ' ') %>
                                        </span>
                                    </td>
                                    <td><%= delivery.codAmount > 0 ? '₹' + delivery.codAmount : '-' %></td>
                                    <td><%= new Date(delivery.createdAt).toLocaleDateString() %></td>
                                    <td>
                                        <a href="/admin/delivery/<%= delivery._id %>" class="btn btn-outline" style="padding: 6px 12px; font-size: 12px;">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="8" style="text-align: center; padding: 40px;">
                                    <i class="fas fa-inbox" style="font-size: 48px; color: var(--text-muted); margin-bottom: 10px;"></i>
                                    <p style="color: var(--text-muted);">No deliveries found</p>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Delivery Agents -->
        <div class="section">
            <div class="section-header">
                <h2 class="section-title">Delivery Agents</h2>
                <a href="/admin/delivery-agents" class="btn btn-primary">Manage Agents</a>
            </div>
            <div class="agents-grid">
                <% if (agents && agents.length > 0) { %>
                    <% agents.slice(0, 6).forEach(agent => { %>
                        <div class="agent-card">
                            <div class="agent-card-header">
                                <div class="agent-avatar">
                                    <%= agent.name.charAt(0).toUpperCase() %>
                                </div>
                                <div class="agent-info">
                                    <h4><%= agent.name %></h4>
                                    <p><%= agent.employeeId %></p>
                                    <span class="agent-status <%= agent.isActive ? 'active' : 'offline' %>">
                                        <%= agent.isActive ? 'Active' : 'Inactive' %>
                                    </span>
                                </div>
                            </div>
                            <div class="agent-stats">
                                <div class="agent-stat">
                                    <div class="label">Total</div>
                                    <div class="value"><%= agent.stats?.totalDeliveries || 0 %></div>
                                </div>
                                <div class="agent-stat">
                                    <div class="label">Rating</div>
                                    <div class="value">⭐ <%= agent.stats?.averageRating || '0' %></div>
                                </div>
                                <div class="agent-stat">
                                    <div class="label">On-Time</div>
                                    <div class="value"><%= agent.stats?.onTimeDeliveryRate || 100 %>%</div>
                                </div>
                                <div class="agent-stat">
                                    <div class="label">Current</div>
                                    <div class="value"><%= agent.currentDeliveries || 0 %></div>
                                </div>
                            </div>
                            <div style="margin-top: 15px;">
                                <a href="/admin/delivery-agent/<%= agent._id %>" class="btn btn-outline" style="width: 100%; justify-content: center;">
                                    View Profile
                                </a>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p style="color: var(--text-muted); text-align: center; padding: 40px;">No agents found</p>
                <% } %>
            </div>
        </div>
    </div>

    <script src="/js/theme.js"></script>
</body>
</html>
