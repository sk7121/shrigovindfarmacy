<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delivery Label - <%= delivery.qrCode %> | Shri Govind Pharmacy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root {
            --primary: #1c8125;
            --primary-dark: #145a1a;
            --bg: #f8f9fa;
            --surface: #ffffff;
            --text: #1a1a1a;
            --text-muted: #6c757d;
            --border: #e9ecef;
            --success: #28a745;
            --shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        }

        [data-theme="dark"] {
            --bg: #121212;
            --surface: #1e1e1e;
            --text: #e0e0e0;
            --text-muted: #a0a0a0;
            --border: #2d2d2d;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            padding: 2rem;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .page-header {
            background: var(--surface);
            padding: 1.5rem;
            border-radius: 12px;
            margin-bottom: 1.5rem;
            box-shadow: var(--shadow);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .page-header h1 {
            color: var(--primary);
            font-size: 1.5rem;
        }

        .btn {
            padding: 0.75rem 1.5rem;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.2s;
        }

        .btn-outline {
            background: transparent;
            border: 2px solid var(--border);
            color: var(--text);
        }

        .btn-outline:hover {
            border-color: var(--primary);
            color: var(--primary);
        }

        .btn-primary {
            background: var(--primary);
            color: white;
        }

        .btn-primary:hover {
            background: var(--primary-dark);
        }

        .label-container {
            background: var(--surface);
            padding: 2rem;
            border-radius: 12px;
            box-shadow: var(--shadow);
            margin-bottom: 1.5rem;
        }

        .label-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-bottom: 1.5rem;
            border-bottom: 2px solid var(--border);
            margin-bottom: 1.5rem;
        }

        .logo-section {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .logo-icon {
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.5rem;
        }

        .logo-text h2 {
            color: var(--primary);
            font-size: 1.25rem;
            font-weight: 700;
        }

        .logo-text p {
            color: var(--text-muted);
            font-size: 0.875rem;
        }

        .delivery-badge {
            padding: 0.5rem 1rem;
            background: rgba(28, 129, 37, 0.1);
            color: var(--primary);
            border-radius: 8px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .label-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 2rem;
            margin-bottom: 1.5rem;
        }

        .shipping-info h3,
        .delivery-info h3 {
            color: var(--text);
            font-size: 1rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .shipping-info h3 i,
        .delivery-info h3 i {
            color: var(--primary);
        }

        .info-card {
            background: var(--bg);
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 1rem;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            padding: 0.5rem 0;
            border-bottom: 1px solid var(--border);
        }

        .info-row:last-child {
            border-bottom: none;
        }

        .info-label {
            color: var(--text-muted);
            font-weight: 500;
        }

        .info-value {
            font-weight: 600;
            color: var(--text);
        }

        .qr-section {
            text-align: center;
        }

        .qr-code {
            width: 200px;
            height: 200px;
            margin: 0 auto 1rem;
            border: 2px solid var(--border);
            border-radius: 12px;
            padding: 1rem;
            background: white;
        }

        .qr-code img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .qr-label {
            font-weight: 600;
            color: var(--primary);
            margin-bottom: 0.5rem;
        }

        .qr-code-text {
            font-family: monospace;
            font-size: 0.875rem;
            color: var(--text-muted);
            word-break: break-all;
        }

        .order-items {
            margin-top: 1.5rem;
            padding-top: 1.5rem;
            border-top: 2px solid var(--border);
        }

        .order-items h3 {
            color: var(--text);
            font-size: 1rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .order-items h3 i {
            color: var(--primary);
        }

        .items-table {
            width: 100%;
            border-collapse: collapse;
        }

        .items-table th {
            text-align: left;
            padding: 0.75rem;
            background: var(--bg);
            font-weight: 600;
            color: var(--text);
        }

        .items-table td {
            padding: 0.75rem;
            border-bottom: 1px solid var(--border);
            color: var(--text);
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.875rem;
        }

        .status-badge.assigned {
            background: rgba(255, 193, 7, 0.1);
            color: var(--warning);
        }

        .status-badge.out_for_delivery {
            background: rgba(230, 126, 34, 0.1);
            color: var(--secondary);
        }

        .status-badge.delivered {
            background: rgba(40, 167, 69, 0.1);
            color: var(--success);
        }

        .print-actions {
            display: flex;
            gap: 1rem;
            margin-top: 1.5rem;
        }

        @media print {
            body {
                background: white;
                padding: 0;
            }

            .page-header,
            .print-actions {
                display: none;
            }

            .label-container {
                box-shadow: none;
                border: 1px solid #ddd;
            }
        }

        @media (max-width: 768px) {
            .label-grid {
                grid-template-columns: 1fr;
            }

            .label-header {
                flex-direction: column;
                gap: 1rem;
                text-align: center;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="page-header">
            <h1><i class="fas fa-shipping-fast"></i> Delivery Label</h1>
            <div style="display: flex; gap: 1rem;">
                <a href="/admin/delivery/<%= delivery._id %>" class="btn btn-outline">
                    <i class="fas fa-arrow-left"></i> Back
                </a>
                <button class="btn btn-primary" onclick="window.print()">
                    <i class="fas fa-print"></i> Print Label
                </button>
            </div>
        </div>

        <div class="label-container">
            <div class="label-header">
                <div class="logo-section">
                    <div class="logo-icon">
                        <i class="fas fa-mortar-pestle"></i>
                    </div>
                    <div class="logo-text">
                        <h2>Shri Govind Pharmacy</h2>
                        <p>Ayurvedic & Herbal Wellness</p>
                    </div>
                </div>
                <div class="delivery-badge">
                    <i class="fas fa-barcode"></i>
                    <%= delivery.qrCode %>
                </div>
            </div>

            <div class="label-grid">
                <div class="shipping-info">
                    <h3><i class="fas fa-map-marker-alt"></i> Delivery Address</h3>
                    <div class="info-card">
                        <div class="info-row">
                            <span class="info-label">Customer Name</span>
                            <span class="info-value"><%= delivery.deliveryAddress?.fullName || 'N/A' %></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Phone</span>
                            <span class="info-value"><%= delivery.deliveryAddress?.phone || 'N/A' %></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Address</span>
                            <span class="info-value"><%= delivery.deliveryAddress?.address || 'N/A' %></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">City, State, PIN</span>
                            <span class="info-value"><%= delivery.deliveryAddress?.city %>, <%= delivery.deliveryAddress?.state %> - <%= delivery.deliveryAddress?.pincode %></span>
                        </div>
                        <% if (delivery.deliveryAddress?.landmark) { %>
                            <div class="info-row">
                                <span class="info-label">Landmark</span>
                                <span class="info-value"><%= delivery.deliveryAddress.landmark %></span>
                            </div>
                        <% } %>
                    </div>

                    <% if (delivery.assignedTo) { %>
                        <h3><i class="fas fa-user"></i> Assigned Agent</h3>
                        <div class="info-card">
                            <div class="info-row">
                                <span class="info-label">Name</span>
                                <span class="info-value"><%= delivery.assignedTo.name %></span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Phone</span>
                                <span class="info-value"><%= delivery.assignedTo.phone %></span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Vehicle</span>
                                <span class="info-value"><%= delivery.assignedTo.vehicleType %> - <%= delivery.assignedTo.vehicleNumber %></span>
                            </div>
                        </div>
                    <% } %>
                </div>

                <div class="qr-section">
                    <div class="qr-label">Scan for Delivery Details</div>
                    <div class="qr-code">
                        <% if (qrLabel && qrLabel.qrCodeDataUri) { %>
                            <img src="<%= qrLabel.qrCodeDataUri %>" alt="QR Code">
                        <% } else { %>
                            <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: var(--text-muted);">
                                <i class="fas fa-qrcode" style="font-size: 4rem; opacity: 0.3;"></i>
                            </div>
                        <% } %>
                    </div>
                    <div class="qr-code-text"><%= delivery.qrCode %></div>
                </div>
            </div>

            <div class="order-items">
                <h3><i class="fas fa-box"></i> Order Details</h3>
                <div class="info-card">
                    <div class="info-row">
                        <span class="info-label">Order ID</span>
                        <span class="info-value"><%= delivery.order?.tracking?.orderId || 'N/A' %></span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Order Date</span>
                        <span class="info-value"><%= delivery.order ? new Date(delivery.order.createdAt).toLocaleDateString('en-IN') : 'N/A' %></span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Status</span>
                        <span class="status-badge <%= delivery.status %>">
                            <i class="fas fa-circle"></i> <%= delivery.status.replace('_', ' ').toUpperCase() %>
                        </span>
                    </div>
                    <% if (delivery.codAmount > 0) { %>
                        <div class="info-row">
                            <span class="info-label">COD Amount</span>
                            <span class="info-value">₹<%= delivery.codAmount %></span>
                        </div>
                    <% } %>
                    <% if (delivery.priority) { %>
                        <div class="info-row">
                            <span class="info-label">Priority</span>
                            <span class="info-value" style="color: <%= delivery.priority === 'high' ? 'var(--danger)' : 'var(--text)' %>;">
                                <%= delivery.priority.toUpperCase() %>
                            </span>
                        </div>
                    <% } %>
                </div>

                <% if (delivery.order && delivery.order.items && delivery.order.items.length > 0) { %>
                    <table class="items-table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Quantity</th>
                                <th>Price</th>
                                <th>Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% delivery.order.items.forEach(item => { %>
                                <tr>
                                    <td><%= item.name %></td>
                                    <td><%= item.quantity %></td>
                                    <td>₹<%= item.price %></td>
                                    <td>₹<%= item.subtotal %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                <% } %>
            </div>

            <div class="print-actions">
                <a href="/admin/delivery/<%= delivery._id %>/qr/<%= delivery.qrCode %>" class="btn btn-outline" download>
                    <i class="fas fa-download"></i> Download QR Code
                </a>
                <button class="btn btn-primary" onclick="window.print()">
                    <i class="fas fa-print"></i> Print Label
                </button>
            </div>
        </div>
    </div>

    <script>
        // Auto-print on load if coming from print action
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('print') === 'true') {
            window.print();
        }
    </script>
</body>

</html>
