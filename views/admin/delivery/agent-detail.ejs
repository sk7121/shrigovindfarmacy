<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= agent.name %> - Delivery Agent Profile</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root {
            --primary: #1c8125; --primary-dark: #145a1a; --secondary: #e67e22;
            --bg: #f8f9fa; --surface: #ffffff; --text: #1a1a1a;
            --text-muted: #6c757d; --border: #e9ecef;
            --success: #28a745; --danger: #dc3545; --warning: #ffc107;
            --shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        }
        [data-theme="dark"] {
            --bg: #121212; --surface: #1e1e1e; --text: #e0e0e0;
            --text-muted: #a0a0a0; --border: #2d2d2d;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--bg); color: var(--text); }
        .container { max-width: 1200px; margin: 0 auto; padding: 20px; }

        .header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 30px; padding: 20px; background: var(--surface);
            border-radius: 12px; box-shadow: var(--shadow);
        }
        .header h1 { color: var(--primary); font-size: 28px; }

        .btn {
            padding: 10px 20px; border: none; border-radius: 8px; cursor: pointer;
            font-weight: 600; text-decoration: none; display: inline-flex;
            align-items: center; gap: 8px;
        }
        .btn-primary { background: var(--primary); color: white; }
        .btn-success { background: var(--success); color: white; }
        .btn-danger { background: var(--danger); color: white; }
        .btn-outline { border: 2px solid var(--border); background: transparent; color: var(--text); }
        .btn-sm { padding: 6px 12px; font-size: 12px; }

        .flash {
            padding: 12px 16px; border-radius: 8px; margin-bottom: 20px;
        }
        .flash.success { background: #d4edda; color: #155724; }
        .flash.error { background: #f8d7da; color: #721c24; }

        .profile-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }

        .card {
            background: var(--surface);
            border-radius: 12px;
            padding: 20px;
            box-shadow: var(--shadow);
        }

        .card-title {
            font-size: 18px;
            font-weight: 600;
            color: var(--primary);
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 2px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            padding: 12px 0;
            border-bottom: 1px solid var(--border);
        }
        .info-row:last-child { border-bottom: none; }
        .info-label { font-weight: 500; color: var(--text-muted); }
        .info-value { font-weight: 600; color: var(--text); }

        .status-badge {
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }
        .status-badge.pending { background: #fff3cd; color: #856404; }
        .status-badge.active { background: #d4edda; color: #155724; }
        .status-badge.inactive { background: #f8d7da; color: #721c24; }
        .status-badge.verified { background: #d1ecf1; color: #0c5460; }

        .document-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 15px;
        }

        .document-card {
            background: var(--bg);
            border: 2px solid var(--border);
            border-radius: 8px;
            padding: 15px;
            text-align: center;
        }

        .document-card i {
            font-size: 48px;
            color: var(--primary);
            margin-bottom: 10px;
        }

        .document-card h4 {
            font-size: 14px;
            color: var(--text-muted);
            margin-bottom: 8px;
        }

        .document-card .doc-number {
            font-size: 13px;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 10px;
        }

        .document-card img {
            max-width: 100%;
            max-height: 200px;
            border-radius: 8px;
            margin-top: 10px;
            cursor: pointer;
            transition: transform 0.2s;
        }

        .document-card img:hover {
            transform: scale(1.05);
        }

        .document-card .no-doc {
            color: var(--text-muted);
            font-size: 12px;
            font-style: italic;
        }

        .document-card .view-btn {
            display: inline-block;
            margin-top: 10px;
            padding: 6px 12px;
            background: var(--primary);
            color: white;
            text-decoration: none;
            border-radius: 6px;
            font-size: 12px;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 15px;
            margin-top: 15px;
        }

        .stat-box {
            background: var(--bg);
            padding: 15px;
            border-radius: 8px;
            text-align: center;
        }

        .stat-box .value {
            font-size: 24px;
            font-weight: 700;
            color: var(--primary);
        }

        .stat-box .label {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 5px;
        }

        .avatar-large {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 40px;
            font-weight: 700;
            margin: 0 auto 15px;
            overflow: hidden;
            object-fit: cover;
        }
        
        .avatar-large img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .profile-header {
            text-align: center;
            padding: 20px;
        }

        .actions-bar {
            display: flex;
            gap: 10px;
            margin-top: 20px;
            flex-wrap: wrap;
        }

        .table-responsive {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }

        table th, table td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid var(--border);
        }

        table th {
            background: var(--bg);
            font-weight: 600;
            color: var(--text-muted);
            font-size: 13px;
        }

        table td {
            font-size: 14px;
        }

        @media (max-width: 768px) {
            .profile-grid {
                grid-template-columns: 1fr;
            }
            .header {
                flex-direction: column;
                gap: 15px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div>
                <h1><i class="fas fa-user-circle"></i> Delivery Agent Profile</h1>
                <p style="color: var(--text-muted);"><%= agent.name %></p>
            </div>
            <div style="display: flex; gap: 10px;">
                <a href="/admin/delivery-agents" class="btn btn-outline">
                    <i class="fas fa-arrow-left"></i> Back
                </a>
                <% if (!agent.isActive) { %>
                    <form action="/admin/delivery-agents/<%= agent._id %>/approve" method="POST" style="display: inline;">
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-check-circle"></i> Approve Agent
                        </button>
                    </form>
                <% } else { %>
                    <a href="/admin/delivery-agent/<%= agent._id %>/edit" class="btn btn-primary">
                        <i class="fas fa-edit"></i> Edit
                    </a>
                <% } %>
            </div>
        </div>

        <% if (locals.success && locals.success.length > 0) { %>
            <div class="flash success"><%= success %></div>
        <% } %>
        <% if (locals.error && locals.error.length > 0) { %>
            <div class="flash error"><%= error %></div>
        <% } %>

        <div class="profile-grid">
            <!-- Profile Information -->
            <div class="card">
                <div class="profile-header">
                    <div class="avatar-large">
                        <% if (agent.profileImage) { %>
                            <img src="<%= agent.profileImage %>" alt="<%= agent.name %>">
                        <% } else { %>
                            <%= agent.name.charAt(0).toUpperCase() %>
                        <% } %>
                    </div>
                    <h2><%= agent.name %></h2>
                    <p style="color: var(--text-muted);"><%= agent.employeeId || 'No Employee ID' %></p>
                    <div style="margin-top: 15px;">
                        <span class="status-badge <%= agent.isActive ? 'active' : 'pending' %>">
                            <%= agent.isActive ? 'Active' : 'Pending Approval' %>
                        </span>
                        <span class="status-badge <%= agent.isAvailable ? 'active' : 'inactive' %>" style="margin-left: 8px;">
                            <%= agent.isAvailable ? 'Available' : 'Unavailable' %>
                        </span>
                    </div>
                </div>

                <div class="info-row">
                    <span class="info-label"><i class="fas fa-envelope"></i> Email</span>
                    <span class="info-value"><%= agent.email %></span>
                </div>
                <div class="info-row">
                    <span class="info-label"><i class="fas fa-phone"></i> Phone</span>
                    <span class="info-value"><%= agent.phone %></span>
                </div>
                <div class="info-row">
                    <span class="info-label"><i class="fas fa-venus-mars"></i> Employment Type</span>
                    <span class="info-value"><%= agent.employmentType %></span>
                </div>
                <div class="info-row">
                    <span class="info-label"><i class="fas fa-calendar"></i> Joining Date</span>
                    <span class="info-value"><%= new Date(agent.joiningDate).toLocaleDateString('en-IN') %></span>
                </div>
                <div class="info-row">
                    <span class="info-label"><i class="fas fa-user-check"></i> Verified By</span>
                    <span class="info-value"><%= agent.verifiedBy?.name || 'Not Verified' %></span>
                </div>
            </div>

            <!-- Vehicle Information -->
            <div class="card">
                <h3 class="card-title"><i class="fas fa-motorcycle"></i> Vehicle Information</h3>
                
                <div class="info-row">
                    <span class="info-label">Vehicle Type</span>
                    <span class="info-value"><%= agent.vehicleType %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Vehicle Number</span>
                    <span class="info-value"><%= agent.vehicleNumber || 'Not Provided' %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">RC Document</span>
                    <span class="info-value"><%= agent.vehicleRC ? 'Uploaded' : 'Not Uploaded' %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Insurance</span>
                    <span class="info-value"><%= agent.vehicleInsurance ? 'Uploaded' : 'Not Uploaded' %></span>
                </div>

                <div class="actions-bar">
                    <% if (agent.vehicleRC) { %>
                        <a href="<%= agent.vehicleRC %>" target="_blank" class="btn btn-outline btn-sm">
                            <i class="fas fa-eye"></i> View RC
                        </a>
                    <% } %>
                    <% if (agent.vehicleInsurance) { %>
                        <a href="<%= agent.vehicleInsurance %>" target="_blank" class="btn btn-outline btn-sm">
                            <i class="fas fa-eye"></i> View Insurance
                        </a>
                    <% } %>
                </div>
            </div>

            <!-- Address & Coverage -->
            <div class="card">
                <h3 class="card-title"><i class="fas fa-map-marker-alt"></i> Address & Coverage</h3>
                
                <div class="info-row">
                    <span class="info-label">Street</span>
                    <span class="info-value"><%= agent.address?.street || 'N/A' %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">City</span>
                    <span class="info-value"><%= agent.address?.city || 'N/A' %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">State</span>
                    <span class="info-value"><%= agent.address?.state || 'N/A' %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Pincode</span>
                    <span class="info-value"><%= agent.address?.pincode || 'N/A' %></span>
                </div>

                <% if (agent.coverageAreas && agent.coverageAreas.length > 0) { %>
                    <div style="margin-top: 15px;">
                        <strong>Coverage Areas:</strong>
                        <ul style="margin-top: 8px; margin-left: 20px;">
                            <% agent.coverageAreas.forEach(area => { %>
                                <li><%= area.city %> - <%= area.pincode %></li>
                            <% }) %>
                        </ul>
                    </div>
                <% } %>
            </div>

            <!-- Police Verification -->
            <div class="card">
                <h3 class="card-title"><i class="fas fa-shield-alt"></i> Police Verification</h3>

                <div class="info-row">
                    <span class="info-label">Status</span>
                    <span class="status-badge <%= agent.policeVerification?.status %>">
                        <%= agent.policeVerification?.status || 'pending' %>
                    </span>
                </div>
                <div class="info-row">
                    <span class="info-label">Verified At</span>
                    <span class="info-value"><%= agent.policeVerification?.verifiedAt ? new Date(agent.policeVerification.verifiedAt).toLocaleDateString('en-IN') : 'Not Verified' %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Verified By</span>
                    <span class="info-value"><%= agent.policeVerification?.verifiedBy || 'N/A' %></span>
                </div>
                
                <% if (agent.policeVerification?.status !== 'verified') { %>
                    <div style="margin-top: 15px;">
                        <form action="/admin/delivery-agents/<%= agent._id %>/verify-profile" method="POST" style="display: inline;">
                            <button type="submit" class="btn btn-success btn-sm" onclick="return confirm('Are you sure you want to verify this agent\'s profile and documents?')">
                                <i class="fas fa-check-circle"></i> Verify Profile & Documents
                            </button>
                        </form>
                    </div>
                <% } else { %>
                    <div style="margin-top: 15px; padding: 10px; background: #d4edda; border-radius: 6px;">
                        <i class="fas fa-check-circle" style="color: var(--success);"></i> 
                        <strong style="color: #155724;">Profile Verified</strong>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- ID Documents Section -->
        <div class="card" style="margin-bottom: 20px;">
            <h3 class="card-title"><i class="fas fa-id-card"></i> Identity Documents & Proofs</h3>
            
            <div class="document-grid">
                <!-- Aadhar Card -->
                <div class="document-card">
                    <i class="fas fa-address-card"></i>
                    <h4>Aadhar Card</h4>
                    <% if (agent.aadharNumber) { %>
                        <p class="doc-number"><%= agent.aadharNumber %></p>
                    <% } else { %>
                        <p class="no-doc">Not provided</p>
                    <% } %>
                    <% if (agent.aadharImage) { %>
                        <img src="<%= agent.aadharImage %>" alt="Aadhar Card" onclick="viewImage(this.src)">
                        <br>
                        <a href="<%= agent.aadharImage %>" target="_blank" class="view-btn">
                            <i class="fas fa-external-link-alt"></i> Full Size
                        </a>
                    <% } else { %>
                        <p class="no-doc">No image uploaded</p>
                    <% } %>
                </div>

                <!-- PAN Card -->
                <div class="document-card">
                    <i class="fas fa-id-card"></i>
                    <h4>PAN Card</h4>
                    <% if (agent.panNumber) { %>
                        <p class="doc-number"><%= agent.panNumber %></p>
                    <% } else { %>
                        <p class="no-doc">Not provided</p>
                    <% } %>
                    <% if (agent.panImage) { %>
                        <img src="<%= agent.panImage %>" alt="PAN Card" onclick="viewImage(this.src)">
                        <br>
                        <a href="<%= agent.panImage %>" target="_blank" class="view-btn">
                            <i class="fas fa-external-link-alt"></i> Full Size
                        </a>
                    <% } else { %>
                        <p class="no-doc">No image uploaded</p>
                    <% } %>
                </div>

                <!-- Driving License -->
                <div class="document-card">
                    <i class="fas fa-id-badge"></i>
                    <h4>Driving License</h4>
                    <% if (agent.drivingLicense) { %>
                        <p class="doc-number">License No: <%= agent.drivingLicense %></p>
                        <% if (agent.drivingLicenseExpiry) { %>
                            <p style="font-size: 11px; color: var(--text-muted);">
                                Expires: <%= new Date(agent.drivingLicenseExpiry).toLocaleDateString('en-IN') %>
                            </p>
                        <% } %>
                        <img src="<%= agent.drivingLicense %>" alt="Driving License" onclick="viewImage(this.src)">
                        <br>
                        <a href="<%= agent.drivingLicense %>" target="_blank" class="view-btn">
                            <i class="fas fa-external-link-alt"></i> Full Size
                        </a>
                    <% } else { %>
                        <p class="no-doc">Not provided</p>
                    <% } %>
                </div>

                <!-- Vehicle RC -->
                <div class="document-card">
                    <i class="fas fa-file-alt"></i>
                    <h4>Vehicle RC</h4>
                    <% if (agent.vehicleRC) { %>
                        <img src="<%= agent.vehicleRC %>" alt="Vehicle RC" onclick="viewImage(this.src)">
                        <br>
                        <a href="<%= agent.vehicleRC %>" target="_blank" class="view-btn">
                            <i class="fas fa-external-link-alt"></i> Full Size
                        </a>
                    <% } else { %>
                        <p class="no-doc">Not uploaded</p>
                    <% } %>
                </div>

                <!-- Vehicle Insurance -->
                <div class="document-card">
                    <i class="fas fa-file-contract"></i>
                    <h4>Vehicle Insurance</h4>
                    <% if (agent.vehicleInsurance) { %>
                        <img src="<%= agent.vehicleInsurance %>" alt="Vehicle Insurance" onclick="viewImage(this.src)">
                        <br>
                        <a href="<%= agent.vehicleInsurance %>" target="_blank" class="view-btn">
                            <i class="fas fa-external-link-alt"></i> Full Size
                        </a>
                    <% } else { %>
                        <p class="no-doc">Not uploaded</p>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Performance Stats -->
        <div class="card" style="margin-bottom: 20px;">
            <h3 class="card-title"><i class="fas fa-chart-line"></i> Performance Statistics</h3>
            
            <div class="stats-grid">
                <div class="stat-box">
                    <div class="value"><%= agent.stats?.totalDeliveries || 0 %></div>
                    <div class="label">Total Deliveries</div>
                </div>
                <div class="stat-box">
                    <div class="value" style="color: var(--success);"><%= agent.stats?.successfulDeliveries || 0 %></div>
                    <div class="label">Successful</div>
                </div>
                <div class="stat-box">
                    <div class="value" style="color: var(--danger);"><%= agent.stats?.failedDeliveries || 0 %></div>
                    <div class="label">Failed</div>
                </div>
                <div class="stat-box">
                    <div class="value">⭐ <%= agent.stats?.averageRating || '0' %></div>
                    <div class="label">Avg Rating</div>
                </div>
                <div class="stat-box">
                    <div class="value"><%= agent.stats?.onTimeDeliveryRate || 100 %>%</div>
                    <div class="label">On-Time Rate</div>
                </div>
                <div class="stat-box">
                    <div class="value">₹<%= agent.stats?.totalEarnings || 0 %></div>
                    <div class="label">Total Earnings</div>
                </div>
            </div>
        </div>

        <!-- Recent Deliveries -->
        <div class="card">
            <h3 class="card-title"><i class="fas fa-shipping-fast"></i> Recent Deliveries</h3>
            
            <% if (deliveries && deliveries.length > 0) { %>
                <div class="table-responsive">
                    <table>
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Customer</th>
                                <th>Status</th>
                                <th>Amount</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% deliveries.forEach(delivery => { %>
                                <tr>
                                    <td><code><%= delivery.order?.orderId || 'N/A' %></code></td>
                                    <td><%= delivery.deliveryAddress?.fullName || 'N/A' %></td>
                                    <td>
                                        <span class="status-badge <%= delivery.status %>">
                                            <%= delivery.status.replace(/_/g, ' ') %>
                                        </span>
                                    </td>
                                    <td><%= delivery.codAmount ? '₹' + delivery.codAmount : 'Paid' %></td>
                                    <td><%= new Date(delivery.createdAt).toLocaleDateString('en-IN') %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <p style="text-align: center; color: var(--text-muted); padding: 40px;">
                    <i class="fas fa-inbox" style="font-size: 48px; margin-bottom: 10px;"></i><br>
                    No deliveries yet
                </p>
            <% } %>
        </div>
    </div>

    <!-- Image Viewer Modal -->
    <div id="imageModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); z-index: 9999; align-items: center; justify-content: center;" onclick="this.style.display='none'">
        <img id="modalImage" src="" style="max-width: 90%; max-height: 90%; border-radius: 8px;">
        <button onclick="document.getElementById('imageModal').style.display='none'" style="position: absolute; top: 20px; right: 40px; background: white; border: none; font-size: 30px; cursor: pointer; color: black; padding: 10px; border-radius: 50%;">&times;</button>
    </div>

    <script>
        function viewImage(src) {
            document.getElementById('modalImage').src = src;
            document.getElementById('imageModal').style.display = 'flex';
        }

        function showTab(tabName) {
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.style.display = 'none';
            });
            document.querySelectorAll('.tab').forEach(tab => {
                tab.classList.remove('active');
            });
            document.getElementById(tabName).style.display = 'block';
            event.target.classList.add('active');
        }
    </script>
    <script src="/js/theme.js"></script>
</body>
</html>
