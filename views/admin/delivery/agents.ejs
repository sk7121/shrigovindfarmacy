<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delivery Agents — Shri Govind Pharmacy</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root {
            --primary: #1c8125; --primary-dark: #145a1a; --secondary: #e67e22;
            --bg: #f8f9fa; --surface: #ffffff; --text: #1a1a1a;
            --text-muted: #6c757d; --border: #e9ecef;
            --success: #28a745; --danger: #dc3545; --warning: #ffc107;
            --shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        }
        [data-theme="dark"] {
            --bg: #121212; --surface: #1e1e1e; --text: #e0e0e0;
            --text-muted: #a0a0a0; --border: #2d2d2d;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--bg); color: var(--text); }
        .container { max-width: 1400px; margin: 0 auto; padding: 20px; }
        
        .header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 30px; padding: 20px; background: var(--surface);
            border-radius: 12px; box-shadow: var(--shadow);
        }
        .header h1 { color: var(--primary); font-size: 28px; }
        
        .btn {
            padding: 10px 20px; border: none; border-radius: 8px; cursor: pointer;
            font-weight: 600; text-decoration: none; display: inline-flex;
            align-items: center; gap: 8px;
        }
        .btn-primary { background: var(--primary); color: white; }
        .btn-success { background: var(--success); color: white; }
        .btn-danger { background: var(--danger); color: white; }
        .btn-outline { border: 2px solid var(--border); background: transparent; }
        .btn-sm { padding: 6px 12px; font-size: 12px; }
        
        .tabs {
            display: flex; gap: 10px; margin-bottom: 20px;
        }
        .tab {
            padding: 12px 24px; background: var(--surface); border: 2px solid var(--border);
            border-radius: 8px; cursor: pointer; font-weight: 600; color: var(--text-muted);
            transition: all 0.3s;
        }
        .tab.active {
            background: var(--primary); color: white; border-color: var(--primary);
        }
        
        .section {
            background: var(--surface); border-radius: 12px; padding: 24px;
            margin-bottom: 24px; box-shadow: var(--shadow);
        }
        .section-header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 20px; padding-bottom: 15px; border-bottom: 2px solid var(--border);
        }
        .section-title { font-size: 20px; color: var(--primary); }
        .badge {
            padding: 4px 12px; border-radius: 12px; font-size: 12px; font-weight: 600;
        }
        .badge-warning { background: #fff3cd; color: #856404; }
        .badge-success { background: #d4edda; color: #155724; }
        
        .agents-grid {
            display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 20px;
        }
        .agent-card {
            border: 1px solid var(--border); border-radius: 12px; padding: 20px;
            transition: all 0.3s;
        }
        .agent-card:hover { box-shadow: var(--shadow); border-color: var(--primary); }
        .agent-card.pending { border-left: 4px solid var(--warning); }
        .agent-card.active { border-left: 4px solid var(--success); }
        
        .agent-header {
            display: flex; align-items: center; gap: 15px; margin-bottom: 15px;
        }
        .agent-avatar {
            width: 60px; height: 60px; border-radius: 50%;
            background: var(--primary); color: white;
            display: flex; align-items: center; justify-content: center;
            font-size: 24px; font-weight: 700;
            overflow: hidden;
            object-fit: cover;
        }
        
        .agent-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .agent-info h4 { margin-bottom: 5px; }
        .agent-info p { font-size: 13px; color: var(--text-muted); }
        
        .agent-details {
            display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin: 15px 0;
        }
        .detail-item { font-size: 13px; }
        .detail-item label { color: var(--text-muted); font-size: 11px; display: block; }
        .detail-item span { font-weight: 500; }
        
        .agent-actions {
            display: flex; gap: 10px; margin-top: 15px;
        }
        
        .flash {
            padding: 12px 16px; border-radius: 8px; margin-bottom: 20px;
        }
        .flash.success { background: #d4edda; color: #155724; }
        .flash.error { background: #f8d7da; color: #721c24; }
        
        .stats-row {
            display: flex; gap: 20px; margin-bottom: 20px;
        }
        .stat-box {
            flex: 1; background: var(--bg); padding: 15px;
            border-radius: 8px; text-align: center;
        }
        .stat-box .value { font-size: 24px; font-weight: 700; color: var(--primary); }
        .stat-box .label { font-size: 12px; color: var(--text-muted); }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div>
                <h1><i class="fas fa-users"></i> Delivery Agents</h1>
                <p style="color: var(--text-muted);">Manage delivery partner registrations</p>
            </div>
            <div style="display: flex; gap: 10px; align-items: center;">
                <button class="icon-btn" id="theme-toggle" title="Toggle dark mode" aria-label="Toggle dark mode" style="background: transparent; border: 2px solid var(--border); border-radius: 8px; padding: 8px 12px; cursor: pointer; color: var(--text);">
                    <i class="fas fa-moon" id="theme-icon"></i>
                </button>
                <a href="/admin/delivery" class="btn btn-outline"><i class="fas fa-chart-line"></i> Dashboard</a>
                <button class="btn btn-primary" onclick="document.getElementById('addAgentModal').style.display='block'">
                    <i class="fas fa-user-plus"></i> Add Agent
                </button>
            </div>
        </div>

        <% if (locals.success && locals.success.length > 0) { %>
            <div class="flash success"><%= success %></div>
        <% } %>
        <% if (locals.error && locals.error.length > 0) { %>
            <div class="flash error"><%= error %></div>
        <% } %>

        <div class="stats-row">
            <div class="stat-box">
                <div class="value"><%= agents.length || 0 %></div>
                <div class="label">Total Agents</div>
            </div>
            <div class="stat-box">
                <div class="value" style="color: var(--warning);"><%= pendingAgents.length || 0 %></div>
                <div class="label">Pending Approval</div>
            </div>
            <div class="stat-box">
                <div class="value" style="color: var(--success);"><%= activeAgents.length || 0 %></div>
                <div class="label">Active Agents</div>
            </div>
        </div>

        <div class="tabs">
            <div class="tab active" onclick="showTab('all')">All Agents (<%= agents.length %>)</div>
            <div class="tab" onclick="showTab('pending')">Pending Approval (<%= pendingAgents.length %>)</div>
            <div class="tab" onclick="showTab('active')">Active Agents (<%= activeAgents.length %>)</div>
        </div>

        <div id="all" class="tab-content">
            <div class="section">
                <div class="section-header">
                    <h2 class="section-title">All Registration Requests</h2>
                </div>
                <div class="agents-grid">
                    <% if (agents && agents.length > 0) { %>
                        <% agents.forEach(agent => { %>
                            <div class="agent-card <%= agent.isActive ? 'active' : 'pending' %>">
                                <div class="agent-header">
                                    <div class="agent-avatar">
                                        <% if (agent.profileImage) { %>
                                            <img src="<%= agent.profileImage %>" alt="<%= agent.name %>">
                                        <% } else { %>
                                            <%= agent.name.charAt(0).toUpperCase() %>
                                        <% } %>
                                    </div>
                                    <div class="agent-info">
                                        <h4><%= agent.name %></h4>
                                        <p><%= agent.employeeId || 'Pending' %></p>
                                        <span class="badge <%= agent.isActive ? 'badge-success' : 'badge-warning' %>">
                                            <%= agent.isActive ? 'Active' : 'Pending Approval' %>
                                        </span>
                                    </div>
                                </div>
                                
                                <div class="agent-details">
                                    <div class="detail-item">
                                        <label>Email</label>
                                        <span><%= agent.email %></span>
                                    </div>
                                    <div class="detail-item">
                                        <label>Phone</label>
                                        <span><%= agent.phone %></span>
                                    </div>
                                    <div class="detail-item">
                                        <label>Vehicle</label>
                                        <span><%= agent.vehicleType %> - <%= agent.vehicleNumber %></span>
                                    </div>
                                    <div class="detail-item">
                                        <label>City</label>
                                        <span><%= agent.address?.city || 'N/A' %></span>
                                    </div>
                                </div>

                                <div class="agent-actions">
                                    <a href="/admin/delivery-agent/<%= agent._id %>" class="btn btn-outline btn-sm">
                                        <i class="fas fa-eye"></i> View
                                    </a>
                                    <% if (!agent.isActive) { %>
                                        <form action="/admin/delivery-agents/<%= agent._id %>/approve" method="POST" style="flex: 1;">
                                            <button type="submit" class="btn btn-success btn-sm" style="width: 100%;">
                                                <i class="fas fa-check"></i> Approve
                                            </button>
                                        </form>
                                        <form action="/admin/delivery-agents/<%= agent._id %>/reject" method="POST" style="flex: 1;" onsubmit="return confirm('Are you sure you want to reject this agent?');">
                                            <button type="submit" class="btn btn-danger btn-sm" style="width: 100%;">
                                                <i class="fas fa-times"></i> Reject
                                            </button>
                                        </form>
                                    <% } else { %>
                                        <button class="btn btn-outline btn-sm" style="flex: 1;" onclick="toggleAgentStatus('<%= agent._id %>')">
                                            <i class="fas fa-power-off"></i> <%= agent.isAvailable ? 'Deactivate' : 'Activate' %>
                                        </button>
                                    <% } %>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p style="color: var(--text-muted); text-align: center; padding: 40px; grid-column: 1/-1;">
                            <i class="fas fa-inbox" style="font-size: 48px; margin-bottom: 10px;"></i><br>
                            No agent registrations yet
                        </p>
                    <% } %>
                </div>
            </div>
        </div>

        <div id="pending" class="tab-content" style="display: none;">
            <div class="section">
                <div class="section-header">
                    <h2 class="section-title"><i class="fas fa-clock"></i> Pending Approvals</h2>
                </div>
                <div class="agents-grid">
                    <% if (pendingAgents && pendingAgents.length > 0) { %>
                        <% pendingAgents.forEach(agent => { %>
                            <div class="agent-card pending">
                                <div class="agent-header">
                                    <div class="agent-avatar">
                                        <% if (agent.profileImage) { %>
                                            <img src="<%= agent.profileImage %>" alt="<%= agent.name %>">
                                        <% } else { %>
                                            <%= agent.name.charAt(0).toUpperCase() %>
                                        <% } %>
                                    </div>
                                    <div class="agent-info">
                                        <h4><%= agent.name %></h4>
                                        <p>Registered: <%= new Date(agent.createdAt).toLocaleDateString() %></p>
                                        <span class="badge badge-warning">Pending Approval</span>
                                    </div>
                                </div>
                                
                                <div class="agent-details">
                                    <div class="detail-item">
                                        <label>Email</label>
                                        <span><%= agent.email %></span>
                                    </div>
                                    <div class="detail-item">
                                        <label>Phone</label>
                                        <span><%= agent.phone %></span>
                                    </div>
                                    <div class="detail-item">
                                        <label>Vehicle</label>
                                        <span><%= agent.vehicleType %> - <%= agent.vehicleNumber %></span>
                                    </div>
                                    <div class="detail-item">
                                        <label>Location</label>
                                        <span><%= agent.address?.city %>, <%= agent.address?.pincode %></span>
                                    </div>
                                </div>

                                <div class="agent-actions">
                                    <form action="/admin/delivery-agents/<%= agent._id %>/approve" method="POST" style="flex: 1;">
                                        <button type="submit" class="btn btn-success btn-sm" style="width: 100%;">
                                            <i class="fas fa-check-circle"></i> Approve & Activate
                                        </button>
                                    </form>
                                    <form action="/admin/delivery-agents/<%= agent._id %>/reject" method="POST" style="flex: 1;" onsubmit="return confirm('Are you sure you want to reject this agent?');">
                                        <button type="submit" class="btn btn-danger btn-sm" style="width: 100%;">
                                            <i class="fas fa-times-circle"></i> Reject
                                        </button>
                                    </form>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p style="color: var(--text-muted); text-align: center; padding: 40px; grid-column: 1/-1;">
                            <i class="fas fa-check-circle" style="font-size: 48px; color: var(--success); margin-bottom: 10px;"></i><br>
                            No pending approvals! All agents are active.
                        </p>
                    <% } %>
                </div>
            </div>
        </div>

        <div id="active" class="tab-content" style="display: none;">
            <div class="section">
                <div class="section-header">
                    <h2 class="section-title"><i class="fas fa-check-circle"></i> Active Agents</h2>
                </div>
                <div class="agents-grid">
                    <% if (activeAgents && activeAgents.length > 0) { %>
                        <% activeAgents.forEach(agent => { %>
                            <div class="agent-card active">
                                <div class="agent-header">
                                    <div class="agent-avatar">
                                        <% if (agent.profileImage) { %>
                                            <img src="<%= agent.profileImage %>" alt="<%= agent.name %>">
                                        <% } else { %>
                                            <%= agent.name.charAt(0).toUpperCase() %>
                                        <% } %>
                                    </div>
                                    <div class="agent-info">
                                        <h4><%= agent.name %></h4>
                                        <p><%= agent.employeeId %></p>
                                        <span class="badge badge-success">Active</span>
                                    </div>
                                </div>
                                
                                <div class="agent-details">
                                    <div class="detail-item">
                                        <label>Email</label>
                                        <span><%= agent.email %></span>
                                    </div>
                                    <div class="detail-item">
                                        <label>Phone</label>
                                        <span><%= agent.phone %></span>
                                    </div>
                                    <div class="detail-item">
                                        <label>Deliveries</label>
                                        <span><%= agent.stats?.totalDeliveries || 0 %></span>
                                    </div>
                                    <div class="detail-item">
                                        <label>Rating</label>
                                        <span>⭐ <%= agent.stats?.averageRating || '0' %></span>
                                    </div>
                                </div>

                                <div class="agent-actions">
                                    <a href="/admin/delivery-agent/<%= agent._id %>" class="btn btn-outline btn-sm">
                                        <i class="fas fa-user"></i> Profile
                                    </a>
                                    <a href="/admin/deliveries?agent=<%= agent._id %>" class="btn btn-outline btn-sm">
                                        <i class="fas fa-box"></i> Deliveries
                                    </a>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p style="color: var(--text-muted); text-align: center; padding: 40px; grid-column: 1/-1;">
                            <i class="fas fa-inbox" style="font-size: 48px; margin-bottom: 10px;"></i><br>
                            No active agents yet
                        </p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Add Agent Modal -->
    <div id="addAgentModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
        <div style="background: var(--surface); padding: 30px; border-radius: 12px; max-width: 600px; width: 90%; max-height: 90vh; overflow-y: auto;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h2 style="color: var(--primary); font-size: 20px;"><i class="fas fa-user-plus"></i> Add Delivery Agent</h2>
                <button onclick="document.getElementById('addAgentModal').style.display='none'" style="background: none; border: none; font-size: 24px; cursor: pointer; color: var(--text-muted);">&times;</button>
            </div>
            <form action="/admin/delivery-agents" method="POST" enctype="multipart/form-data">
                <div class="form-group" style="margin-bottom: 15px;">
                    <label style="display: block; margin-bottom: 5px; font-weight: 500;">Full Name</label>
                    <input type="text" name="name" required style="width: 100%; padding: 10px; border: 2px solid var(--border); border-radius: 8px;">
                </div>
                <div class="form-group" style="margin-bottom: 15px;">
                    <label style="display: block; margin-bottom: 5px; font-weight: 500;">Email</label>
                    <input type="email" name="email" required style="width: 100%; padding: 10px; border: 2px solid var(--border); border-radius: 8px;">
                </div>
                <div class="form-group" style="margin-bottom: 15px;">
                    <label style="display: block; margin-bottom: 5px; font-weight: 500;">Phone</label>
                    <input type="tel" name="phone" required pattern="[6-9][0-9]{9}" style="width: 100%; padding: 10px; border: 2px solid var(--border); border-radius: 8px;">
                </div>
                <div class="form-group" style="margin-bottom: 15px;">
                    <label style="display: block; margin-bottom: 5px; font-weight: 500;">Password</label>
                    <input type="password" name="password" required minlength="6" style="width: 100%; padding: 10px; border: 2px solid var(--border); border-radius: 8px;">
                </div>
                <div class="form-group" style="margin-bottom: 15px;">
                    <label style="display: block; margin-bottom: 5px; font-weight: 500;">Vehicle Type</label>
                    <select name="vehicleType" required style="width: 100%; padding: 10px; border: 2px solid var(--border); border-radius: 8px;">
                        <option value="bike">Motorcycle</option>
                        <option value="scooter">Scooter</option>
                        <option value="cycle">Bicycle</option>
                        <option value="car">Car</option>
                    </select>
                </div>
                <div class="form-group" style="margin-bottom: 15px;">
                    <label style="display: block; margin-bottom: 5px; font-weight: 500;">Vehicle Number</label>
                    <input type="text" name="vehicleNumber" required style="width: 100%; padding: 10px; border: 2px solid var(--border); border-radius: 8px; text-transform: uppercase;">
                </div>
                <div class="form-group" style="margin-bottom: 15px;">
                    <label style="display: block; margin-bottom: 5px; font-weight: 500;">City</label>
                    <input type="text" name="address.city" required style="width: 100%; padding: 10px; border: 2px solid var(--border); border-radius: 8px;">
                </div>
                <div class="form-group" style="margin-bottom: 15px;">
                    <label style="display: block; margin-bottom: 5px; font-weight: 500;">Pincode</label>
                    <input type="text" name="address.pincode" required pattern="[0-9]{6}" style="width: 100%; padding: 10px; border: 2px solid var(--border); border-radius: 8px;">
                </div>

                <!-- ID Documents Section -->
                <div style="margin-top: 20px; padding-top: 20px; border-top: 2px solid var(--border);">
                    <h3 style="color: var(--primary); font-size: 16px; margin-bottom: 15px;"><i class="fas fa-id-card"></i> ID Documents (Optional)</h3>

                    <div class="form-group" style="margin-bottom: 15px;">
                        <label style="display: block; margin-bottom: 5px; font-weight: 500; font-size: 13px;">Aadhar Number</label>
                        <input type="text" name="aadharNumber" placeholder="XXXX-XXXX-XXXX" style="width: 100%; padding: 10px; border: 2px solid var(--border); border-radius: 8px;">
                    </div>
                    <div class="form-group" style="margin-bottom: 15px;">
                        <label style="display: block; margin-bottom: 5px; font-weight: 500; font-size: 13px;">PAN Number</label>
                        <input type="text" name="panNumber" placeholder="ABCDE1234F" style="width: 100%; padding: 10px; border: 2px solid var(--border); border-radius: 8px; text-transform: uppercase;">
                    </div>
                    <div class="form-group" style="margin-bottom: 15px;">
                        <label style="display: block; margin-bottom: 5px; font-weight: 500; font-size: 13px;">Driving License Number</label>
                        <input type="text" name="drivingLicense" style="width: 100%; padding: 10px; border: 2px solid var(--border); border-radius: 8px; text-transform: uppercase;">
                    </div>

                    <!-- Document Upload Fields -->
                    <div style="margin-top: 15px; padding-top: 15px; border-top: 1px dashed var(--border);">
                        <p style="font-size: 12px; color: var(--text-muted); margin-bottom: 10px;">
                            <i class="fas fa-upload"></i> Upload Document Images (optional)
                        </p>
                        
                        <div class="form-group" style="margin-bottom: 10px;">
                            <label style="display: block; margin-bottom: 5px; font-weight: 500; font-size: 12px;">Aadhar Card Image</label>
                            <input type="file" name="aadharImage" accept="image/*,.pdf" style="width: 100%; padding: 8px; border: 2px dashed var(--border); border-radius: 8px;">
                        </div>
                        
                        <div class="form-group" style="margin-bottom: 10px;">
                            <label style="display: block; margin-bottom: 5px; font-weight: 500; font-size: 12px;">PAN Card Image</label>
                            <input type="file" name="panImage" accept="image/*,.pdf" style="width: 100%; padding: 8px; border: 2px dashed var(--border); border-radius: 8px;">
                        </div>
                        
                        <div class="form-group" style="margin-bottom: 10px;">
                            <label style="display: block; margin-bottom: 5px; font-weight: 500; font-size: 12px;">Driving License Image</label>
                            <input type="file" name="drivingLicense" accept="image/*,.pdf" style="width: 100%; padding: 8px; border: 2px dashed var(--border); border-radius: 8px;">
                        </div>
                        
                        <div class="form-group" style="margin-bottom: 10px;">
                            <label style="display: block; margin-bottom: 5px; font-weight: 500; font-size: 12px;">Vehicle RC Image</label>
                            <input type="file" name="vehicleRC" accept="image/*,.pdf" style="width: 100%; padding: 8px; border: 2px dashed var(--border); border-radius: 8px;">
                        </div>
                        
                        <div class="form-group" style="margin-bottom: 10px;">
                            <label style="display: block; margin-bottom: 5px; font-weight: 500; font-size: 12px;">Vehicle Insurance Image</label>
                            <input type="file" name="vehicleInsurance" accept="image/*,.pdf" style="width: 100%; padding: 8px; border: 2px dashed var(--border); border-radius: 8px;">
                        </div>
                    </div>
                </div>

                <div style="display: flex; gap: 10px; margin-top: 20px;">
                    <button type="submit" class="btn btn-primary" style="flex: 1;"><i class="fas fa-plus"></i> Create Agent</button>
                    <button type="button" onclick="document.getElementById('addAgentModal').style.display='none'" class="btn btn-outline" style="flex: 1;"><i class="fas fa-times"></i> Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function showTab(tabName) {
            // Hide all tabs
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.style.display = 'none';
            });
            
            // Remove active from all tabs
            document.querySelectorAll('.tab').forEach(tab => {
                tab.classList.remove('active');
            });
            
            // Show selected tab
            document.getElementById(tabName).style.display = 'block';
            
            // Add active to clicked tab
            event.target.classList.add('active');
        }
        
        function toggleAgentStatus(agentId) {
            fetch(`/admin/delivery-agents/${agentId}/toggle`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                }
            });
        }
    </script>

