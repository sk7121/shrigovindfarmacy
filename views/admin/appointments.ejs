<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Appointments — Admin — Shri Govind Pharmacy</title>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet">

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

  <style>
    :root {
      --primary: #1c8125;
      --primary-dark: #145a1a;
      --secondary: #e67e22;
      --bg: #f8f9fa;
      --surface: #ffffff;
      --text: #1a1a1a;
      --text-muted: #6c757d;
      --border: #e9ecef;
      --success: #28a745;
      --danger: #dc3545;
      --warning: #ffc107;
      --info: #17a2b8;
      --shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      --shadow-lg: 0 4px 16px rgba(0, 0, 0, 0.12);
    }

    [data-theme="dark"] {
      --bg: #121212;
      --surface: #1e1e1e;
      --text: #e0e0e0;
      --text-muted: #a0a0a0;
      --border: #2d2d2d;
      --shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
      --shadow-lg: 0 4px 16px rgba(0, 0, 0, 0.4);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    .admin-header {
      background: var(--surface);
      padding: 20px 40px;
      box-shadow: var(--shadow);
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .admin-header h1 {
      font-size: 1.5rem;
      color: var(--primary);
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .nav-links {
      display: flex;
      gap: 15px;
    }

    .nav-links a {
      padding: 10px 20px;
      border-radius: 8px;
      text-decoration: none;
      color: var(--text);
      font-weight: 600;
      transition: all 0.3s;
      background: var(--bg);
    }

    .nav-links a:hover,
    .nav-links a.active {
      background: var(--primary);
      color: white;
    }

    .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 40px 20px;
    }

    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
    }

    .page-title {
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--text);
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      margin-bottom: 30px;
    }

    .stat-card {
      background: var(--surface);
      padding: 24px;
      border-radius: 12px;
      box-shadow: var(--shadow);
      text-align: center;
    }

    .stat-card i {
      font-size: 2rem;
      margin-bottom: 12px;
    }

    .stat-card.pending i {
      color: var(--warning);
    }

    .stat-card.confirmed i {
      color: var(--success);
    }

    .stat-card.completed i {
      color: var(--info);
    }

    .stat-card.cancelled i {
      color: var(--danger);
    }

    .stat-number {
      font-size: 2rem;
      font-weight: 700;
      color: var(--text);
    }

    .stat-label {
      font-size: 0.85rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .card {
      background: var(--surface);
      border-radius: 12px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .table-responsive {
      overflow-x: auto;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    thead {
      background: var(--bg);
    }

    th,
    td {
      padding: 16px;
      text-align: left;
      border-bottom: 1px solid var(--border);
    }

    th {
      font-weight: 600;
      color: var(--text-muted);
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    td {
      font-size: 0.9rem;
    }

    tr:hover {
      background: var(--bg);
    }

    .status-badge {
      padding: 4px 12px;
      border-radius: 50px;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
    }

    .status-badge.pending {
      background: rgba(255, 193, 7, 0.1);
      color: var(--warning);
    }

    .status-badge.confirmed {
      background: rgba(40, 167, 69, 0.1);
      color: var(--success);
    }

    .status-badge.completed {
      background: rgba(23, 162, 184, 0.1);
      color: var(--info);
    }

    .status-badge.cancelled {
      background: rgba(220, 53, 69, 0.1);
      color: var(--danger);
    }

    .type-badge {
      padding: 4px 10px;
      border-radius: 6px;
      font-size: 0.75rem;
      font-weight: 600;
      background: var(--bg);
      color: var(--text);
    }

    .actions {
      display: flex;
      gap: 8px;
    }

    .btn {
      padding: 8px 16px;
      border-radius: 6px;
      border: none;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: all 0.3s;
      font-size: 0.85rem;
    }

    .btn-success {
      background: var(--success);
      color: white;
    }

    .btn-success:hover {
      opacity: 0.9;
    }

    .btn-danger {
      background: var(--danger);
      color: white;
    }

    .btn-danger:hover {
      opacity: 0.9;
    }

    .btn-sm {
      padding: 6px 12px;
      font-size: 0.8rem;
    }

    .theme-toggle {
      background: none;
      border: none;
      font-size: 1.2rem;
      color: var(--text);
      cursor: pointer;
      padding: 8px;
      border-radius: 8px;
      transition: all 0.3s;
    }

    .theme-toggle:hover {
      background: var(--bg);
    }

    .empty-state {
      text-align: center;
      padding: 60px 20px;
    }

    .empty-state i {
      font-size: 4rem;
      color: var(--text-muted);
      margin-bottom: 20px;
    }

    .empty-state h3 {
      color: var(--text);
      margin-bottom: 10px;
    }

    .empty-state p {
      color: var(--text-muted);
    }

    .patient-info {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .patient-name {
      font-weight: 600;
      color: var(--text);
    }

    .patient-email {
      font-size: 0.8rem;
      color: var(--text-muted);
    }

    .doctor-info {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .doctor-name {
      font-weight: 600;
      color: var(--text);
    }

    .date-time {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .date {
      font-weight: 600;
    }

    .time {
      font-size: 0.85rem;
      color: var(--text-muted);
    }
  </style>
  <script src="/js/theme.js"></script>

</head>

<body>
  <style>
    .flash {
      padding: 12px 14px;
      border-radius: 14px;
      margin: 18px auto;
      max-width: 980px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 10px;
      border: 1px solid rgba(0,0,0,0.08);
      background: rgba(255, 255, 255, 0.9);
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    }
    .flash.success {
      border-color: rgba(74, 222, 128, 0.4);
      color: #166534;
      background: rgba(74, 222, 128, 0.15);
    }
    .flash.error {
      border-color: rgba(255, 107, 107, 0.4);
      color: #b91c1c;
      background: rgba(254, 202, 202, 0.25);
    }
  </style>
  <% if (success && success.length) { %>
    <div class="flash success"><%= success[0] %></div>
  <% } %>
  <% if (error && error.length) { %>
    <div class="flash error"><%= error[0] %></div>
  <% } %>

  <header class="admin-header">
    <h1><i class="fa-solid fa-calendar-check"></i> Manage Appointments</h1>
    <div style="display: flex; gap: 15px; align-items: center;">
      <nav class="nav-links">
        <a href="/admin/home"><i class="fa-solid fa-chart-line"></i> Dashboard</a>
        <a href="/admin/doctors"><i class="fa-solid fa-user-doctor"></i> Doctors</a>
        <a href="/admin/appointments" class="active"><i class="fa-solid fa-calendar-check"></i> Appointments</a>
        <a href="/home"><i class="fa-solid fa-house"></i> Back to Site</a>
      </nav>
      <button class="theme-toggle" onclick="toggleTheme()">
        <i class="fa-solid fa-moon" id="theme-icon"></i>
      </button>
    </div>
  </header>

  <div class="container">
    <div class="page-header">
      <h2 class="page-title">All Appointments</h2>
    </div>

    <!-- Stats -->
    <% 
      const stats = {
        pending: appointments.filter(a => a.status === 'Pending').length,
        confirmed: appointments.filter(a => a.status === 'Confirmed').length,
        completed: appointments.filter(a => a.status === 'Completed').length,
        cancelled: appointments.filter(a => a.status === 'Cancelled').length
      };
    %>
    <div class="stats-grid">
      <div class="stat-card pending">
        <i class="fa-solid fa-clock"></i>
        <div class="stat-number"><%= stats.pending %></div>
        <div class="stat-label">Pending</div>
      </div>
      <div class="stat-card confirmed">
        <i class="fa-solid fa-check-circle"></i>
        <div class="stat-number"><%= stats.confirmed %></div>
        <div class="stat-label">Confirmed</div>
      </div>
      <div class="stat-card completed">
        <i class="fa-solid fa-clipboard-check"></i>
        <div class="stat-number"><%= stats.completed %></div>
        <div class="stat-label">Completed</div>
      </div>
      <div class="stat-card cancelled">
        <i class="fa-solid fa-times-circle"></i>
        <div class="stat-number"><%= stats.cancelled %></div>
        <div class="stat-label">Cancelled</div>
      </div>
    </div>

    <% if (appointments && appointments.length > 0) { %>
    <div class="card">
      <div class="table-responsive">
        <table>
          <thead>
            <tr>
              <th>Patient</th>
              <th>Doctor</th>
              <th>Type</th>
              <th>Date & Time</th>
              <th>Reason</th>
              <th>Fee</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% appointments.forEach(appointment => { %>
            <tr>
              <td>
                <div class="patient-info">
                  <span class="patient-name"><%= appointment.patientDetails?.name || appointment.patient?.name || 'N/A' %></span>
                  <span class="patient-email"><%= appointment.patientDetails?.email || appointment.patient?.email || 'N/A' %></span>
                </div>
              </td>
              <td>
                <div class="doctor-info">
                  <span class="doctor-name">Dr. <%= appointment.doctor?.name || 'N/A' %></span>
                  <span style="font-size: 0.8rem; color: var(--text-muted);"><%= appointment.appointmentType %></span>
                </div>
              </td>
              <td>
                <span class="type-badge"><%= appointment.appointmentType %></span>
              </td>
              <td>
                <div class="date-time">
                  <span class="date"><%= new Date(appointment.appointmentDate).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
                  <span class="time"><%= appointment.appointmentTime %></span>
                </div>
              </td>
              <td style="max-width: 200px;">
                <span style="color: var(--text-muted); font-size: 0.85rem;"><%= appointment.reason %></span>
              </td>
              <td>
                <span style="font-weight: 600;">₹<%= appointment.consultationFee || 0 %></span>
                <% if (appointment.paymentStatus === 'Paid') { %>
                <span style="color: var(--success); font-size: 0.75rem; display: block;">
                  <i class="fa-solid fa-check"></i> Paid
                </span>
                <% } else { %>
                <span style="color: var(--warning); font-size: 0.75rem; display: block;">
                  <i class="fa-solid fa-clock"></i> Unpaid
                </span>
                <% } %>
              </td>
              <td>
                <span class="status-badge <%= appointment.status.toLowerCase() %>"><%= appointment.status %></span>
              </td>
              <td>
                <div class="actions">
                  <% if (appointment.status === 'Pending') { %>
                  <form action="/admin/appointment/<%= appointment._id %>/status" method="POST" style="display: inline;">
                    <input type="hidden" name="status" value="Confirmed">
                    <button type="submit" class="btn btn-success btn-sm" title="Confirm">
                      <i class="fa-solid fa-check"></i>
                    </button>
                  </form>
                  <% } %>
                  <% if (appointment.status !== 'Completed' && appointment.status !== 'Cancelled') { %>
                  <form action="/admin/appointment/<%= appointment._id %>/status" method="POST" style="display: inline;">
                    <input type="hidden" name="status" value="Completed">
                    <button type="submit" class="btn btn-primary btn-sm" title="Mark Complete" style="background: var(--info);">
                      <i class="fa-solid fa-clipboard-check"></i>
                    </button>
                  </form>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
    <% } else { %>
    <div class="card empty-state">
      <i class="fa-solid fa-calendar-times"></i>
      <h3>No Appointments Yet</h3>
      <p>Appointments will appear here once patients start booking</p>
    </div>
    <% } %>
  </div>
</body>

</html>
