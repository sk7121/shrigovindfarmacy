<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Terms & Conditions – Shri Govind Pharmacy</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer">
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/theme.js"></script>

  <style>
    .policy-container {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }
    .policy-header {
      text-align: center;
      margin-bottom: 3rem;
      padding-bottom: 2rem;
      border-bottom: 2px solid var(--primary-color, #1c8125);
    }
    .policy-header h1 {
      font-size: 2.5rem;
      color: var(--text-color, #1a1a1a);
      margin-bottom: 0.5rem;
    }
    .policy-header .last-updated {
      color: var(--muted-color, #666);
      font-size: 0.95rem;
    }
    .policy-section {
      margin-bottom: 2.5rem;
    }
    .policy-section h2 {
      font-size: 1.5rem;
      color: var(--primary-color, #1c8125);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .policy-section h2 i {
      font-size: 1.3rem;
    }
    .policy-section h3 {
      font-size: 1.1rem;
      color: var(--text-color, #333);
      margin-top: 1.25rem;
      margin-bottom: 0.75rem;
    }
    .policy-section p, .policy-section li {
      line-height: 1.8;
      color: var(--text-color, #333);
      font-size: 1rem;
    }
    .policy-section ul {
      margin-left: 1.5rem;
      margin-top: 0.75rem;
    }
    .policy-section li {
      margin-bottom: 0.5rem;
    }
    .policy-highlight {
      background: rgba(28, 129, 37, 0.08);
      border-left: 4px solid var(--primary-color, #1c8125);
      padding: 1.25rem;
      border-radius: 0 8px 8px 0;
      margin: 1.5rem 0;
    }
    .policy-warning {
      background: rgba(255, 152, 0, 0.1);
      border-left: 4px solid #ff9800;
      padding: 1.25rem;
      border-radius: 0 8px 8px 0;
      margin: 1.5rem 0;
    }
    .policy-table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.5rem 0;
    }
    .policy-table th, .policy-table td {
      padding: 1rem;
      border: 1px solid #ddd;
      text-align: left;
    }
    .policy-table th {
      background: rgba(28, 129, 37, 0.1);
      font-weight: 600;
    }
    .contact-box {
      background: linear-gradient(135deg, var(--primary-color, #1c8125), #2d9d3a);
      color: white;
      padding: 2rem;
      border-radius: 12px;
      text-align: center;
      margin-top: 3rem;
    }
    .contact-box h3 {
      margin-bottom: 1rem;
      font-size: 1.4rem;
    }
    .contact-box a {
      color: white;
      text-decoration: underline;
    }
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--primary-color, #1c8125);
      text-decoration: none;
      font-weight: 500;
      margin-bottom: 2rem;
      transition: gap 0.2s;
    }
    .back-link:hover {
      gap: 0.75rem;
    }
    [data-theme="dark"] .policy-highlight {
      background: rgba(28, 129, 37, 0.15);
    }
    [data-theme="dark"] .policy-warning {
      background: rgba(255, 152, 0, 0.15);
    }
    [data-theme="dark"] .policy-table th {
      background: rgba(28, 129, 37, 0.2);
    }
    [data-theme="dark"] .policy-table td,
    [data-theme="dark"] .policy-table th {
      border-color: #444;
    }
  </style>
</head>

<body>
  <style>
    .flash {
      padding: 12px 14px;
      border-radius: 14px;
      margin: 18px auto;
      max-width: 980px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 10px;
      border: 1px solid rgba(0,0,0,0.08);
      background: rgba(255, 255, 255, 0.9);
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    }
    .flash.success {
      border-color: rgba(74, 222, 128, 0.4);
      color: #166534;
      background: rgba(74, 222, 128, 0.15);
    }
    .flash.error {
      border-color: rgba(255, 107, 107, 0.4);
      color: #b91c1c;
      background: rgba(254, 202, 202, 0.25);
    }
  </style>
  <% if (success && success.length) { %>
    <div class="flash success"><%= success[0] %></div>
  <% } %>
  <% if (error && error.length) { %>
    <div class="flash error"><%= error[0] %></div>
  <% } %>

