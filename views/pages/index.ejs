  <style>
    /* Toast Notifications */
    .toast-zone {
      position: fixed;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 10000;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      pointer-events: none;
    }

    .toast {
      background: white;
      padding: 1rem 1.25rem;
      border-radius: 10px;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
      display: flex;
      align-items: center;
      gap: 0.75rem;
      min-width: 320px;
      max-width: 450px;
      transform: translateY(20px);
      opacity: 0;
      transition: all 0.3s ease;
      pointer-events: auto;
    }

    .toast.show {
      transform: translateY(0);
      opacity: 1;
    }

    .toast.success {
      border-left: 4px solid #28a745;
    }

    .toast.error {
      border-left: 4px solid #dc3545;
    }

    .toast.info {
      border-left: 4px solid #17a2b8;
    }

    .toast i {
      font-size: 1.25rem;
    }

    .toast.success i {
      color: #28a745;
    }

    .toast.error i {
      color: #dc3545;
    }

    .toast.info i {
      color: #17a2b8;
    }

    .toast-action {
      margin-left: auto;
      padding: 0.5rem 1rem;
      background: #28a745;
      color: white;
      text-decoration: none;
      border-radius: 6px;
      font-weight: 600;
      font-size: 0.85rem;
      white-space: nowrap;
      transition: background 0.2s;
    }

    .toast-action:hover {
      background: #218838;
    }

    @media (max-width: 768px) {
      .toast-zone {
        bottom: 1rem;
        left: 50%;
        transform: translateX(-50%);
        width: calc(100% - 2rem);
        max-width: 400px;
      }

      .toast {
        min-width: auto;
        width: 100%;
        padding: 0.875rem 1rem;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.15);
      }

      .toast-action {
        font-size: 0.75rem;
        padding: 0.4rem 0.75rem;
      }

      .toast i {
        font-size: 1.1rem;
      }
    }

    @media (max-width: 480px) {
      .toast-zone {
        bottom: 0.75rem;
        left: 50%;
        transform: translateX(-50%);
        width: calc(100% - 1.5rem);
      }

      .toast {
        padding: 0.75rem 0.875rem;
        border-radius: 8px;
      }

      .toast-action {
        font-size: 0.7rem;
        padding: 0.35rem 0.6rem;
      }
    }

    /* Product Filter Section - Responsive */
    .search-filter-section {
      background: var(--surface);
      padding: 20px;
      border-radius: 12px;
      margin-bottom: 30px;
      box-shadow: var(--shadow);
      max-width: 1200px;
      margin-left: auto;
      margin-right: auto;
      text-align: center;
    }

    .product-filter-form {
      display: inline-grid;
      grid-template-columns: repeat(5, auto);
      gap: 15px;
      align-items: end;
      justify-content: center;
      max-width: 100%;
    }

    .filter-field {
      min-width: 150px;
    }

    .filter-field:first-child {
      min-width: 250px;
    }

    .filter-actions {
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .filter-field label {
      display: block;
      font-weight: 600;
      margin-bottom: 5px;
      color: var(--text);
    }

    .filter-field input,
    .filter-field select {
      width: 100%;
      padding: 10px;
      border: 2px solid var(--border);
      border-radius: 8px;
      font-size: 14px;
    }

    .filter-actions {
      display: flex;
      gap: 10px;
      align-items: center;
    }

    /* Tablet - 3 columns */
    @media (max-width: 1024px) {
      .product-filter-form {
        grid-template-columns: repeat(3, auto);
        gap: 12px;
      }

      .filter-field:first-child {
        grid-column: span 3;
        min-width: 100%;
      }

      .filter-field:nth-child(2),
      .filter-field:nth-child(3),
      .filter-field:nth-child(4) {
        min-width: 120px;
      }

      .filter-actions {
        grid-column: span 3;
        justify-content: center;
      }
    }

    /* Mobile - 2 columns */
    @media (max-width: 768px) {
      .search-filter-section {
        padding: 15px;
      }

      .product-filter-form {
        grid-template-columns: repeat(2, auto);
        gap: 10px;
      }

      .filter-field:first-child {
        grid-column: span 2;
        min-width: 100%;
      }

      .filter-field:nth-child(2),
      .filter-field:nth-child(3),
      .filter-field:nth-child(4) {
        min-width: 120px;
      }

      .filter-actions {
        grid-column: span 2;
        justify-content: center;
      }

      .filter-actions .btn {
        flex: 1;
        justify-content: center;
      }
    }

    /* Very small screens - 1 column */
    @media (max-width: 480px) {
      .search-filter-section {
        padding: 12px;
      }

      .product-filter-form {
        grid-template-columns: 1fr;
        gap: 10px;
      }

      .filter-field,
      .filter-field:first-child,
      .filter-field:nth-child(2),
      .filter-field:nth-child(3),
      .filter-field:nth-child(4),
      .filter-actions {
        grid-column: span 1;
      }

      .filter-field {
        min-width: 100%;
      }

      .filter-actions {
        justify-content: center;
      }

      .filter-actions .btn {
        flex: 1;
        justify-content: center;
      }
    }
  </style>
</head>

