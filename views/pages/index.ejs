            }

            // Add to Cart Functionality
            document.addEventListener('DOMContentLoaded', function () {
              const addToCartButtons = document.querySelectorAll('.add-to-cart-btn');
              const processingButtons = new Set();

              addToCartButtons.forEach(button => {
                button.addEventListener('click', async function (e) {
                  e.preventDefault();

                  // Prevent double-click
                  if (processingButtons.has(this)) {
                    return;
                  }

                  const productId = this.getAttribute('data-product-id');
                  const productName = this.getAttribute('data-name');
                  const productPrice = this.getAttribute('data-price');

                  if (!productId) return;

                  // Check if user is logged in (if button is disabled for non-logged users)
                  if (this.disabled) {
                    showToast('Please login to add items to cart', 'error');
                    return;
                  }

                  // Mark button as processing
                  processingButtons.add(this);
                  const originalText = this.innerHTML;
                  this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Adding...';
                  this.disabled = true;

                  try {
                    const response = await fetch('/user/add-to-cart/' + productId, {
                      method: 'POST',
                      headers: {
                        'Content-Type': 'application/json'
                      },
                      body: JSON.stringify({
                        quantity: 1
                      })
                    });

                    if (response.ok) {
                      const result = await response.json();
                      showToast('Added to cart successfully! 🛒', 'success', 'Go to Cart', '/user/cart');
                      // Update badges dynamically
                      updateBadges(result.cartCount, result.cartItemCount, result.wishlistCount);
                    } else {
                      // Try to parse as JSON first
                      try {
                        const result = await response.json();
                        if (result.redirect) {
                          // Server returned a redirect (e.g., email verification needed)
                          if (result.redirect.includes('/verify-otp')) {
                            showToast('Please verify your email to continue', 'info');
                            setTimeout(() => {
                              window.location.href = result.redirect;
                            }, 1000);
                          } else {
                            showToast(result.message || 'Authentication required', 'error');
                            setTimeout(() => {
                              window.location.href = result.redirect;
                            }, 1000);
                          }
                          return;
                        } else {
                          showToast(result.message || 'Error adding to cart', 'error');
                        }
                      } catch (jsonError) {
                        // Not JSON, check for redirects
                        if (response.redirected || response.url.includes('/login') || response.status === 302 || response.status === 401) {
                          showToast('First login, then add to cart', 'error');
                          setTimeout(() => {
                            window.location.href = '/login';
                          }, 1000);
                        } else {
                          showToast('Error adding to cart', 'error');
                        }
                      }
                    }
                  } catch (err) {
                    console.log(err);
                    showToast('Error adding to cart', 'error');
                  } finally {
                    // Re-enable button
                    processingButtons.delete(this);
                    this.innerHTML = originalText;
                    this.disabled = false;
                  }
                });
              });

              // Update badges function using API data
              function updateBadges(cartCount, cartItemCount, wishlistCount) {
                const cartCountEl = document.getElementById('cart-count');
                const wishCountEl = document.getElementById('wish-count');

                if (cartCountEl) {
                  cartCountEl.textContent = cartCount || 0;
                }
                if (wishCountEl) {
                  wishCountEl.textContent = wishlistCount || 0;
                }
              }

              // Fetch and update counts on page load
              async function fetchCounts() {
                try {
                  const response = await fetch('/api/user/counts');
                  if (response.ok) {
                    const result = await response.json();
                    if (result.success) {
                      updateBadges(result.cartCount, result.cartItemCount, result.wishlistCount);
                    }
                  }
                } catch (err) {
                  console.log('Error fetching counts:', err);
                }
              }

              // Fetch counts on page load
              fetchCounts();

              // Check wishlist status and update buttons
              async function checkWishlistStatus() {
                try {
                  const wishlistButtons = document.querySelectorAll('.wish-it');
                  for (const btn of wishlistButtons) {
                    const productId = btn.closest('.product-card')?.dataset.productId;
                    if (!productId) continue;

                    const response = await fetch('/wishlist/check/' + productId);
                    const result = await response.json();

                    if (result.success === false) {
                      // API returned an error, skip this item
                      console.log('Wishlist check failed for product', productId, result.message);
                      continue;
                    }

                    if (result.inWishlist) {
                      const icon = btn.querySelector('i');
                      if (icon) {
                        icon.classList.remove('far');
                        icon.classList.add('fas');
                        btn.style.color = '#e91e63';
                      }
                    }
                  }
                } catch (err) {
                  console.log('Error checking wishlist status:', err);
                }
              }

              // Add event listeners to wishlist buttons
              document.querySelectorAll('.wish-it').forEach(btn => {
                btn.addEventListener('click', async function (e) {
                  e.preventDefault();
                  e.stopPropagation();

                  const productId = this.closest('.product-card')?.dataset.productId;
                  if (!productId) return;

                  const icon = this.querySelector('i');

                  // First check actual wishlist status from server
                  try {
                    const checkResponse = await fetch('/wishlist/check/' + productId);
                    const checkResult = await checkResponse.json();
                    const isInWishlist = checkResult.inWishlist;

                    if (isInWishlist) {
                      // Remove from wishlist
                      const response = await fetch('/wishlist/remove/' + productId, {
                        method: 'POST',
                        headers: {
                          'Content-Type': 'application/json'
                        }
                      });

                      const result = await response.json();

                      if (result.success) {
                        showToast('Removed from wishlist', 'info');
                        // Update badges dynamically
                        updateBadges(result.cartCount || 0, result.cartItemCount || 0, result.wishlistCount);
                        // Update button icon
                        icon.classList.remove('fas');
                        icon.classList.add('far');
                        this.style.color = '';
                      } else if (result.redirect) {
                        // Server returned a redirect (e.g., email verification needed)
                        if (result.redirect.includes('/verify-otp')) {
                          showToast('Please verify your email to use wishlist', 'info');
                          setTimeout(() => {
                            window.location.href = result.redirect;
                          }, 1000);
                        } else {
                          showToast(result.message || 'Authentication required', 'error');
                          setTimeout(() => {
                            window.location.href = result.redirect;
                          }, 1000);
                        }
                      } else {
                        showToast(result.message || 'Error removing from wishlist', 'error');
                      }
                    } else {
                      // Add to wishlist
                      const response = await fetch('/wishlist/add/' + productId, {
                        method: 'POST',
                        headers: {
                          'Content-Type': 'application/json'
                        }
                      });

                      const result = await response.json();

                      if (result.success) {
                        showToast('Added to wishlist! ❤️', 'success');
                        // Update badges dynamically
                        updateBadges(result.cartCount || 0, result.cartItemCount || 0, result.wishlistCount);
                        // Update button icon
                        icon.classList.remove('far');
                        icon.classList.add('fas');
                        this.style.color = '#e91e63';
                      } else if (result.redirect) {
                        // Server returned a redirect (e.g., email verification needed)
                        if (result.redirect.includes('/verify-otp')) {
                          showToast('Please verify your email to use wishlist', 'info');
                          setTimeout(() => {
                            window.location.href = result.redirect;
                          }, 1000);
                        } else {
                          showToast(result.message || 'Authentication required', 'error');
                          setTimeout(() => {
                            window.location.href = result.redirect;
                          }, 1000);
                        }
                      } else {
                        showToast(result.message || 'Error adding to wishlist', 'error');
                      }
                    }
                  } catch (err) {
                    console.log('Wishlist error:', err);
                    // Try to check if it's a redirect response
                    try {
                      // If the error is due to JSON parsing of HTML, it might be a redirect
                      // For now, assume any error means authentication issue
                      showToast('Please verify your email to use wishlist', 'info');
                      // Don't redirect immediately, let user decide
                    } catch (innerErr) {
                      showToast('Please login to add items to wishlist', 'error');
                      setTimeout(() => {
                        window.location.href = '/login';
                      }, 1500);
                    }
                  }
                });
              });

              // Check wishlist status on page load
              checkWishlistStatus();

              // Quick view function
              window.quickView = function (productId) {
                // You can implement a modal here
                console.log('Quick view product:', productId);
                showToast('Quick view coming soon!', 'info');
              };

              // Load product reviews
              window.loadReviews = async function (productId) {
                try {
                  const response = await fetch(`/api/products/${productId}/reviews`);
                  const result = await response.json();

                  if (result.success) {
                    const reviewsContainer = document.getElementById('reviews-container');
                    if (!reviewsContainer) return;

                    if (result.reviews.length === 0) {
                      reviewsContainer.innerHTML = '<p style="text-align: center; color: var(--text-muted); padding: 20px;">No reviews yet. Be the first to review!</p>';
                      return;
                    }

                    let html = '';
                    result.reviews.forEach(review => {
                      const date = new Date(review.createdAt).toLocaleDateString('en-IN');
                      const stars = '★'.repeat(review.rating) + '☆'.repeat(5 - review.rating);

                      html += `
                <div class="review-card" style="background: var(--surface); padding: 15px; border-radius: 8px; margin-bottom: 15px; border: 1px solid var(--border);">
                  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                    <div>
                      <strong style="color: var(--text);">${review.user?.name || 'Anonymous'}</strong>
                      ${review.verified ? '<span style="background: #4ade80; color: white; padding: 2px 8px; border-radius: 12px; font-size: 11px; margin-left: 8px;">✓ Verified Purchase</span>' : ''}
                    </div>
                    <span style="color: var(--text-muted); font-size: 12px;">${date}</span>
                  </div>
                  <div style="color: #ffc107; font-size: 18px; margin-bottom: 8px;">${stars}</div>
                  <h4 style="color: var(--text); margin: 10px 0;">${review.title}</h4>
                  <p style="color: var(--text-muted); line-height: 1.6;">${review.comment}</p>
                  <div style="margin-top: 10px;">
                    <button onclick="markHelpful('${review._id}')" style="background: none; border: 1px solid var(--border); padding: 5px 15px; border-radius: 5px; cursor: pointer; color: var(--text-muted);">
                      <i class="fas fa-thumbs-up"></i> Helpful (${review.helpful?.length || 0})
                    </button>
                  </div>
                </div>
              `;
                    });

                    reviewsContainer.innerHTML = html;
                  }
                } catch (error) {
                  console.log('Load reviews error:', error);
                }
              };

              // Mark review as helpful
              window.markHelpful = async function (reviewId) {
                try {
                  const response = await fetch(`/api/reviews/${reviewId}/helpful`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                  });
                  const result = await response.json();

                  if (result.success) {
                    showToast('Review marked as helpful!', 'success');
                    // Reload reviews to update count
                    const productId = document.querySelector('[data-product-id]')?.dataset.productId;
                    if (productId) loadReviews(productId);
                  } else {
                    showToast(result.message, 'error');
                  }
                } catch (error) {
                  showToast('Error marking review as helpful', 'error');
                }
              };

              // Submit review
              window.submitReview = async function (productId) {
                const rating = document.getElementById('review-rating')?.value;
                const title = document.getElementById('review-title')?.value;
                const comment = document.getElementById('review-comment')?.value;

                if (!rating || !title || !comment) {
                  showToast('Please fill all fields', 'error');
                  return;
                }

                try {
                  const response = await fetch(`/api/products/${productId}/review`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ rating, title, comment })
                  });
                  const result = await response.json();

                  if (result.success) {
                    showToast('Review submitted successfully!', 'success');
                    document.getElementById('review-modal').style.display = 'none';
                    loadReviews(productId);
                  } else {
                    showToast(result.message, 'error');
                  }
                } catch (error) {
                  showToast('Error submitting review', 'error');
                }
              };

              // Open review modal
              window.openReviewModal = function (productId) {
                document.getElementById('review-product-id').value = productId;
                document.getElementById('review-modal').style.display = 'flex';
              };

              // Close review modal
              window.closeReviewModal = function () {
                document.getElementById('review-modal').style.display = 'none';
              };

              // Toast notification function
              function showToast(message, type = 'success', actionText = null, actionUrl = null) {
                const toastZone = document.getElementById('toastZone');
                const toast = document.createElement('div');
                toast.className = 'toast ' + type;

                let actionHTML = '';
                if (actionText && actionUrl) {
                  actionHTML = `<a href="${actionUrl}" class="toast-action">${actionText}</a>`;
                }

                toast.innerHTML = `
          <i class="fas fa-${type === 'success' ? 'check-circle' : type === 'error' ? 'times-circle' : 'info-circle'}"></i>
          <span>${message}</span>
          ${actionHTML}
        `;

                toastZone.appendChild(toast);

                setTimeout(() => {
                  toast.classList.add('show');
                }, 10);

                setTimeout(() => {
                  toast.classList.remove('show');
                  setTimeout(() => toast.remove(), 300);
                }, 3000);
              }
            });
          </script>

          <!-- Review Modal -->
          <div id="review-modal"
            style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 9999; align-items: center; justify-content: center;">
            <div
              style="background: var(--surface); padding: 30px; border-radius: 12px; max-width: 500px; width: 90%; max-height: 80vh; overflow-y: auto;">
              <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h3 style="color: var(--text); margin: 0;">Write a Review</h3>
                <button onclick="closeReviewModal()"
                  style="background: none; border: none; font-size: 24px; cursor: pointer; color: var(--text-muted);">&times;</button>
              </div>

              <input type="hidden" id="review-product-id">

              <div style="margin-bottom: 15px;">
                <label style="display: block; font-weight: 600; margin-bottom: 5px; color: var(--text);">Rating</label>
                <select id="review-rating"
                  style="width: 100%; padding: 10px; border: 2px solid var(--border); border-radius: 8px; font-size: 14px;">
                  <option value="5">★★★★★ - Excellent</option>
                  <option value="4">★★★★☆ - Very Good</option>
                  <option value="3">★★★☆☆ - Good</option>
                  <option value="2">★★☆☆☆ - Fair</option>
                  <option value="1">★☆☆☆☆ - Poor</option>
                </select>
              </div>

              <div style="margin-bottom: 15px;">
                <label style="display: block; font-weight: 600; margin-bottom: 5px; color: var(--text);">Review
                  Title</label>
                <input type="text" id="review-title" placeholder="Summarize your experience"
                  style="width: 100%; padding: 10px; border: 2px solid var(--border); border-radius: 8px; font-size: 14px;">
              </div>

              <div style="margin-bottom: 20px;">
                <label style="display: block; font-weight: 600; margin-bottom: 5px; color: var(--text);">Your
                  Review</label>
                <textarea id="review-comment" placeholder="Share your experience with this product" rows="4"
                  style="width: 100%; padding: 10px; border: 2px solid var(--border); border-radius: 8px; font-size: 14px; resize: vertical;"></textarea>
              </div>

              <button onclick="submitReview(document.getElementById('review-product-id').value)" class="btn btn-primary"
                style="width: 100%;">
                <i class="fas fa-paper-plane"></i> Submit Review
              </button>
            </div>
          </div>

          <script src="/js/theme.js"></script>
          <script src="/js/script.js"></script>
</body>

</html>