                      <strong style="color: var(--text-muted); font-size: 13px;">Active Filters:</strong>
                      <% if (filters.search) { %>
                        <span class="filter-tag"
                          style="display: inline-block; background: var(--primary); color: white; padding: 4px 12px; border-radius: 20px; font-size: 12px; margin: 5px 5px 0 10px;">
                          Search: <%= filters.search %> <i class="fas fa-times"></i>
                        </span>
                        <% } %>
                          <% if (filters.category !=='all' ) { %>
                            <span class="filter-tag"
                              style="display: inline-block; background: var(--primary); color: white; padding: 4px 12px; border-radius: 20px; font-size: 12px; margin: 5px 5px 0 10px;">
                              Category: <%= filters.category %> <i class="fas fa-times"></i>
                            </span>
                            <% } %>
                    </div>
                    <% } %>
                </div>

                <% if (products && products.length> 0) { %>
                  <div class="product-grid" id="product-grid">
                    <% products.slice(0, 8).forEach(product=> { %>
                      <article class="product-card" data-product-id="<%= product._id %>"
                        data-category="<%= product.category %>">
                        <div class="product-image">
                          <img src="<%= product.image || 'https://via.placeholder.com/500' %>" alt="<%= product.name %>"
                            loading="lazy" width="500" height="500">
                          <% if (product.stock> 10) { %>
                            <span class="product-badge instock">In Stock</span>
                            <% } else if (product.stock> 0) { %>
                              <span class="product-badge" style="background: #f39c12;">Low Stock</span>
                              <% } else { %>
                                <span class="product-badge" style="background: #e74c3c;">Out of Stock</span>
                                <% } %>
                                  <% if (product.averageRating>= 4.5) { %>
                                    <span class="product-badge-2">Best Seller</span>
                                    <% } %>
                                      <div class="product-overlay">
                                        <button class="overlay-btn wish-it" aria-label="Add to wishlist">
                                          <i class="fas fa-heart"></i>
                                        </button>
                                        <button class="overlay-btn quick-view" data-id="<%= product._id %>"
                                          aria-label="Quick view" onclick="quickView('<%= product._id %>')">
                                          <i class="fas fa-eye"></i>
                                        </button>
                                      </div>
                        </div>
                        <div class="product-details">
                          <div class="pd-brand">
                            <%= product.category || 'Product' %>
                          </div>
                          <h4 class="product-title">
                            <%= product.name %>
                          </h4>
                          <div class="pd-rating">
                            <% const rating=product.averageRating || 0; %>
                              <% for(let i=1; i<=5; i++) { %>
                                <% if (i <=Math.floor(rating)) { %>
                                  <i class="fas fa-star"></i>
                                  <% } else if (i===Math.ceil(rating) && rating % 1 !==0) { %>
                                    <i class="fas fa-star-half-alt"></i>
                                    <% } else { %>
                                      <i class="far fa-star"></i>
                                      <% } %>
                                        <% } %>
                                          <span>(<%= product.numReviews || 0 %>)</span>
                          </div>
                          <div class="product-price">
                            <span class="current-price">₹<%= product.price %></span>
                            <% if (product.oldPrice) { %>
                              <span class="old-price">₹<%= product.oldPrice %></span>
                              <span class="discount-pct">
                                <%= Math.round((1 - product.price / product.oldPrice) * 100) %>% off
                              </span>
                              <% } %>
                          </div>
                          <button class="add-to-cart-btn" data-product-id="<%= product._id %>"
                            data-name="<%= product.name %>" data-price="<%= product.price %>" <%=product.stock===0
                            ? 'disabled style="opacity:0.5;cursor:not-allowed;"' : '' %>>
                            <i class="fas fa-cart-plus"></i>
                            <%= product.stock===0 ? 'Out of Stock' : 'Add to Cart' %>
                          </button>
                        </div>
                      </article>
                      <% }) %>
                  </div>
                  <% } else { %>
