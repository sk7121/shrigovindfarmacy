                    <!-- Category Filter -->
                    <div class="filter-field">
                      <label>
                        <i class="fas fa-filter"></i> Category
                      </label>
                      <select name="category">
                        <option value="all">All Categories</option>
                        <% if (typeof categories !=='undefined' && categories.length> 0) { %>
                          <% categories.forEach(cat=> { %>
                            <option value="<%= cat %>" <%=typeof filters !=='undefined' && filters.category===cat
                              ? 'selected' : '' %>><%= cat %>
                            </option>
                            <% }) %>
                              <% } %>
                      </select>
                    </div>

                    <!-- Submit Button -->
                    <div class="filter-actions">
                      <button type="button" id="filter-submit-btn" class="btn btn-primary">
                        <i class="fas fa-search"></i> Search
                      </button>
                      <button type="button" id="clear-filters-btn" class="btn btn-outline" title="Clear filters">
