    <!-- DYNAMIC CATEGORY SECTIONS -->
    <% if (categories && categories.length > 0) { %>
    <% categories.forEach((cat, catIndex) => { 
        const products = productsByCategory[cat.slug] || [];
        const colorClass = cat.color || 'green';
        const icons = {
          'ayurvedic': 'fas fa-capsules',
          'sashtri': 'fas fa-leaf', 
          'herbal-cosmetics': 'fas fa-heart',
          'fmcg': 'fas fa-soap'
        };
        const subcategories = {
          'ayurvedic': ['All', 'Immunity', 'Stress Relief', 'Digestion', 'Joint Care', 'Liver Care'],
          'sashtri': ['All', 'Rasa Shastra', 'Kwath', 'Churna', 'Asava & Arishta', 'Ghrita'],
          'herbal-cosmetics': ['All', 'Skincare', 'Haircare', 'Bath & Body', 'Face Wash'],
          'fmcg': ['All', 'Food', 'Beverages', 'Personal Care', 'Home Care']
        };
        const btnOutline = {
          'green': 'btn-outline-green',
          'saffron': 'btn-outline-saffron',
          'pink': 'btn-outline-pink',
          'blue': 'btn-outline-blue'
        };
        const descMap = {
          'ayurvedic': 'Classical & modern Ayurvedic formulations. Trusted remedies backed by centuries of wisdom and modern science.',
          'sashtri': 'Traditional classical preparations rooted in ancient Ayurvedic scriptures. Pure, potent, and time-tested formulations.',
          'herbal-cosmetics': 'Natural herbal cosmetics for radiant skin and healthy hair. Chemical-free beauty solutions from nature.',
          'fmcg': 'Fast-moving consumer goods for daily wellness. Quality personal care and household essentials.'
        };
      %>
    <section class="cat-section" id="<%= cat.slug %>" data-cat="<%= cat.slug %>">
      <div class="container">
        <div class="cat-section-head <%= catIndex % 2 === 1 ? 'reverse' : '' %>">
          <div class="csh-left">
            <div class="cat-label-wrap <%= colorClass %>">
              <div class="cat-icon-lg <%= colorClass %>"><i class="<%= cat.icon || icons[cat.slug] || 'fas fa-box' %>"></i></div>
              <div class="cat-label-text">
                <div class="sec-tag" style="background:rgba(<%= colorClass === 'green' ? '28,129,37' : colorClass === 'saffron' ? '230,126,34' : colorClass === 'pink' ? '233,30,99' : '33,150,243' %>,0.1);color:<%= colorClass === 'green' ? '#1c8125' : colorClass === 'saffron' ? '#e67e22' : colorClass === 'pink' ? '#e91e63' : '#2196f3' %>;border-color:rgba(<%= colorClass === 'green' ? '28,129,37' : colorClass === 'saffron' ? '230,126,34' : colorClass === 'pink' ? '233,30,99' : '33,150,243' %>,0.2)"><i class="<%= cat.icon || icons[cat.slug] || 'fas fa-box' %>"></i> Category 0<%= catIndex + 1 %></div>
                <h2 class="section-title" style="text-align:left;"><%= cat.name %></h2>
                <p class="sec-sub" style="text-align:left;"><%= cat.description || descMap[cat.slug] || 'Quality products for your wellness.' %></p>
              </div>
            </div>
          </div>
          <div class="csh-right">
            <div class="cat-meta-chips">
              <span class="cmc <%= colorClass %>"><i class="fas fa-box"></i> <%= cat.productCount || 0 %>+ Products</span>
              <span class="cmc <%= colorClass %>"><i class="fas fa-flask"></i> Lab Tested</span>
            </div>
            <a href="#" class="btn <%= btnOutline[colorClass] %>">View All <%= cat.name %> <i class="fas fa-arrow-right"></i></a>
          </div>
        </div>

        <!-- Sub-filter tags -->
        <div class="cat-tags">
          <% (subcategories[cat.slug] || ['All']).forEach((subcat, subIndex) => { %>
          <button class="ctag <%= colorClass %><%= subIndex === 0 ? ' active' : '' %>" data-tag="<%= subcat === 'All' ? 'all' : subcat.toLowerCase().replace(/[^a-z0-9]+/g, '-') %>" data-cat="<%= cat.slug %>">
            <%= subcat %>
          </button>
          <% }) %>
        </div>

        <div class="product-grid cat-product-grid" id="grid-<%= cat.slug %>">
          <% if (products && products.length > 0) { %>
          <% products.forEach(product => { 
              const discount = product.oldPrice ? Math.round(((product.oldPrice - product.price) / product.oldPrice) * 100) : 0;
              const inStock = product.stock > 0;
            %>

          <div class="product-card" data-product-id="<%= product._id %>" data-category="<%= product.category %>" data-tag="<%= (product.description || '').toLowerCase().includes('immunity') ? 'immunity' : (product.description || '').toLowerCase().includes('stress') ? 'stress' : (product.description || '').toLowerCase().includes('digest') ? 'digestion' : 'all' %>">
            <div class="product-image">
              <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy">
              <span class="product-badge instock"><%= inStock ? 'In Stock' : 'Out of Stock' %></span>
              <% if (product.numReviews > 50) { %>
              <span class="product-badge-2">Best Seller</span>
              <% } %>
              <div class="product-overlay">
                <button class="overlay-btn wish-it" title="Wishlist"><i class="fas fa-heart"></i></button>
                <button class="overlay-btn quick-view" title="Quick View"><i class="fas fa-eye"></i></button>
              </div>
            </div>
            <div class="product-details">
              <div class="pd-brand">shri govind pharma</div>
              <h4 class="product-title"><%= product.name %></h4>
              <div class="pd-rating">
                <% const rating = product.averageRating || 0; %>
                <% for(let i=1; i<=5; i++) { %>
                <% if (i <= Math.floor(rating)) { %>
                <i class="fas fa-star"></i>
                <% } else if (i === Math.ceil(rating) && rating % 1 !== 0) { %>
                <i class="fas fa-star-half-stroke"></i>
                <% } else { %>
                <i class="far fa-star"></i>
                <% } %>
                <% } %>
                <span>(<%= product.numReviews || 0 %>)</span>
              </div>
              <div class="product-price">
                <span class="current-price">₹<%= product.price %></span>
                <% if (product.oldPrice) { %>
                <span class="old-price">₹<%= product.oldPrice %></span>
                <span class="discount-pct"><%= discount %>% off</span>
                <% } %>
              </div>
              <button class="add-to-cart-btn" data-product-id="<%= product._id %>" data-name="<%= product.name %>" data-price="<%= product.price %>">
                <i class="fas fa-cart-plus"></i> Add to Cart
              </button>
            </div>
          </div>
          <% }) %>
          <% } else { %>
          <div class="no-products">
            <i class="fas fa-box-open"></i>
            <h3>No products in this category yet</h3>
            <p>Check back soon for new arrivals!</p>
          </div>
          <% } %>
        </div>
        <div class="cat-load-more">
          <button class="btn <%= btnOutline[colorClass] %> load-more-btn" data-cat="<%= cat.slug %>">Load More <i class="fas fa-arrow-down"></i></button>
        </div>
      </div>
    </section>

    <% if (catIndex < categories.length - 1) { %>
    <!-- DIVIDER -->
    <div class="cat-section-divider"></div>
    <% } %>

    <% }) %>
    <% } %>

    <!-- QUICK VIEW MODAL -->
    <div id="productModal" class="modal">
      <div class="modal-content">
        <button class="modal-close" id="modal-close"><i class="fas fa-times"></i></button>
        <div class="modal-grid">
          <div class="modal-img-side">
