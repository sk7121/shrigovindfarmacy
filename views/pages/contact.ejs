  <!-- ══════════════════════════════════
     FORM + MAP
══════════════════════════════════ -->
  <section class="form-map-sec">
    <div class="container">
      <div class="form-map-grid">

        <!-- ── Contact Form ── -->
        <div class="form-col reveal">
          <span class="section-pill"><i class="fa-solid fa-paper-plane"></i> Send Message</span>
          <h2 class="section-heading">Drop Us a <em>Message</em></h2>
          <p class="section-sub">We'll get back to you within 2 hours on business days.</p>

          <form id="contactForm" novalidate>

            <div class="field-row">
              <div class="field-group">
                <label for="fName">Full Name <span class="req">*</span></label>
                <div class="field-wrap">
                  <i class="fa-regular fa-user ficon"></i>
                  <input type="text" id="fName" placeholder="Ramesh Sharma" autocomplete="name" autocorrect="off">
                </div>
                <span class="field-error" id="err-fName">
                  <i class="fa-solid fa-circle-exclamation"></i> Name is required.
                </span>
              </div>

              <div class="field-group">
                <label for="fPhone">Mobile <span class="req">*</span></label>
                <div class="field-wrap">
                  <i class="fa-solid fa-phone ficon"></i>
                  <input type="tel" id="fPhone" placeholder="9876543210" maxlength="10" inputmode="numeric" autocomplete="tel">
                </div>
                <span class="field-error" id="err-fPhone">
                  <i class="fa-solid fa-circle-exclamation"></i> Enter valid 10-digit number.
                </span>
              </div>
            </div>

            <div class="field-group">
              <label for="fEmail">Email Address <span class="req">*</span></label>
              <div class="field-wrap">
                <i class="fa-regular fa-envelope ficon"></i>
                <input type="email" id="fEmail" placeholder="you@example.com" autocomplete="email">
              </div>
              <span class="field-error" id="err-fEmail">
                <i class="fa-solid fa-circle-exclamation"></i> Enter a valid email address.
              </span>
            </div>

            <div class="field-group">
              <label for="fSubject">Subject <span class="req">*</span></label>
              <div class="field-wrap select-wrap">
                <i class="fa-solid fa-tag ficon"></i>
                <select id="fSubject">
                  <option value="" disabled selected>Choose a topic&hellip;</option>
                  <option value="Product Enquiry">Product Enquiry</option>
                  <option value="Order / Delivery">Order / Delivery</option>
                  <option value="Doctor Consultation">Doctor Consultation</option>
                  <option value="Bulk / Wholesale Order">Bulk / Wholesale Order</option>
                  <option value="Return or Refund">Return or Refund</option>
                  <option value="Feedback / Suggestion">Feedback / Suggestion</option>
                  <option value="Other">Other</option>
                </select>
                <i class="fa-solid fa-chevron-down select-arrow"></i>
              </div>
              <span class="field-error" id="err-fSubject">
                <i class="fa-solid fa-circle-exclamation"></i> Please choose a subject.
              </span>
            </div>

            <div class="field-group">
              <label for="fMsg">
                Message <span class="req">*</span>
                <span class="char-ctr" id="charCtr">0 / 500</span>
              </label>
              <div class="field-wrap">
                <i class="fa-regular fa-comment-dots ficon ficon-top"></i>
                <textarea id="fMsg" rows="5" placeholder="Tell us how we can help&hellip;" maxlength="500"></textarea>
              </div>
              <span class="field-error" id="err-fMsg">
                <i class="fa-solid fa-circle-exclamation"></i> Please write your message.
              </span>
            </div>

            <!-- Privacy + reCAPTCHA row -->
            <div class="captcha-row">
              <label class="check-label">
                <input type="checkbox" id="fAgree">
                <span class="check-box"></span>
                <span>I agree to the <a href="#" class="link-green">Privacy Policy</a></span>
              </label>
              <div class="captcha-badge">
                <i class="fa-solid fa-shield-halved"></i>
                <span>reCAPTCHA</span>
              </div>
            </div>

            <button type="submit" class="submit-btn" id="submitBtn">
              <span class="sbtn-text">
                <i class="fa-solid fa-paper-plane"></i> Send Message
              </span>
              <span class="sbtn-loader"><span class="spin-ring"></span></span>
            </button>

            <p class="secure-note">
              <i class="fa-solid fa-lock"></i>
              Your info is safe &amp; never shared with anyone.
            </p>

          </form>
        </div>

