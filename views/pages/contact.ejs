              <div>
                <strong>Store Hours</strong>
                <p>Mon&ndash;Sat: 8 AM &ndash; 9 PM<br>Sunday: 9 AM &ndash; 6 PM</p>
              </div>
            </div>
            <div class="store-item">
              <div class="store-ico"><i class="fa-solid fa-landmark"></i></div>
              <div>
                <strong>Landmarks</strong>
                <p>Opp. District Hospital,<br>Near SBI Main Branch</p>
              </div>
            </div>
            <div class="store-item">
              <div class="store-ico"><i class="fa-solid fa-square-parking"></i></div>
              <div>
                <strong>Parking</strong>
                <p>Free street parking<br>available outside store</p>
              </div>
            </div>
          </div>

          <!-- Social links -->
          <div class="social-row">
            <span>Follow us on:</span>
            <div class="social-icons">
              <a href="https://instagram.com/shrigovindpharmacy" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="soc-btn soc-ig">
                <i class="fa-brands fa-instagram"></i>
