<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : '500 - Server Error' %></title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
      background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .container {
      text-align: center;
      background: white;
      padding: 60px 40px;
      border-radius: 20px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
      max-width: 500px;
    }
    h1 {
      font-size: 120px;
      color: #f5576c;
      margin-bottom: 10px;
      line-height: 1;
    }
    h2 {
      font-size: 24px;
      color: #333;
      margin-bottom: 20px;
    }
    p {
      color: #666;
      font-size: 16px;
      margin-bottom: 30px;
      line-height: 1.6;
    }
    .message {
      background: #fff5f5;
      padding: 15px;
      border-radius: 8px;
      margin-bottom: 30px;
      color: #c53030;
      border: 1px solid #feb2b2;
    }
    .error-id {
      background: #f7f7f7;
      padding: 10px 15px;
      border-radius: 6px;
      font-family: monospace;
      font-size: 12px;
      color: #666;
      margin-bottom: 30px;
      display: inline-block;
    }
    a {
      display: inline-block;
      background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
      color: white;
      padding: 15px 40px;
      border-radius: 30px;
      text-decoration: none;
      font-weight: 600;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    a:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 30px rgba(245, 87, 108, 0.4);
    }
    .icon {
      font-size: 60px;
      margin-bottom: 20px;
    }
    .actions {
      display: flex;
      gap: 15px;
      justify-content: center;
      flex-wrap: wrap;
    }
    a.secondary {
      background: #e0e0e0;
    }
    a.secondary:hover {
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }
  </style>
</head>
<body>
  <style>
    .flash {
      padding: 12px 14px;
      border-radius: 14px;
      margin: 18px auto;
      max-width: 980px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 10px;
      border: 1px solid rgba(0,0,0,0.08);
      background: rgba(255, 255, 255, 0.9);
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    }
    .flash.success {
      border-color: rgba(74, 222, 128, 0.4);
      color: #166534;
      background: rgba(74, 222, 128, 0.15);
    }
    .flash.error {
      border-color: rgba(255, 107, 107, 0.4);
      color: #b91c1c;
      background: rgba(254, 202, 202, 0.25);
    }
  </style>
  <% if (success && success.length) { %>
    <div class="flash success"><%= success[0] %></div>
  <% } %>
  <% if (error && error.length) { %>
    <div class="flash error"><%= error[0] %></div>
  <% } %>

  <div class="container">
    <div class="icon">⚠️</div>
    <h1>500</h1>
    <h2><%= typeof title !== 'undefined' ? title : 'Server Error' %></h2>
    <% if (typeof message !== 'undefined') { %>
      <div class="message"><%= message %></div>
    <% } else { %>
      <div class="message">Something went wrong on our end. We're working to fix it!</div>
    <% } %>
    <% if (typeof errorId !== 'undefined') { %>
      <div class="error-id">Error ID: <%= errorId %></div>
    <% } %>
    <div class="actions">
      <a href="/home">← Back to Home</a>
      <a href="javascript:history.back()" class="secondary">Go Back</a>
    </div>
  </div>
</body>
</html>
